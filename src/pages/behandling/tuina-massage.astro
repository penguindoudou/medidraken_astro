---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';

// Images
import tuina_girlImage from '../../assets/images/tuina_girl_wide2.png';
import johannes_mao_profileImage from '../../assets/images/johannes_mao_profile.jpg';
import linnea_mao_profileImage from '../../assets/images/linnea_mao_profile.jpg';
---

<BaseLayout title="TuiNa Medicinsk Massage i Nyköping & Gnesta mot Smärta & Stelhet">
    <!-- ======================================= -->
    <!-- Sektion 1: Toppsektion (Hero)           -->
    <!-- ======================================= -->
    <section class="hero-section min-h-[60vh]">
        <div class="hero-background">
            <Image src={tuina_girlImage} alt="TuiNa Massage Behandling"
                class="hero-bg-image object-[30%_60%] opacity-80" />
        </div>
        <div class="hero-content text-center">
            <h1 class="hero-title text-brand-earth-lighter">TuiNa Massage</h1>
            <div class="hero-text bg-brand-earth-dark/60 p-6 rounded-lg backdrop-blur-sm border border-white/10">
                <h2 class="hero-subtitle font-semibold">Lös Upp Spänningar & Återfå Din Rörlighet</h2>

                <p class="hero-text text-brand-earth-lightest mt-3">
                    Har du smärta, stelhet eller spänningar som begränsar dig i vardagen? TuiNa är en kraftfull och
                    dynamisk
                    massageform från Traditionell Kinesisk Medicin. Genom djupgående tekniker arbetar vi med kroppens
                    muskler, leder och energibanor (Qi) för att harmonisera obalanserna bakom dina besvär.
                </p>
            </div>

            <div class="mt-10">
                <a href="/kontakt/?subject=behandling&sub=terapeutisk#tidsbokning"
                    class="btn btn-primary-on-dark shadow-lg shadow-black/10 px-8 py-4 text-lg mb-0 inline-block">
                    Hör av dig och boka behandling
                </a>
            </div>
        </div>
    </section>

    <!-- ======================================= -->
    <!-- Sektion 2: Symtom & Tillstånd           -->
    <!-- ======================================= -->
    <section class="bg-white border-t border-neutral-100">
        <div class="section-standard">
            <div class="container-base">
                <!-- Unified Header -->
                <div class="text-center max-w-3xl mx-auto mb-16 px-4">
                    <h2 class="text-brand-earth mb-4 uppercase tracking-wide">Fysiska & Stressrelaterade Tillstånd</h2>
                    <p class="text-lg text-neutral-700">
                        TuiNa är en exceptionellt effektiv metod för att arbeta med kroppens muskler och leder, oavsett
                        om du behöver behandla ett akut problem eller vill förbättra din kropps funktion och rörlighet
                        på lång sikt.
                    </p>
                    <p class="text-lg text-neutral-700 mt-3">
                        Det kan vara till hjälp om du upplever något av följande:
                    </p>
                </div>

                <!-- Content Grid: Side-by-Side on Desktop -->
                <div class="grid grid-cols-1 lg:grid-cols-[1.5fr_1fr] gap-8 lg:gap-12 items-start max-w-6xl mx-auto">

                    <!-- Left: Fysiska tillstånd (Accent path) -->
                    <div class="bg-brand-accent/10 rounded-3xl p-6 md:p-8 border border-brand-accent/25 shadow-sm">
                        <div class="flex items-center mb-4 pb-6 border-b border-brand-accent/30">
                            <div
                                class="h-20 w-20 rounded-full bg-brand-accent/10 flex items-center justify-center mr-6 shrink-0">
                                <Icon name="ryggont" class="h-16 w-16 text-brand-accent-dark" />
                            </div>
                            <h3 class="text-brand-earth-dark font-bold text-3xl m-0">Fysiska tillstånd</h3>
                        </div>

                        <!-- 2-column layout inside the left card for physical symptoms -->
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-10">
                            <!-- Column 1: Rygg, nacke och huvud -->
                            <div>
                                <h4 class="text-brand-earth-dark italic font-bold text-xl mb-4 px-2">Rygg, Nacke & Huvud
                                </h4>
                                <ul class="flex flex-col gap-y-4">
                                    <li>
                                        <a href="/symtom/"
                                            class="group flex items-center p-4 -mx-4 sm:mx-0 rounded-2xl hover:bg-white/50 focus:bg-white/80 focus:ring-2 focus:ring-brand-accent/50 active:scale-[0.98] transition-all outline-none">
                                            <div
                                                class="h-16 w-16 shrink-0 rounded-full border border-brand-accent/30 flex items-center justify-center mr-4 group-hover:bg-brand-accent/20 group-hover:border-transparent group-focus:border-brand-earth-dark transition-all">
                                                <Icon name="nackont" class="h-12 w-12 text-brand-accent-dark" />
                                            </div>
                                            <span
                                                class="text-brand-accent-dark font-medium text-lg lg:text-xl group-hover:text-brand-accent group-focus:text-brand-earth-dark transition-all">Nackspärr
                                                & stel nacke</span>
                                        </a>
                                    </li>
                                    <li>
                                        <a href="/symtom/nacke-axlar-skuldror/"
                                            class="group flex items-center p-4 -mx-4 sm:mx-0 rounded-2xl hover:bg-white/50 focus:bg-white/80 focus:ring-2 focus:ring-brand-accent/50 active:scale-[0.98] transition-all outline-none">
                                            <div
                                                class="h-16 w-16 shrink-0 rounded-full border border-brand-accent/30 flex items-center justify-center mr-4 group-hover:bg-brand-accent/20 group-hover:border-transparent group-focus:border-brand-earth-dark transition-all">
                                                <Icon name="nackont" class="h-12 w-12 text-brand-accent-dark" />
                                            </div>
                                            <span
                                                class="text-brand-accent-dark font-medium text-lg lg:text-xl group-hover:text-brand-accent group-focus:text-brand-earth-dark transition-all">Värk
                                                & spänningar i axlar och skuldror</span>
                                        </a>
                                    </li>
                                    <li>
                                        <a href="/symtom/rygg-landrygg/"
                                            class="group flex items-center p-4 -mx-4 sm:mx-0 rounded-2xl hover:bg-white/50 focus:bg-white/80 focus:ring-2 focus:ring-brand-accent/50 active:scale-[0.98] transition-all outline-none">
                                            <div
                                                class="h-16 w-16 shrink-0 rounded-full border border-brand-accent/30 flex items-center justify-center mr-4 group-hover:bg-brand-accent/20 group-hover:border-transparent group-focus:border-brand-earth-dark transition-all">
                                                <Icon name="ryggont" class="h-14 w-14 text-brand-accent-dark" />
                                            </div>
                                            <span
                                                class="text-brand-accent-dark font-medium text-lg lg:text-xl group-hover:text-brand-accent group-focus:text-brand-earth-dark transition-all">Ryggont,
                                                ryggskott & ischias</span>
                                        </a>
                                    </li>
                                    <li>
                                        <a href="/symtom/huvudvark-yrsel/"
                                            class="group flex items-center p-4 -mx-4 sm:mx-0 rounded-2xl hover:bg-white/50 focus:bg-white/80 focus:ring-2 focus:ring-brand-accent/50 active:scale-[0.98] transition-all outline-none">
                                            <div
                                                class="h-16 w-16 shrink-0 rounded-full border border-brand-accent/30 flex items-center justify-center mr-4 group-hover:bg-brand-accent/20 group-hover:border-transparent group-focus:border-brand-earth-dark transition-all">
                                                <Icon name="huvudvark" class="h-12 w-12 text-brand-accent-dark" />
                                            </div>
                                            <span
                                                class="text-brand-accent-dark font-medium text-lg lg:text-xl group-hover:text-brand-accent group-focus:text-brand-earth-dark transition-all">Huvudvärk,
                                                migrän & yrsel</span>
                                        </a>
                                    </li>
                                </ul>
                            </div>

                            <!-- Column 2: Leder, skador och rörlighet -->
                            <div>
                                <h4 class="text-brand-earth-dark italic font-bold text-xl mb-4 px-2">Leder, Skador &
                                    Rörlighet</h4>
                                <ul class="flex flex-col gap-y-4">
                                    <!-- Hoverable Group for Ledvärk with hidden sub-items -->
                                    <li class="group/parent relative">
                                        <a href="/symtom/ledvark-idrottsskador-artros/"
                                            class="group flex items-center p-4 -mx-4 sm:mx-0 rounded-2xl hover:bg-white/50 focus:bg-white/80 focus:ring-2 focus:ring-brand-accent/50 active:scale-[0.98] transition-all outline-none relative z-10">
                                            <div
                                                class="h-16 w-16 shrink-0 rounded-full border border-brand-accent/30 flex items-center justify-center mr-4 group-hover:bg-brand-accent/20 group-hover:border-transparent group-focus:border-brand-earth-dark transition-all">
                                                <Icon name="ledvark" class="h-15 w-15 text-brand-accent-dark" />
                                            </div>
                                            <span
                                                class="text-brand-accent-dark font-medium text-lg lg:text-xl group-hover:text-brand-accent group-focus:text-brand-earth-dark transition-all">Ledvärk,
                                                artros & idrottsskador</span>
                                        </a>

                                        <!-- Sub-items hidden by default, expanding smoothly on hover -->
                                        <div
                                            class="grid grid-rows-[0fr] transition-[grid-template-rows] duration-300 ease-in-out group-hover/parent:grid-rows-[1fr] sm:pl-16 pl-6">
                                            <div class="overflow-hidden">
                                                <ul
                                                    class="flex flex-col opacity-0 group-hover/parent:opacity-100 transition-opacity duration-300 delay-100 pb-2">
                                                    <li class="pt-1">
                                                        <a href="/symtom/ledvark-idrottsskador-artros/ont-i-hofter-hoftbesvar"
                                                            class="group/sub flex items-center p-3 -mx-4 sm:mx-0 rounded-xl hover:bg-white/50 focus:bg-white/80 transition-all outline-none">
                                                            <div
                                                                class="h-10 w-10 shrink-0 rounded-full border border-brand-accent/20 flex items-center justify-center mr-3 group-hover/sub:bg-brand-accent/10 transition-colors">
                                                                <Icon name="ledvark"
                                                                    class="h-10 w-10 text-brand-accent" />
                                                            </div>
                                                            <span
                                                                class="text-brand-accent-dark font-medium group-hover/sub:text-brand-accent transition-colors">Ont
                                                                i höfter & höftbesvär</span>
                                                        </a>
                                                    </li>
                                                    <li>
                                                        <a href="/symtom/ledvark-idrottsskador-artros/ont-i-knan-knabesvar/"
                                                            class="group/sub flex items-center p-3 -mx-4 sm:mx-0 rounded-xl hover:bg-white/50 focus:bg-white/80 transition-all outline-none">
                                                            <div
                                                                class="h-10 w-10 shrink-0 rounded-full border border-brand-accent/20 flex items-center justify-center mr-3 group-hover/sub:bg-brand-accent/10 transition-colors">
                                                                <Icon name="ledvark"
                                                                    class="h-9 w-9 text-brand-accent" />
                                                            </div>
                                                            <span
                                                                class="text-brand-accent-dark font-medium group-hover/sub:text-brand-accent transition-colors">Ont
                                                                i knän & knäbesvär</span>
                                                        </a>
                                                    </li>
                                                </ul>
                                            </div>
                                        </div>
                                    </li>

                                    <li>
                                        <a href="/symtom/ledvark-idrottsskador-artros/tennisarmbage-musarm-vark-i-handleder/"
                                            class="group flex items-center p-4 -mx-4 sm:mx-0 rounded-2xl hover:bg-white/50 focus:bg-white/80 focus:ring-2 focus:ring-brand-accent/50 active:scale-[0.98] transition-all outline-none">
                                            <div
                                                class="h-16 w-16 shrink-0 rounded-full border border-brand-accent/30 flex items-center justify-center mr-4 group-hover:bg-brand-accent/20 group-hover:border-transparent group-focus:border-brand-earth-dark transition-all">
                                                <Icon name="tennisarmbage" class="h-14 w-14 text-brand-accent-dark" />
                                            </div>
                                            <span
                                                class="text-brand-accent-dark font-medium text-lg lg:text-xl group-hover:text-brand-accent group-focus:text-brand-earth-dark transition-all">Tennisarmbåge
                                                & musarm</span>
                                        </a>
                                    </li>
                                    <li>
                                        <a href="/na-dina-halsomal/forbattra-balans-rorlighet-kroppskontroll/"
                                            class="group flex items-center p-4 -mx-4 sm:mx-0 rounded-2xl hover:bg-white/50 focus:bg-white/80 focus:ring-2 focus:ring-brand-accent/50 active:scale-[0.98] transition-all outline-none">
                                            <div
                                                class="h-16 w-16 shrink-0 rounded-full border border-brand-accent/30 flex items-center justify-center mr-4 group-hover:bg-brand-accent/20 group-hover:border-transparent group-focus:border-brand-earth-dark transition-all">
                                                <Icon name="taichi_qigong_flow_min"
                                                    class="h-18 w-18 text-brand-accent-dark" />
                                            </div>
                                            <span
                                                class="text-brand-accent-dark font-medium text-lg lg:text-xl group-hover:text-brand-accent group-focus:text-brand-earth-dark transition-all">Förbättra
                                                rörlighet & kroppskontroll</span>
                                        </a>
                                    </li>
                                </ul>
                            </div>
                        </div>

                        <div class="mt-8">
                            <a href="/symtom/"
                                class="btn-tertiary inline-flex items-center group text-sm font-bold uppercase tracking-wider text-brand-accent-dark hover:text-brand-accent hover:translate-x-1 focus:text-brand-earth-dark active:scale-95 transition-all outline-none">
                                <span class="pb-1">Visa alla besvär vi kan hjälpa dig med</span>
                                <span
                                    class="ml-2 transform transition-transform group-hover:translate-x-1">&rarr;</span>
                            </a>
                        </div>
                    </div>

                    <!-- Right: Stressrelaterad box (Sky path) -->
                    <div class="bg-brand-sky/5 rounded-3xl p-6 md:p-8 border border-brand-sky/10 shadow-sm h-full">
                        <div class="flex items-center mb-10 pb-6 border-b border-brand-sky/20">
                            <div
                                class="h-20 w-20 shrink-0 rounded-full bg-brand-sky/10 flex items-center justify-center mr-6">
                                <Icon name="stress3" class="h-18 w-18 text-brand-sky" />
                            </div>
                            <h3 class="text-brand-sky font-bold text-3xl m-0 leading-tight">Stressrelaterade tillstånd
                            </h3>
                        </div>

                        <ul class="space-y-6 mt-5">
                            <li>
                                <a href="/symtom/nacke-axlar-skuldror/"
                                    class="group flex items-center p-4 -mx-4 sm:mx-0 rounded-2xl hover:bg-white/50 focus:bg-white/80 focus:ring-2 focus:ring-brand-sky/30 active:scale-[0.98] transition-all outline-none">
                                    <div
                                        class="h-16 w-16 shrink-0 rounded-full border border-brand-sky/30 flex items-center justify-center mr-5 group-hover:bg-brand-sky/20 group-hover:border-transparent group-focus:border-brand-sky-dark transition-all">
                                        <Icon name="stress3" class="h-14 w-14 text-brand-sky" />
                                    </div>
                                    <span
                                        class="text-neutral-700 font-medium text-lg lg:text-xl group-hover:text-brand-sky group-focus:text-brand-sky-dark transition-all">Stressrelaterade
                                        muskelspänningar</span>
                                </a>
                            </li>
                            <li>
                                <a href="/symtom/somnproblem-insomnia/"
                                    class="group flex items-center p-4 -mx-4 sm:mx-0 rounded-2xl hover:bg-white/50 focus:bg-white/80 focus:ring-2 focus:ring-brand-sky/30 active:scale-[0.98] transition-all outline-none">
                                    <div
                                        class="h-16 w-16 shrink-0 rounded-full border border-brand-sky/30 flex items-center justify-center mr-5 group-hover:bg-brand-sky/20 group-hover:border-transparent group-focus:border-brand-sky-dark transition-all">
                                        <Icon name="broken_moon_with_stars" class="h-10 w-10 text-brand-sky" />
                                    </div>
                                    <span
                                        class="text-neutral-700 font-medium text-lg lg:text-xl group-hover:text-brand-sky group-focus:text-brand-sky-dark transition-all">Sömnproblem
                                        & Insomnia</span>
                                </a>
                            </li>
                            <li>
                                <a href="/symtom/utbrandhet-trotthet/"
                                    class="group flex items-center p-4 -mx-4 sm:mx-0 rounded-2xl hover:bg-white/50 focus:bg-white/80 focus:ring-2 focus:ring-brand-sky/30 active:scale-[0.98] transition-all outline-none">
                                    <div
                                        class="h-16 w-16 shrink-0 rounded-full border border-brand-sky/30 flex items-center justify-center mr-5 group-hover:bg-brand-sky/20 group-hover:border-transparent group-focus:border-brand-sky-dark transition-all">
                                        <Icon name="outlined_wilted_leaf" class="h-10 w-10 text-brand-sky" />
                                    </div>
                                    <span
                                        class="text-neutral-700 font-medium text-lg lg:text-xl group-hover:text-brand-sky group-focus:text-brand-sky-dark transition-all">Utbrändhet
                                        & Trötthet</span>
                                </a>
                            </li>
                            <li>
                                <a href="/symtom/ofta-forkyld/"
                                    class="group flex items-center p-4 -mx-4 sm:mx-0 rounded-2xl hover:bg-white/50 focus:bg-white/80 focus:ring-2 focus:ring-brand-sky/30 active:scale-[0.98] transition-all outline-none">
                                    <div
                                        class="h-16 w-16 shrink-0 rounded-full border border-brand-sky/30 flex items-center justify-center mr-5 group-hover:bg-brand-sky/20 group-hover:border-transparent group-focus:border-brand-sky-dark transition-all">
                                        <Icon name="broken_shield" class="h-12 w-12 text-brand-sky" />
                                    </div>
                                    <span
                                        class="text-neutral-700 font-medium text-xl group-hover:text-brand-sky group-focus:text-brand-sky-dark transition-all">Ofta
                                        förkyld</span>
                                </a>
                            </li>
                        </ul>

                        <div class="mt-8">
                            <a href="/na-dina-halsomal/"
                                class="btn-tertiary inline-flex items-center group text-sm font-bold uppercase tracking-wider text-brand-sky hover:text-brand-sky-light hover:translate-x-1 focus:text-brand-sky-dark active:scale-95 transition-all outline-none">
                                <span class="pb-1">Visa alla besvär vi kan hjälpa dig med</span>
                                <span
                                    class="ml-2 transform transition-transform group-hover:translate-x-1">&rarr;</span>
                            </a>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </section>

    <!-- ======================================= -->
    <!-- Sektion 3: Hur Fungerar TuiNa?          -->
    <!-- ======================================= -->
    <section class="section-standard bg-brand-earth-lightest border-t border-neutral-100">
        <div class="container-base max-w-5xl">
            <div class="text-center mb-10 md:mb-14">
                <h2 class="text-brand-earth mb-4">Hur Fungerar TuiNa?</h2>
                <p class="text-lg text-neutral-700 max-w-2xl mx-auto">
                    TuiNa kombinerar olika handtekniker för att professionellt bearbeta kroppens muskler och
                    energisystem, med målet att åtgärda rotsaken till din smärta, värk och stelhet.
                </p>
            </div>

            <!-- Unified Container for Context & Coherence -->
            <div class="relative">

                <!-- Visual 3-Step Journey -->
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8 relative z-10">

                    <!-- Step 1: Blockage -->
                    <div
                        class="relative z-10 flex flex-col items-center text-center p-6 md:p-8 bg-brand-accent/5 rounded-3xl border border-brand-accent/20 shadow-sm transition-transform hover:-translate-y-1">
                        <div
                            class="h-16 w-16 rounded-full bg-brand-earth/10 flex items-center justify-center mb-6 ring-4 ring-brand-earth/5">
                            <Icon name="ryggont" class="h-13 w-13 text-brand-earth" />
                        </div>
                        <h3 class="text-lg md:text-xl font-bold text-brand-earth-dark mb-3">1. Smärta & Stelhet</h3>
                        <p class="text-neutral-600 text-sm">
                            Blockeringar i kroppens muskler och energisystem skapar djupa spänningar, vilket ofta
                            resulterar i ihållande smärta och minskad rörlighet.
                        </p>
                    </div>

                    <!-- Step 2: Processing -->
                    <div
                        class="relative z-10 flex flex-col items-center text-center p-6 md:p-8 bg-brand-accent/5 rounded-3xl border border-brand-accent/20 shadow-md transform md:-translate-y-6 transition-transform hover:-translate-y-1 md:hover:-translate-y-7">
                        <div
                            class="h-16 w-16 rounded-full bg-brand-accent/10 flex items-center justify-center mb-6 ring-4 ring-brand-earth/5">
                            <Icon name="lightening" stroke-width="1.5" class="h-14 w-14 text-brand-accent-dark" />
                        </div>
                        <h3 class="text-lg md:text-xl font-bold text-brand-earth-dark mb-3">2. Lös Upp Blockeringar</h3>
                        <p class="text-neutral-700 text-sm">
                            Genom ett brett spektrum av handtekniker – från tryck på specifika punkter till knådning –
                            bearbetar vi djupt för att stärka kroppen och lösa upp spänningar.
                        </p>
                    </div>

                    <!-- Step 3: Harmony -->
                    <div
                        class="relative z-10 flex flex-col items-center text-center p-6 md:p-8 bg-brand-accent/5 rounded-3xl border border-brand-accent/20 shadow-sm transition-transform hover:-translate-y-1">
                        <div
                            class="h-16 w-16 rounded-full bg-brand-sky/10 flex items-center justify-center mb-6 ring-4 ring-brand-earth/5">
                            <Icon name="holistic_qi_human" class="h-14 w-14 text-brand-sky" />
                        </div>
                        <h3 class="text-lg md:text-xl font-bold text-brand-earth-dark mb-3">3. Mjukare Kropp & Harmoni
                        </h3>
                        <p class="text-neutral-600 text-sm">
                            Resultatet är en mjukare, mer avslappnad kropp med förbättrad rörlighet och harmoni i
                            vardagen.
                        </p>
                    </div>

                </div>

                <p class="italic text-center text-neutral-600 mt-12 mb-2 relative z-10">
                    Föredrar du en skön och avkopplande upplevelse? <a href="/behandling/oljemassage/"
                        class="text-brand-sky hover:text-brand-sky-dark hover:underline font-medium">Läs mer om
                        Oljemassage</a>
                </p>
            </div>
        </div>
    </section>

    <!-- ======================================= -->
    <!-- Sektion 5: Om terapeuterna              -->
    <!-- ======================================= -->
    <section class="section-standard bg-white pt-16 pb-8 border-t border-neutral-100">
        <div class="container-base max-w-4xl text-center">
            <h2 class="text-brand-earth mb-4">Möt Din Terapeut</h2>
            <p class="text-lg text-neutral-700 max-w-2xl mx-auto mb-12">
                Hos oss utförs TuiNa av våra erfarna terapeuter Johannes och Linnéa Mao. Deras samlade expertis
                garanterar en behandling som är anpassad för dina behov.
            </p>

            <div class="max-w-4xl mx-auto px-4 grid grid-cols-1 lg:grid-cols-2 gap-6">
                <!-- Johannes -->
                <article
                    class="team-card flex-row bg-brand-accent/5 border border-brand-earth/10 text-left overflow-hidden min-h-[11rem] shadow-sm">
                    <div class="relative w-28 md:w-36 shrink-0 self-stretch overflow-hidden">
                        <Image src={johannes_mao_profileImage} alt="Johannes Mao"
                            class="absolute inset-0 h-full w-full object-cover object-top" />
                    </div>
                    <div class="team-content justify-center py-4 pl-5">
                        <h3 class="team-name text-lg group-hover/link:text-brand-accent transition-colors">Johannes Mao
                        </h3>
                        <p class="team-role text-xs">Grundare, Terapeut & Huvudinstruktör</p>
                        <div class="team-bio">
                            <p class="text-sm leading-relaxed">Med över 30 års erfarenhet och en bakgrund som farmaceut
                                anpassar Johannes tidlös visdom för att hjälpa dig uppnå optimal hälsa.</p>
                        </div>
                    </div>
                </article>

                <!-- Linnéa -->
                <article
                    class="team-card flex-row bg-brand-accent/5 border border-brand-earth/10 text-left overflow-hidden min-h-[11rem] shadow-sm">
                    <div class="relative w-28 md:w-36 shrink-0 self-stretch overflow-hidden">
