---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';
---

<BaseLayout title="Nå Dina Hälsomål - Medidraken">
    <!-- ======================================= -->
    <!-- Huvudsektion för Hälsomål               -->
    <!-- ======================================= -->
    <section class="bg-white pt-12 pb-16">
        <div class="section-standard">
            <div class="container-base">
                <!-- Sidans Introduktion -->
                <div class="text-center max-w-4xl mx-auto mb-16 px-4 pt-4">
                    <h1 class="text-brand-earth-dark mb-6 text-4xl md:text-5xl leading-tight">Ta nästa steg mot ett friskare liv</h1>
                    <p class="text-xl text-neutral-700 mt-4 leading-relaxed max-w-3xl mx-auto">
                        Vill du hitta inre ro, stärka kroppen eller öka din dagliga energi? 
                    </p>
                    <p class="text-xl text-neutral-700 mt-4 leading-relaxed max-w-3xl mx-auto">
                        Vi har beprövade metoder för att hjälpa dig nå dina hälsomål. Välj det område du vill fokusera på nedan.
                    </p>
                </div>

                <!-- Content Grid: Side-by-Side on Desktop -->
                <div class="grid grid-cols-1 lg:grid-cols-[1.5fr_1fr] gap-8 lg:gap-12 items-start max-w-7xl mx-auto">
                    
                    <!-- Vänster: Fysisk Balans & Styrka (Accent path) -->
                    <div class="bg-brand-accent/10 rounded-3xl p-8 border border-brand-accent/25 shadow-sm h-full">
                        <div class="flex items-center mb-10 pb-6 border-b border-brand-accent/30">
                            <div class="h-20 w-20 rounded-full bg-brand-accent/10 flex items-center justify-center mr-6 shrink-0">
                                <Icon name="taichi_yinyang_mabu" class="h-16 w-16 text-brand-accent-dark" />
                            </div>
                            <h2 class="text-brand-earth-dark font-bold text-3xl m-0 leading-tight">Fysisk Balans & Styrka</h2>
                        </div>

                        <ul class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-6">
                            <!-- Förbättra balans -->
                            <li>
                                <a href="/na-dina-halsomal/forbattra-balans-rorlighet-kroppskontroll/"
                                    class="group flex items-center p-4 -mx-4 sm:mx-0 rounded-2xl hover:bg-white/50 focus:bg-white/80 focus:ring-2 focus:ring-brand-accent/50 active:scale-[0.98] transition-all outline-none">
                                    <div class="h-16 w-16 shrink-0 rounded-full border border-brand-accent/30 flex items-center justify-center mr-4 group-hover:bg-brand-accent/20 group-hover:border-transparent group-focus:border-brand-earth-dark transition-all">
                                        <Icon name="taichi_yinyang_gongbu" class="h-12 w-12 text-brand-accent-dark" />
                                    </div>
                                    <span class="text-brand-accent-dark font-medium text-lg lg:text-xl group-hover:text-brand-accent group-focus:text-brand-earth-dark transition-all">Förbättra balans & rörlighet</span>
                                </a>
                            </li>

                            <!-- Stärka immunförsvaret -->
                            <li>
                                <a href="/na-dina-halsomal/starka-immunforsvaret-bygga-motstandskraft/"
                                    class="group flex items-center p-4 -mx-4 sm:mx-0 rounded-2xl hover:bg-white/50 focus:bg-white/80 focus:ring-2 focus:ring-brand-accent/50 active:scale-[0.98] transition-all outline-none">
                                    <div class="h-16 w-16 shrink-0 rounded-full border border-brand-accent/30 flex items-center justify-center mr-4 group-hover:bg-brand-accent/20 group-hover:border-transparent group-focus:border-brand-earth-dark transition-all">
                                        <Icon name="shield_health" class="h-12 w-12 text-brand-accent-dark" />
                                    </div>
                                    <span class="text-brand-accent-dark font-medium text-lg lg:text-xl group-hover:text-brand-accent group-focus:text-brand-earth-dark transition-all">Stärka immunförsvaret</span>
                                </a>
                            </li>

                            <!-- Öka energi -->
                            <li class="col-span-1 sm:col-span-2 mt-2">
                                <a href="/na-dina-halsomal/oka-energi-livskraft/"
                                    class="group flex items-center p-4 -mx-4 sm:mx-0 rounded-2xl hover:bg-white/50 focus:bg-white/80 focus:ring-2 focus:ring-brand-accent/50 active:scale-[0.98] transition-all outline-none">
                                    <div class="h-16 w-16 shrink-0 rounded-full border border-brand-accent/30 flex items-center justify-center mr-4 group-hover:bg-brand-accent/20 group-hover:border-transparent group-focus:border-brand-earth-dark transition-all">
                                        <Icon name="lightening" class="h-12 w-12 text-brand-accent-dark" stroke-width="1.7"/>
                                    </div>
                                    <span class="text-brand-accent-dark font-medium text-lg lg:text-xl group-hover:text-brand-accent group-focus:text-brand-earth-dark transition-all">Öka energi & livskraft</span>
                                </a>
                            </li>
                        </ul>
                    </div>

                    <!-- Höger: Mental Klarhet & Lugn (Sky path) -->
                    <div class="bg-brand-sky/5 rounded-3xl p-8 border border-brand-sky/10 shadow-sm h-full">
                        <div class="flex items-center mb-10 pb-6 border-b border-brand-sky/20">
                            <div class="h-20 w-20 shrink-0 rounded-full bg-brand-sky/10 flex items-center justify-center mr-6">
                                <Icon name="flower" class="h-12 w-12 text-brand-sky" />
                            </div>
                            <h2 class="text-brand-sky font-bold text-3xl m-0 leading-tight">Mental Klarhet & Lugn</h2>
                        </div>

                        <ul class="space-y-6 mt-5">
                            <!-- Minska stress -->
                            <li>
                                <a href="/na-dina-halsomal/minska-stress-hitta-inre-lugn/" class="group flex items-center p-4 -mx-4 rounded-2xl hover:bg-white/50 focus:bg-white/80 focus:ring-2 focus:ring-brand-sky/30 active:scale-[0.98] transition-all outline-none">
                                    <div class="h-16 w-16 shrink-0 rounded-full border border-brand-sky/30 flex items-center justify-center mr-5 group-hover:bg-brand-sky/20 group-hover:border-transparent group-focus:border-brand-sky-dark transition-all">
                                        <Icon name="Yin_yang" class="h-10 w-10 text-brand-sky" />
                                    </div>
                                    <span class="text-neutral-700 font-medium text-lg lg:text-xl group-hover:text-brand-sky group-focus:text-brand-sky-dark transition-all">Minska stress & hitta inre lugn</span>
                                </a>
                            </li>

                            <!-- Stärka fokus -->
                            <li>
                                <a href="/na-dina-halsomal/starka-fokus-mental-styrka/" class="group flex items-center p-4 -mx-4 rounded-2xl hover:bg-white/50 focus:bg-white/80 focus:ring-2 focus:ring-brand-sky/30 active:scale-[0.98] transition-all outline-none">
                                    <div class="h-16 w-16 shrink-0 rounded-full border border-brand-sky/30 flex items-center justify-center mr-5 group-hover:bg-brand-sky/20 group-hover:border-transparent group-focus:border-brand-sky-dark transition-all">
                                        <Icon name="bullseye-arrow-svgrepo-com" class="h-12 w-12 text-brand-sky" />
                                    </div>
                                    <span class="text-neutral-700 font-medium text-lg lg:text-xl group-hover:text-brand-sky group-focus:text-brand-sky-dark transition-all">Stärka fokus & mental styrka</span>
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- ======================================= -->
    <!-- CTA: Redo att ta första steget?         -->
    <!-- ======================================= -->
    <section class="bg-brand-earth-light section-standard text-center border-t border-neutral-100">
        <div class="container-base max-w-4xl">
            <!-- Huvud CTA -->
            <div class="max-w-3xl mx-auto mb-16">
                <h2 class="text-brand-earth-dark mb-6 text-3xl md:text-5xl">Osäker på var du ska börja?</h2>
                <p class="text-brand-earth-dark text-lg md:text-xl leading-relaxed mb-10">
                    Hör av dig så hjälper vi dig att ta reda på vilka behandlingar eller träningsformer som passar just dig och dina mål bäst.
                </p>

                <a href="/kontakt/?subject=radgivning"
                    class="btn btn-primary-on-dark shadow-lg shadow-black/10 px-10 py-5 text-xl mb-0">
                    Få rådgivning
                </a>
            </div>

            <!-- Trust & Info Row (Discrete boxes with icon containers) -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8 pt-6 mt-0 border-t border-brand-earth-dark/10">

                <!-- Column 1: Platser -->
                <div
                    class="group bg-brand-earth-dark/5 rounded-2xl p-6 shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-300 border-2 border-brand-earth-dark/10 flex flex-col items-start text-left">
                    <div class="flex items-center mb-4">
                        <div
                            class="flex items-center justify-center h-10 w-10 rounded-full bg-brand-earth-dark/25 mr-3">
                            <div class="relative flex h-3 w-3 items-center justify-center">
                                <span
                                    class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-accent opacity-75"></span>
                                <span class="relative inline-flex rounded-full h-2 w-2 bg-brand-accent"></span>
                            </div>
                        </div>
                        <span class="font-bold text-brand-earth-dark text-xl">Platser</span>
                    </div>
                    <div class="text-neutral-700 leading-relaxed text-sm md:text-base flex-grow">
                        Våra behandlingar och kurser hålls i <a href="/kontakt/#mottagningar"
                            class="text-brand-sky hover:text-brand-sky-dark font-medium underline decoration-brand-sky/20 underline-offset-4">Nyköping</a>,
                        <a href="/kontakt/#mottagningar"
                            class="text-brand-sky hover:text-brand-sky-dark font-medium underline decoration-brand-sky/20 underline-offset-4">Gnesta</a>
                        och <a href="/kontakt/#mottagningar"
                            class="text-brand-sky hover:text-brand-sky-dark font-medium underline decoration-brand-sky/20 underline-offset-4">Oxelösund</a>.
                    </div>
                    <a href="/kontakt/#mottagningar"
                        class="text-brand-sky hover:text-brand-sky-dark font-medium flex items-center mt-4 group-hover:translate-x-1 transition-transform">Se alla adresser &rarr;</a>
                </div>

                <!-- Column 2: Friskvård -->
                <div
                    class="group bg-brand-earth-dark/5 rounded-2xl p-6 shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-300 border-2 border-brand-earth-dark/10 flex flex-col items-start text-left">
                    <div class="flex items-center mb-4">
                        <div
                            class="flex items-center justify-center h-10 w-10 rounded-full bg-brand-earth-dark/25 text-brand-accent mr-3">
                            <Icon name="shield_health" class="h-6 w-6" />
                        </div>
                        <span class="font-bold text-brand-earth-dark text-xl">Friskvårdsbidrag</span>
                    </div>
                    <div class="text-neutral-700 leading-relaxed text-sm md:text-base flex-grow">
                        Använd ditt Friskvårdsbidrag! Alla våra kurser och behandlingar är godkända.<br />
                    </div>
                    <a href="/friskvardsbidrag/"
                        class="text-brand-sky hover:text-brand-sky-dark font-medium flex items-center mt-4 group-hover:translate-x-1 transition-transform">Läs
                        mer &rarr;</a>
                </div>

                <!-- Column 3: Presentkort -->
                <div
                    class="group bg-brand-earth-dark/5 rounded-2xl p-6 shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-300 border-2 border-brand-earth-dark/10 flex flex-col items-start text-left">
                    <div class="flex items-center mb-4">
                        <div
                            class="flex items-center justify-center h-10 w-10 rounded-full bg-brand-earth-dark/25 text-brand-accent mr-3">
                            <Icon name="present" class="h-6 w-6" />
                        </div>
                        <span class="font-bold text-brand-earth-dark text-xl">Presentkort</span>
                    </div>
                    <div class="text-neutral-700 leading-relaxed text-sm md:text-base flex-grow">
                        Ge bort en upplevelse av hälsa och vitalitet med ett presentkort hos oss.<br />
                    </div>
                    <a href="/presentkort/"
                        class="text-brand-sky hover:text-brand-sky-dark font-medium flex items-center mt-4 group-hover:translate-x-1 transition-transform">Läs
                        mer &rarr;</a>
                </div>

            </div>
        </div>
    </section>
</BaseLayout>
