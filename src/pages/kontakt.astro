---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';

// Images
import johannesImage from '../assets/images/johannes_mao_profile.jpg';
import linneaImage from '../assets/images/linnea_mao_profile.jpg';
import { siteConfig } from '../data/site.ts';
import { coursesTaiChi, coursesQigong } from '../data/courses.ts';

// Helpers for prefilling next upcoming helgkurs
const today = new Date().setHours(0, 0, 0, 0);
const nextTaiChi = coursesTaiChi.find(c => new Date(c.lastDate).getTime() >= today);
const nextQigong = coursesQigong.find(c => new Date(c.lastDate).getTime() >= today);
---

<BaseLayout title="Kontakt">
    <!-- Introduktion: Kontakta Oss (Vit Bakgrund) -->
    <section class="pt-20 lg:pt-28 pb-6 lg:pb-12 bg-white relative overflow-hidden">
        <div class="container-base">

            <!-- Rad 1: Intro & Dekorativ Icon -->
            <div class="grid grid-cols-1 lg:grid-cols-[1.0fr_0.8fr] gap-12 lg:gap-4 items-center">
                <!-- Vänster: Intro -->
                <div class="max-w-xl lg:ml-auto">
                    <h1 class="text-brand-earth-dark mb-6">Kontakta Oss</h1>
                    <div class="space-y-4 text-lg text-neutral-800 leading-relaxed">
                        <p>Vi ser fram emot att höra från dig!</p>

                        <p>
                            Oavsett om du har en fråga, vill anmäla ditt intresse för en kurs eller boka en behandling,
                            är du varmt välkommen att höra av dig.
                        </p>

                        <p>
                            För snabbast svar rekommenderar vi att du ringer <a href={`tel:${siteConfig.phone.clean}`}
                                class="text-brand-sky-dark hover:text-brand-accent-dark font-bold transition-colors underline decoration-brand-sky/30 underline-offset-4">{siteConfig.phone.display}</a>
                            eller använder formuläret
                            nedan.
                        </p>
                    </div>
                </div>
                <!-- Höger: Dekorativ Grafik -->
                <div class="hidden lg:flex justify-center pr-4 opacity-40 text-brand-accent-dark">
                    <Icon name="taichi_qigong_flow" class="w-full max-w-[250px] h-auto" />
                </div>
            </div>
        </div>
    </section>

    <!-- Huvudinnehåll: Tidsbokning & Formulär (Ljus Jord-bakgrund) -->
    <section class="pb-20 lg:pb-28 bg-brand-earth-lightest relative overflow-hidden">
        <div class="container-base space-y-6 lg:space-y-12">

            <!-- Rad 2: Tillgänglighet och Tidsbokning (Flyttad upp) -->
            <div id="tidsbokning"
                class="scroll-mt-20 text-center max-w-5xl mx-auto py-8 lg:py-10 border-y border-brand-earth-light/20">
                <h2 class="text-3xl text-brand-earth-dark font-semibold mb-10">Tillgänglighet och Tidsbokning</h2>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                    <!-- Tidsbokning -->
                    <div
                        class="flex flex-col items-center p-6 bg-white rounded-xl shadow-sm border border-brand-earth-light/20">
                        <div
                            class="w-16 h-16 bg-brand-accent/10 rounded-full flex items-center justify-center mb-4 text-brand-accent-dark">
                            <Icon name="calendar" class="w-10 h-10" />
                        </div>
                        <h4 class="text-xl font-bold text-brand-earth-dark mb-3">Endast tidsbokning</h4>
                        <p class="text-neutral-700 leading-relaxed">
                            Alla behandlingar, kurser och privatlektioner hos Medidraken sker endast efter
                            tidsbokning.
                        </p>
                    </div>

                    <!-- Vanliga tider -->
                    <div
                        class="flex flex-col items-center p-6 bg-white rounded-xl shadow-sm border border-brand-earth-light/20">
                        <div
                            class="w-16 h-16 bg-brand-accent/10 rounded-full flex items-center justify-center mb-4 text-brand-accent-dark">
                            <Icon name="clock" class="w-10 h-10" />
                        </div>
                        <h4 class="text-xl font-bold text-brand-earth-dark mb-3">Vanliga tider</h4>
                        <p class="text-neutral-700 leading-relaxed">
                            Vi erbjuder vanligtvis tider alla dagar i veckan mellan kl. 09:00 och 20:00, men vi är
                            flexibla och kan ofta anpassa oss efter ditt schema.
                        </p>
                    </div>

                    <!-- Kontakta oss -->
                    <div
                        class="flex flex-col items-center p-6 bg-white rounded-xl shadow-sm border border-brand-earth-light/20">
                        <div
                            class="w-16 h-16 bg-brand-accent/10 rounded-full flex items-center justify-center mb-4 text-brand-accent-dark">
                            <Icon name="phone_outline" class="w-10 h-10" />
                        </div>
                        <h4 class="text-xl font-bold text-brand-earth-dark mb-3">Hitta en tid</h4>
                        <p class="text-neutral-700 leading-relaxed">
                            Kontakta oss så hjälper vi dig att hitta en tid som passar dig.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Rad 3: Formulär & Kontaktinfo -->
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20 items-start">
                <!-- Vänster: Formulär -->
                <div
                    class="contact-form-wrapper bg-white shadow-xl shadow-brand-earth/5 p-8 sm:p-10 rounded-2xl border border-brand-earth-light/30">
                    <h3 class="text-2xl text-brand-earth mb-6 font-semibold">Skicka ett Meddelande</h3>

                    <!-- NOTERA TILL UTVECKLARE: Här kan du klistra in din Fluent Forms shortcode typ [fluentform id="1"].
                    Nedan är en välbyggd mockup på hur formuläret ska se ut enligt instruktionerna. -->
                    <form action="#" method="POST" class="space-y-5"
                        x-data="{ 
                            subject: '', 
                            subSubject: '', 
                            location: '', 
                            recipient: 'Okänd', 
                            amount: '',
                            selectedDays: [],
                            selectedTimes: [],
                            selectedTravelPeriods: [],
                            customTravelPeriod: '',
                            specificDate: '',
                            specificTime: '',
                            useSpecificDate: false,
                            isPrefilled: false,
                            prefillSource: ''
                        }" x-init="
                            const params = new URLSearchParams(window.location.search);
                            if (params.has('subject')) subject = params.get('subject');
                            if (params.has('sub')) subSubject = params.get('sub');
                            if (params.has('location')) location = params.get('location');
                            let urlDate = params.has('date') ? params.get('date') : null;
                            let urlTime = params.has('time') ? params.get('time') : null;
                            
                            $watch('subject', value => { 
                                if (params.has('subject') && value !== params.get('subject')) {
                                    urlDate = null;
                                    urlTime = null;
                                }
                                subSubject = '';
                                selectedDays = [];
                                selectedTimes = [];
                                selectedTravelPeriods = [];
                                customTravelPeriod = '';
                                specificDate = urlDate || '';
                                specificTime = urlTime || '';
                                isPrefilled = false;
                            });

                            const applyPrefill = () => {
                                if (subSubject === 'helgkurs') {
                                    if (urlDate || urlTime) {
                                        specificDate = urlDate || '';
                                        specificTime = urlTime || '';
                                        isPrefilled = true;
                                        prefillSource = 'url';
                                        useSpecificDate = true;
                                    } else {
                                        let course = null;
                                        if (subject === 'taichi') course = JSON.parse(document.getElementById('nextTaiChiData').textContent);
                                        if (subject === 'qigong') course = JSON.parse(document.getElementById('nextQigongData').textContent);
                                        
                                        if (course) {
                                            specificDate = course.date;
                                            specificTime = course.times;
                                            isPrefilled = true;
                                            prefillSource = 'auto';
                                            useSpecificDate = true;
                                        }
                                    }
                                } else {
                                    isPrefilled = false;
                                    prefillSource = '';
                                    useSpecificDate = false;
                                }
                            };

                            $watch('subSubject', value => {
                                if (params.has('sub') && value !== '' && value !== params.get('sub')) {
                                    urlDate = null;
                                    urlTime = null;
                                }
                                applyPrefill();
                            });

                            // Run prefill on init if params already set
                            if (subSubject === 'helgkurs') {
                                setTimeout(applyPrefill, 100);
                            } else if (urlDate || urlTime) {
                                specificDate = urlDate || '';
                                specificTime = urlTime || '';
                                useSpecificDate = true;
                            }
                        ">

                    {/* Data for Alpine.js */}
                    <script id="nextTaiChiData" type="application/json" set:html={JSON.stringify(nextTaiChi || null)} />
                    <script id="nextQigongData" type="application/json" set:html={JSON.stringify(nextQigong || null)} />

                        <div>
                            <label for="name" class="block text-sm font-medium text-neutral-700 mb-1">Namn <span
                                    class="text-red-500">*</span></label>
                            <input type="text" id="name" name="name" required
                                class="w-full border-neutral-300 rounded-md shadow-sm focus:border-brand-sky focus:ring focus:ring-brand-sky/20 transition-all p-3 border bg-neutral-50/50">
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                            <div>
                                <label for="email" class="block text-sm font-medium text-neutral-700 mb-1">E-post
                                    <span class="text-red-500">*</span></label>
                                <input type="email" id="email" name="email" required
                                    class="w-full border-neutral-300 rounded-md shadow-sm focus:border-brand-sky focus:ring focus:ring-brand-sky/20 transition-all p-3 border bg-neutral-50/50">
                            </div>
                            <div>
                                <label for="phone" class="block text-sm font-medium text-neutral-700 mb-1">Telefon
                                    <span class="text-red-500">*</span></label>
                                <input type="tel" id="phone" name="phone" required
                                    class="w-full border-neutral-300 rounded-md shadow-sm focus:border-brand-sky focus:ring focus:ring-brand-sky/20 transition-all p-3 border bg-neutral-50/50">
                            </div>
                        </div>

                        <!-- Önskad Ort (Valfritt) -->
                        <div>
                            <label for="location" class="block text-sm font-medium text-neutral-700 mb-1">Önskad
                                ort (valfri)</label>
                            <select id="location" name="location" x-model="location"
                                class="w-full border-neutral-300 rounded-md shadow-sm focus:border-brand-sky focus:ring focus:ring-brand-sky/20 transition-all p-3 border bg-neutral-50/50 bg-white">
                                <option value="">-- Välj ort --</option>
                                <option value="gnesta">Gnesta</option>
                                <option value="nykoping">Nyköping</option>
                                <option value="oxelosund">Oxelösund</option>
                            </select>

                            <!-- Dynamisk adressvisning -->
                            <div x-show="location === 'gnesta'" x-cloak
                                class="mt-2 text-sm text-neutral-600 flex items-start bg-brand-earth-lightest/50 p-2.5 rounded border border-brand-earth-light/20"
                                x-transition>
                                <svg class="w-4 h-4 mr-2 mt-0.5 shrink-0 text-brand-sky-dark" fill="none"
                                    stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z">
                                    </path>
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                </svg>
                                <span><strong>Gnesta:</strong> {siteConfig.addresses.gnesta.full}</span>
                            </div>
                            <div x-show="location === 'nykoping'" x-cloak
                                class="mt-2 text-sm text-neutral-600 flex items-start bg-brand-earth-lightest/50 p-2.5 rounded border border-brand-earth-light/20"
                                x-transition>
                                <svg class="w-4 h-4 mr-2 mt-0.5 shrink-0 text-brand-sky-dark" fill="none"
                                    stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z">
                                    </path>
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                </svg>
                                <span><strong>Nyköping:</strong> {siteConfig.addresses.nykoping.full}</span>
                            </div>
                            <div x-show="location === 'oxelosund'" x-cloak
                                class="mt-2 text-sm text-neutral-600 flex items-start bg-brand-earth-lightest/50 p-2.5 rounded border border-brand-earth-light/20"
                                x-transition>
                                <svg class="w-4 h-4 mr-2 mt-0.5 shrink-0 text-brand-sky-dark" fill="none"
                                    stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z">
                                    </path>
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                </svg>
                                <span><strong>Oxelösund:</strong> {siteConfig.addresses.oxelosund.full}</span>
                            </div>
                        </div>

                        <!-- Main Category -->
                        <div>
                            <label for="subject" class="block text-sm font-medium text-neutral-700 mb-1">Ditt Ärende
                                <span class="text-red-500">*</span></label>
                            <select id="subject" name="subject" required x-model="subject"
                                class="w-full border-neutral-300 rounded-md shadow-sm focus:border-brand-sky focus:ring focus:ring-brand-sky/20 transition-all p-3 border bg-neutral-50/50 bg-white">
                                <option value="">-- Välj ett ärende --</option>
                                <option value="taichi">Tai Chi</option>
                                <option value="qigong">Medicinsk Qigong</option>
                                <option value="instruktorskurs">Instruktörskurs</option>
                                <option value="behandling">Behandling</option>
                                <option value="halsoresa">Hälsoresa till Kina</option>
                                <option value="presentkort">Presentkort</option>
                                <option value="friskvardsbidrag">Friskvårdsbidrag</option>
                                <option value="ovrigt">Övrigt</option>
                            </select>
                        </div>

                        <!-- Sub-Category: Tai Chi & Qigong -->
                        <div x-show="['taichi', 'qigong'].includes(subject)" x-cloak class="mt-4"
                            x-transition:enter="transition ease-out duration-300"
                            x-transition:enter-start="opacity-0 -translate-y-2"
                            x-transition:enter-end="opacity-100 translate-y-0">
                            <label for="course_type" class="block text-sm font-medium text-neutral-700 mb-1">Typ av kurs
                                <span class="text-red-500">*</span></label>
                            <select id="course_type" name="course_type"
                                :required="['taichi', 'qigong'].includes(subject)" x-model="subSubject"
                                class="w-full border-neutral-300 rounded-md shadow-sm focus:border-brand-sky focus:ring focus:ring-brand-sky/20 transition-all p-3 border bg-neutral-50/50 bg-white">
                                <option value="">-- Välj typ av kurs --</option>
                                <option value="helgkurs">Helgkurs</option>
                                <option value="privatkurs">Privatkurs</option>
                                <option value="specifik_forfragan">Specifik förfrågan</option>
                                <option value="vet_ej">Vet ej / Behöver rådgivning</option>
                            </select>
                        </div>

                        <!-- Specifik förfrågan (Text area) -->
                        <div x-show="['taichi', 'qigong'].includes(subject) && subSubject === 'specifik_forfragan'"
                            x-cloak class="mt-4" x-transition:enter="transition ease-out duration-300"
                            x-transition:enter-start="opacity-0 -translate-y-2"
                            x-transition:enter-end="opacity-100 translate-y-0">
                            <label for="specific_request"
                                class="block text-sm font-medium text-neutral-700 mb-1">Beskriv din förfrågan kort <span
                                    class="text-red-500">*</span></label>
                            <input type="text" id="specific_request" name="specific_request"
                                :required="['taichi', 'qigong'].includes(subject) && subSubject === 'specifik_forfragan'"
                                class="w-full border-neutral-300 rounded-md shadow-sm focus:border-brand-sky focus:ring focus:ring-brand-sky/20 transition-all p-3 border bg-neutral-50/50">
                        </div>

                        <!-- Sub-Category: Behandling -->
                        <div x-show="subject === 'behandling'" x-cloak class="mt-4"
                            x-transition:enter="transition ease-out duration-300"
                            x-transition:enter-start="opacity-0 -translate-y-2"
                            x-transition:enter-end="opacity-100 translate-y-0">
                            <label for="behandling_type" class="block text-sm font-medium text-neutral-700 mb-1">Typ av behandling
                                <span class="text-red-500">*</span></label>
                            <select id="behandling_type" name="behandling_type"
                                :required="subject === 'behandling'" x-model="subSubject"
                                class="w-full border-neutral-300 rounded-md shadow-sm focus:border-brand-sky focus:ring focus:ring-brand-sky/20 transition-all p-3 border bg-neutral-50/50 bg-white">
                                <option value="">-- Välj typ av behandling --</option>
                                <option value="terapeutisk">Terapeutisk behandling (TuiNa eller Akupunktur)</option>
                                <option value="oljemassage">Oljemassage</option>
                            </select>

                            <!-- Helper for Terapeutisk -->
                            <div x-show="subSubject === 'terapeutisk'" x-cloak
                                class="mt-3 bg-brand-sky-light/20 p-4 rounded-md border border-brand-sky/30"
                                x-transition>
                                <p class="text-sm text-brand-earth-dark font-medium flex items-start">
                                    <svg class="w-5 h-5 mr-3 shrink-0 text-brand-sky-dark" fill="none" stroke="currentColor"
                                        viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                            d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                    </svg>
                                    <span>Vid terapeutisk behandling baseras valet av behandlingsmetoden på ditt nuvarande tillstånd och terapeutens professionella bedömning i samråd med dig för att ge dig den bästa möjliga hjälpen.</span>
                                </p>
                            </div>
                        </div>

                        <!-- Sub-Category: Presentkort -->
                        <div x-show="subject === 'presentkort'" x-cloak class="mt-4 space-y-4"
                            x-transition:enter="transition ease-out duration-300"
                            x-transition:enter-start="opacity-0 -translate-y-2"
                            x-transition:enter-end="opacity-100 translate-y-0">
                            <div>
                                <label for="giftcard_type" class="block text-sm font-medium text-neutral-700 mb-1">Vad för
                                    typ av presentkort? <span class="text-red-500">*</span></label>
                                <select id="giftcard_type" name="giftcard_type" :required="subject === 'presentkort'"
                                    x-model="subSubject"
                                    class="w-full border-neutral-300 rounded-md shadow-sm focus:border-brand-sky focus:ring focus:ring-brand-sky/20 transition-all p-3 border bg-neutral-50/50 bg-white">
                                    <option value="">-- Välj typ --</option>
                                    <option value="valfritt_belopp">Valfritt belopp</option>
                                    <option value="specifik_behandling">Specifik Behandling</option>
                                    <option value="specifik_kurs">Specifik Kurs</option>
                                    <option value="vet_ej">Vet ej / Behöver rådgivning</option>
                                </select>
                            </div>

                            <div x-show="subSubject === 'valfritt_belopp'" x-cloak x-transition
                                class="bg-brand-sky-light/10 p-4 rounded-lg border border-brand-sky/20">
                                <label for="amount" class="block text-sm font-medium text-neutral-700 mb-1">Önskat belopp (kr) <span class="text-red-500">*</span></label>
                                <input type="number" id="amount" name="amount" x-model="amount" :required="subject === 'presentkort' && subSubject === 'valfritt_belopp'"
                                    class="w-full border-neutral-300 rounded-md shadow-sm focus:border-brand-sky focus:ring focus:ring-brand-sky/20 transition-all p-3 border bg-neutral-50/50"
                                    placeholder="T.ex. 500">
                                <p class="text-xs text-neutral-500 mt-2">Fyll i det belopp du vill ladda presentkortet med.</p>
                            </div>

                            <div class="bg-brand-accent/5 p-4 rounded-lg border border-brand-accent/20">
                                <label for="recipient_name" class="block text-sm font-medium text-neutral-700 mb-1">Mottagarens namn <span class="text-red-500">*</span></label>
                                <input type="text" id="recipient_name" name="recipient_name" x-model="recipient" :required="subject === 'presentkort'"
                                    class="w-full border-neutral-300 rounded-md shadow-sm focus:border-brand-sky focus:ring focus:ring-brand-sky/20 transition-all p-3 border bg-neutral-50/50">
                                <p class="text-xs text-neutral-500 mt-2">Ange namn på mottagaren. Låt det stå <span class="font-semibold text-brand-earth">"Okänd"</span> om du inte vet namnet än.</p>
                            </div>
                        </div>

                        <!-- Sub-Category: Friskvårdsbidrag -->
                        <div x-show="subject === 'friskvardsbidrag'" x-cloak class="mt-4"
                            x-transition:enter="transition ease-out duration-300"
                            x-transition:enter-start="opacity-0 -translate-y-2"
                            x-transition:enter-end="opacity-100 translate-y-0">
                            <label for="friskvard_type" class="block text-sm font-medium text-neutral-700 mb-1">Vad vill
                                du använda friskvårdsbidraget till? <span class="text-red-500">*</span></label>
                            <select id="friskvard_type" name="friskvard_type" :required="subject === 'friskvardsbidrag'"
                                x-model="subSubject"
                                class="w-full border-neutral-300 rounded-md shadow-sm focus:border-brand-sky focus:ring focus:ring-brand-sky/20 transition-all p-3 border bg-neutral-50/50 bg-white">
                                <option value="">-- Välj alternativ --</option>
                                <option value="taichi">Tai Chi</option>
                                <option value="qigong">Medicinsk Qigong</option>
                                <option value="behandling">Behandling</option>
                                <option value="vet_ej">Vet ej / Behöver rådgivning</option>
                            </select>
                        </div>

                        <!-- Övrigt Text Input -->
                        <div x-show="subject === 'ovrigt'" x-cloak class="mt-4"
                            x-transition:enter="transition ease-out duration-300"
                            x-transition:enter-start="opacity-0 -translate-y-2"
                            x-transition:enter-end="opacity-100 translate-y-0">
                            <label for="other_request" class="block text-sm font-medium text-neutral-700 mb-1">Vad
                                gäller ditt ärende? <span class="text-red-500">*</span></label>
                            <input type="text" id="other_request" name="other_request" :required="subject === 'ovrigt'"
                                class="w-full border-neutral-300 rounded-md shadow-sm focus:border-brand-sky focus:ring focus:ring-brand-sky/20 transition-all p-3 border bg-neutral-50/50">
                        </div>

                        <!-- Bokningspreferenser (Tid & Dag) -->
                        <div x-show="['taichi', 'qigong', 'behandling', 'instruktorskurs'].includes(subject)" x-cloak class="mt-8 space-y-6 border-t border-brand-earth-light/20 pt-8" x-transition>
                            <h4 class="text-xl font-bold text-brand-earth-dark flex items-center">
                                <Icon name="clock" class="w-6 h-6 mr-3 text-brand-accent-dark" />
                                Tidspreferenser <span class="text-sm font-normal text-neutral-500 ml-2">(valfritt)</span>
                            </h4>

                            <!-- Toggle: Specifikt vs Generellt -->
                            <div class="inline-flex bg-neutral-100/80 p-1 rounded-lg border border-neutral-200 w-full sm:w-auto mt-2 mb-4">
                                <button type="button" 
                                    @click="useSpecificDate = false"
                                    :class="!useSpecificDate ? 'bg-white text-brand-earth-dark shadow-sm ring-1 ring-black/5' : 'text-neutral-500 hover:text-neutral-700 hover:bg-neutral-200/50'"
                                    class="flex-1 sm:flex-none px-5 py-2.5 text-sm font-semibold rounded-md transition-all duration-200">
                                    Generella tider
                                </button>
                                <button type="button" 
                                    @click="useSpecificDate = true"
                                    :class="useSpecificDate ? 'bg-white text-brand-earth-dark shadow-sm ring-1 ring-black/5' : 'text-neutral-500 hover:text-neutral-700 hover:bg-neutral-200/50'"
                                    class="flex-1 sm:flex-none px-5 py-2.5 text-sm font-semibold rounded-md transition-all duration-200">
                                    Specifika tider
                                </button>
                            </div>

                            <!-- Specifikt Datum & Tid (Visas när toggle är PÅ) -->
                            <div x-show="useSpecificDate" x-cloak class="space-y-4 bg-brand-accent/5 p-5 rounded-xl border border-brand-accent/20" x-transition>
                                <div class="flex items-center justify-between mb-2">
                                    <label class="block text-sm font-bold text-brand-earth-dark">Önskat datum & tid</label>
                                    <template x-if="isPrefilled">
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-brand-sky-light/30 text-brand-sky-dark border border-brand-sky/20 transition-all">
                                            <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                            <span x-text="prefillSource === 'url' ? 'Förifyllt för vald kurs' : 'Förifyllt för nästa kurs'"></span>
                                        </span>
                                    </template>
                                </div>
                                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                                    <div>
                                        <input type="text" x-model="specificDate" name="specific_date" placeholder="ÅÅÅÅ-MM-DD"
                                            class="w-full border-neutral-300 rounded-md shadow-sm focus:border-brand-sky focus:ring focus:ring-brand-sky/20 transition-all p-3 border bg-white">
                                        <p class="text-[11px] text-neutral-500 mt-1.5 leading-tight">Önskat datum (t.ex. 14-15 Okt eller 2026-05-12)</p>
                                    </div>
                                    <div>
                                        <input type="text" x-model="specificTime" name="specific_time" placeholder="HH:MM"
                                            class="w-full border-neutral-300 rounded-md shadow-sm focus:border-brand-sky focus:ring focus:ring-brand-sky/20 transition-all p-3 border bg-white">
                                        <p class="text-[11px] text-neutral-500 mt-1.5 leading-tight">Önskad tid (t.ex. 10:00-15:00 eller Eftermiddag)</p>
                                    </div>
                                </div>
                            </div>

                            <!-- Veckodagar (Chips) - Visas när toggle är AV -->
                            <div x-show="!useSpecificDate" x-cloak class="space-y-3" x-transition>
                                <label class="block text-sm font-medium text-neutral-700">Vilka dagar passar dig bäst? <span class="text-xs font-normal text-neutral-500 ml-1">(Välj flera om du vill)</span></label>
                                <div class="flex flex-wrap gap-2">
                                    <template x-for="day in ['Mån', 'Tis', 'Ons', 'Tor', 'Fre', 'Lör', 'Sön']">
                                        <button type="button" 
                                            @click="selectedDays.includes(day) ? selectedDays = selectedDays.filter(d => d !== day) : selectedDays.push(day)"
                                            :class="selectedDays.includes(day) ? 'bg-brand-sky text-white border-brand-sky shadow-md scale-105' : 'bg-white text-neutral-600 border-neutral-200 hover:border-brand-sky/50'"
                                            class="px-4 py-2 rounded-full border text-sm font-medium transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-brand-sky/20">
                                            <span x-text="day"></span>
                                        </button>
                                    </template>
                                </div>
                                <input type="hidden" name="preferred_days" :value="selectedDays.join(', ')">
                            </div>

                            <!-- Tid på dagen (Grid) - Visas när toggle är AV -->
                            <div x-show="!useSpecificDate" x-cloak class="space-y-3" x-transition>
                                <label class="block text-sm font-medium text-neutral-700">Vilken tid på dagen föredrar du?</label>
                                <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
                                    <template x-for="time in ['Förmiddag', 'Eftermiddag', 'Kväll']">
                                        <label class="relative flex items-center p-3 rounded-lg border cursor-pointer transition-all duration-200 hover:bg-neutral-50"
                                            :class="selectedTimes.includes(time) ? 'bg-brand-sky-light/10 border-brand-sky ring-1 ring-brand-sky' : 'bg-white border-neutral-200'">
                                            <input type="checkbox" :value="time" x-model="selectedTimes" class="sr-only">
                                            <span class="text-sm font-medium" :class="selectedTimes.includes(time) ? 'text-brand-sky-dark' : 'text-neutral-700'" x-text="time"></span>
                                            <template x-if="selectedTimes.includes(time)">
                                                <svg class="w-4 h-4 ml-auto text-brand-sky-dark" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
                                            </template>
                                        </label>
                                    </template>
                                </div>
                                <input type="hidden" name="preferred_time_ranges" :value="selectedTimes.join(', ')">
                            </div>
                        </div>

                        <!-- Resepreferenser (Hälsoresa) -->
                        <div x-show="subject === 'halsoresa'" x-cloak class="mt-8 space-y-6 border-t border-brand-earth-light/20 pt-8" x-transition>
                            <h4 class="text-xl font-bold text-brand-earth-dark flex items-center">
                                <Icon name="calendar" class="w-6 h-6 mr-3 text-brand-accent-dark" />
                                Reseperiod <span class="text-sm font-normal text-neutral-500 ml-2">(valfritt)</span>
                            </h4>

                            <div class="space-y-3 mt-4">
                                <label class="block text-sm font-medium text-neutral-700">Vilken tid på året passar dig bäst? <span class="text-xs font-normal text-neutral-500 ml-1">(Välj en eller flera)</span></label>
                                <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                                    <template x-for="period in ['Vår (Maj-Juni)', 'Höst (Oktober-November)', 'Annat datum / Flexibel']">
                                        <label class="relative flex items-center p-3 rounded-lg border cursor-pointer transition-all duration-200 hover:bg-neutral-50"
                                            :class="selectedTravelPeriods.includes(period) ? 'bg-brand-sky-light/10 border-brand-sky ring-1 ring-brand-sky' : 'bg-white border-neutral-200'">
                                            <input type="checkbox" :value="period" x-model="selectedTravelPeriods" class="sr-only">
                                            <span class="text-sm font-medium" :class="selectedTravelPeriods.includes(period) ? 'text-brand-sky-dark' : 'text-neutral-700'" x-text="period"></span>
                                            <template x-if="selectedTravelPeriods.includes(period)">
                                                <svg class="w-4 h-4 ml-auto text-brand-sky-dark" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
                                            </template>
                                        </label>
                                    </template>
                                </div>

                                <div x-show="selectedTravelPeriods.includes('Annat datum / Flexibel')" x-cloak class="mt-3 p-4 bg-brand-accent/5 rounded-lg border border-brand-accent/20" x-transition>
                                    <label for="custom_travel_period" class="block text-sm font-medium text-brand-earth-dark mb-1">Ange önskade datum eller period</label>
                                    <input type="text" id="custom_travel_period" name="custom_travel_period" x-model="customTravelPeriod" :required="selectedTravelPeriods.includes('Annat datum / Flexibel')"
                                        class="w-full border-neutral-300 rounded-md shadow-sm focus:border-brand-sky focus:ring focus:ring-brand-sky/20 transition-all p-3 border bg-white"
                                        placeholder="T.ex. September 2027 eller 'när som helst under hösten'">
                                </div>

                                <input type="hidden" name="preferred_travel_periods" :value="selectedTravelPeriods.join(', ')">
                            </div>
                        </div>

                        <div>
                            <label for="message" class="block text-sm font-medium text-neutral-700 mb-1 mt-4">Ditt
                                Meddelande
                                <span class="text-red-500" x-show="subject !== 'ovrigt'">*</span></label>
                            <p class="text-xs text-neutral-500 mb-2" x-show="!['ovrigt'].includes(subject)">Beskriv ditt
                                ärende, dina frågor eller vad du behöver hjälp med.</p>
                            <textarea id="message" name="message" rows="5" :required="subject !== 'ovrigt'"
                                class="w-full border-neutral-300 rounded-md shadow-sm focus:border-brand-sky focus:ring focus:ring-brand-sky/20 transition-all p-3 border bg-neutral-50/50"></textarea>
                        </div>

                        <button type="submit"
                            class="w-full btn btn-primary-on-dark mt-6 text-center justify-center py-4 text-lg">
                            Skicka Meddelande
                        </button>
                    </form>

                    <div class="mt-8 text-center border-t border-neutral-100 pt-6">
                        <p class="text-sm text-neutral-600">
                            Gäller din förfrågan ett Företag? <br class="hidden sm:block">
                            <a href="/for-foretag/kontakt-offert/"
                                class="text-brand-sky-dark hover:text-brand-accent-dark font-semibold underline decoration-brand-sky-dark/30 underline-offset-4 mt-1 inline-block">Använd
                                vårt separata formulär för offertförfrågan här &rarr;</a>
                        </p>
                    </div>
                </div>

                <!-- Höger: Kontaktbox & Team -->
                <div class="space-y-8">
                    <!-- Kontaktinformation Box -->
                    <div class="bg-brand-accent/10 border border-brand-accent/20 p-8 rounded-xl space-y-6">
                        <div>
                            <div class="flex items-center text-brand-earth-dark font-semibold text-lg mb-2">
                                <svg class="w-6 h-6 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z">
                                    </path>
                                </svg>
                                Telefon
                            </div>
                            <a href={`tel:${siteConfig.phone.clean}`}
                                class="text-brand-sky-dark hover:text-brand-accent-dark font-medium text-lg ml-9 transition-colors">{siteConfig.phone.display}</a>
                        </div>
                        <div>
                            <div class="flex items-center text-brand-earth-dark font-semibold text-lg mb-2">
                                <svg class="w-6 h-6 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z">
                                    </path>
                                </svg>
                                E-post
                            </div>
                            <a href={`mailto:${siteConfig.email}`}
                                class="text-brand-sky-dark hover:text-brand-accent-dark font-medium text-lg transition-colors ml-9">{siteConfig.email}</a>
                        </div>
                        <div class="pt-4 border-t border-brand-accent/20 mt-6">
                            <p class="text-sm text-neutral-600 italic leading-relaxed">
                                "Vi svarar när vi är tillgängliga. Lämna gärna ett meddelande eller skicka ett SMS,
                                så
                                återkommer vi så snart vi kan."
                            </p>
                        </div>
                    </div>

                    <!-- Team Profiler -->
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-1 xl:grid-cols-2 gap-4 items-start"
                        x-data="{ activePerson: null }">
                        <!-- Johannes -->
                        <article
                            class="team-card h-auto flex flex-row bg-white border border-brand-accent/20 text-left overflow-hidden items-start">
                            <div class="relative w-24 md:w-32 shrink-0 aspect-[3/4] overflow-hidden">
                                <Image src={johannesImage} alt="Johannes Mao"
                                    class="absolute inset-0 h-full w-full object-cover object-top" />
                            </div>
                            <div
                                class="team-content flex flex-col self-stretch justify-start py-3 pl-4 pr-3 flex-grow md:min-h-[260px]">
                                <h3 class="text-brand-earth-dark text-base font-bold mb-1">Johannes Mao</h3>
                                <p class="text-[10px] font-bold uppercase tracking-wider text-brand-accent-dark mb-2">
                                    Grundare & Terapeut</p>
                                <div class="team-bio">
                                    <p class="text-xs leading-relaxed text-neutral-700">Med över 30 års erfarenhet
                                        och
                                        tusentals behandlingar är Johannes Medidrakens drivkraft.</p>
                                    <div x-show="activePerson === 'johannes'" x-transition x-cloak
                                        class="mt-2 space-y-2">
                                        <p class="text-xs leading-relaxed text-neutral-700">Han är utbildad
                                            farmaceut
                                            inom
                                            både kinesisk och västerländsk medicin, samt terapeut inom TuiNa
                                            massage.
                                        </p>
                                    </div>
                                </div>
                                <button @click="activePerson = (activePerson === 'johannes' ? null : 'johannes')"
                                    class="mt-auto text-base font-semibold text-brand-sky hover:text-brand-accent-dark transition-all flex items-center gap-1">
                                    <span x-text="activePerson === 'johannes' ? 'Visa mindre' : 'Läs mer'"></span>
                                    <svg class="h-3 w-3 transform transition-transform duration-300"
                                        :class="activePerson === 'johannes' ? 'rotate-180' : ''" fill="none"
                                        stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                                            d="M19 9l-7 7-7-7" />
                                    </svg>
                                </button>
                            </div>
                        </article>

                        <!-- Linnéa -->
                        <article
                            class="team-card h-auto flex flex-row bg-white border border-brand-accent/20 text-left overflow-hidden items-start">
                            <div class="relative w-24 md:w-32 shrink-0 aspect-[3/4] overflow-hidden">
                                <Image src={linneaImage} alt="Linnéa Mao"
                                    class="absolute inset-0 h-full w-full object-cover object-top" />
                            </div>
                            <div
                                class="team-content flex flex-col self-stretch justify-start py-3 pl-4 pr-3 flex-grow md:min-h-[260px]">
                                <h3 class="text-brand-earth-dark text-base font-bold mb-1">Linnéa Mao</h3>
                                <p class="text-[10px] font-bold uppercase tracking-wider text-brand-accent-dark mb-2">
                                    Läkare
                                    i TCM & Akupunktör</p>
                                <div class="team-bio">
                                    <p class="text-xs leading-relaxed text-neutral-700">Linnéa är läkare inom TCM
                                        och
                                        akupunktör, utbildad i Kina, med närmare 20 års erfarenhet.</p>
                                    <div x-show="activePerson === 'linnea'" x-transition x-cloak class="mt-2 space-y-2">
                                        <p class="text-xs leading-relaxed text-neutral-700">Som terapeut är hon känd
                                            för
                                            att
                                            vara mjuk, inkännande och specialiserad på smärta, stress och migrän.
                                        </p>
                                    </div>
                                </div>
                                <button @click="activePerson = (activePerson === 'linnea' ? null : 'linnea')"
                                    class="mt-auto text-base font-semibold text-brand-sky hover:text-brand-accent-dark transition-all flex items-center gap-1">
                                    <span x-text="activePerson === 'linnea' ? 'Visa mindre' : 'Läs mer'"></span>
                                    <svg class="h-3 w-3 transform transition-transform duration-300"
                                        :class="activePerson === 'linnea' ? 'rotate-180' : ''" fill="none"
                                        stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                                            d="M19 9l-7 7-7-7" />
                                    </svg>
                                </button>
                            </div>
                        </article>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="section-standard bg-neutral-50 scroll-mt-20" id="mottagningar">
        <div class="container-base">

            <div class="text-center max-w-3xl mx-auto mb-10">
                <h2 class="text-3xl text-brand-earth-dark font-semibold mb-4">Hitta till Oss</h2>
                <p class="text-lg text-neutral-700 leading-relaxed">
                    Vi har mottagningar i Gnesta, Nyköping och Oxelösund.
                </p>
                <p class="text-lg text-neutral-700 leading-relaxed mt-4">
                    Vi tar emot besök endast efter tidsbokning. Välkommen att kontakta oss för att boka en tid via
                    kontaktuppgifterna eller formuläret ovan.
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 items-start">

                <!-- Nyköping -->
                <div
                    class="bg-white rounded-xl shadow-lg shadow-brand-earth/5 overflow-hidden flex flex-col border border-brand-earth-light/20">
                    <div class="p-6 bg-brand-accent/10 border-b border-brand-accent/20">
                        <h4 class="text-xl font-bold text-brand-earth-dark mb-2 flex items-center">
                            <svg class="w-5 h-5 mr-2 text-brand-sky" fill="none" stroke="currentColor"
                                viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z">
                                </path>
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                            </svg>
                            Nyköping
                        </h4>
                        <p class="text-neutral-700 font-medium">{siteConfig.addresses.nykoping.full}</p>
                    </div>
                    <div class="w-full h-72 bg-neutral-200">
                        <iframe src={siteConfig.addresses.nykoping.embedUrl} width="100%" height="100%"
                            style="border:0;" allowfullscreen="" loading="lazy"
                            referrerpolicy="no-referrer-when-downgrade">
                        </iframe>
                    </div>
                </div>

                <!-- Gnesta -->
                <div
                    class="bg-white rounded-xl shadow-lg shadow-brand-earth/5 overflow-hidden flex flex-col border border-brand-earth-light/20">
                    <div class="p-6 bg-brand-accent/10 border-b border-brand-accent/20">
                        <h4 class="text-xl font-bold text-brand-earth-dark mb-2 flex items-center">
                            <svg class="w-5 h-5 mr-2 text-brand-sky" fill="none" stroke="currentColor"
                                viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z">
                                </path>
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                            </svg>
                            Gnesta
                        </h4>
                        <p class="text-neutral-700 font-medium">{siteConfig.addresses.gnesta.full}</p>
                    </div>
                    <div class="w-full h-72 bg-neutral-200">
                        <iframe src={siteConfig.addresses.gnesta.embedUrl} width="100%" height="100%" style="border:0;"
                            allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade">
                        </iframe>
                    </div>
                </div>

                <!-- Oxelösund -->
                <div
                    class="bg-white rounded-xl shadow-lg shadow-brand-earth/5 overflow-hidden flex flex-col border border-brand-earth-light/20">
                    <div class="p-6 bg-brand-accent/10 border-b border-brand-accent/20">
                        <h4 class="text-xl font-bold text-brand-earth-dark mb-2 flex items-center">
                            <svg class="w-5 h-5 mr-2 text-brand-sky" fill="none" stroke="currentColor"
                                viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z">
                                </path>
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                            </svg>
                            Oxelösund
                        </h4>
                        <p class="text-neutral-700 font-medium">{siteConfig.addresses.oxelosund.full}</p>
                    </div>
                    <div class="w-full h-72 bg-neutral-200">
                        <iframe src={siteConfig.addresses.oxelosund.embedUrl} width="100%" height="100%"
                            style="border:0;" allowfullscreen="" loading="lazy"
                            referrerpolicy="no-referrer-when-downgrade">
                        </iframe>
                    </div>
                </div>

            </div>
        </div>
    </section>
</BaseLayout>