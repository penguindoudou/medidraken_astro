---
import { Image } from 'astro:assets';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Icon from '../../../components/Icon.astro';

// Images
import qigong_bamboo15Image from '../../../assets/images/qigong_bamboo15.png';
import johannes_mao_profileImage from '../../../assets/images/johannes_mao_profile.jpg';
import maria_morris_profileImage from '../../../assets/images/maria_morris_profile.jpg';
import magnus_rooth_profileImage from '../../../assets/images/magnus_rooth_profile.jpg';
import qigong_johannes_instructing_groupImage from '../../../assets/images/qigong_johannes_instructing_group.jpg';
---

<BaseLayout title="Medicinsk Qigong i Nyköping">
    <!-- ======================================= -->
    <!-- Sektion 1: Hero                         -->
    <!-- ======================================= -->
    <section class="hero-section">
        <div class="hero-background">
            <!-- Bildförslag: En person som utövar Qigong i naturen, mjukt ljus -->
            <Image src={qigong_bamboo15Image} alt="Medicinsk Qigong för inre balans och energi" class="hero-bg-image" />
        </div>
        <div class="hero-content">
            <h1 class="hero-title text-brand-accent">Medicinsk Qigong</h1>

            <div class="hero-text bg-brand-earth-dark/20 p-6 rounded-lg backdrop-blur-sm border border-white/10">

                <h2 class="hero-subtitle font-bold mb-3">Återfå Energi & Inre Balans</h2>

                <p class="hero-text mt-0">
                    Känner du dig stressad, trött eller ur balans? Medicinsk Qigong är en varsam men kraftfull metod för
                    att
                    stärka din hälsa inifrån. Genom mjuka rörelser, fokuserad andning och mental närvaro löser du upp
                    spänningar, kultiverar din livsenergi (Qi) och aktiverar kroppens egen förmåga till återhämtning.
                </p>
            </div>
            <div class="mt-10">
                <a href="#kursanmalan" class="btn btn-primary-on-dark">
                    Se Kursstarter & Anmäl Intresse
                </a>
            </div>
        </div>
    </section>

    <!-- ======================================= -->
    <!-- Sektion 2: För Vem? (Expanderbar)       -->
    <!-- ======================================= -->
    <section class="section-standard bg-white">
        <div class="container-base">
            <div class="max-w-4xl mx-auto text-center mb-16">
                <h2 class="text-brand-earth">En Väg till Styrka, Balans & Inre Fokus</h2>
                <p class="mt-6 text-lg text-neutral-700">
                    Inom Traditionell Kinesisk Medicin ses hälsa som ett resultat av fritt flödande livsenergi (Qi).
                    Genom
                    Tai Chins kontrollerade rörelser omfördelas och balanseras denna energi. Samtidigt har kombinationen
                    av
                    rörelse och fokuserad närvaro en direkt reglerande effekt på dina organ och nervsystem, vilket
                    hjälper
                    till att sänka stressnivåer och harmonisera hela ditt system.
                </p>
            </div>

            <!-- Content Grid: Side-by-Side on Desktop -->
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-start max-w-7xl mx-auto">

                <!-- Left: Fysiska tillstånd (Accent path) -->
                <div class="bg-brand-accent/10 rounded-3xl p-8 border border-brand-accent/25 shadow-sm">
                    <div class="flex items-center mb-10 pb-6 border-b border-brand-accent/30">
                        <div class="h-16 w-16 rounded-full bg-brand-accent/10 flex items-center justify-center mr-6">
                            <Icon name="ryggont" class="h-13 w-13 text-brand-accent-dark" />
                        </div>
                        <h3 class="text-brand-earth-dark font-bold text-3xl m-0">Specifika Besvär & Tillstånd</h3>
                    </div>

                    <ul class="space-y-6">
                        <li>
                            <a href="/symtom/rygg-landrygg/"
                                class="group flex items-center p-4 -mx-4 rounded-2xl hover:bg-white/50 focus:bg-white/80 focus:ring-2 focus:ring-brand-accent/50 active:scale-[0.98] transition-all outline-none">
                                <div
                                    class="h-16 w-16 shrink-0 rounded-full border border-brand-accent/30 flex items-center justify-center mr-5 group-hover:bg-brand-accent/20 group-hover:border-transparent group-focus:border-brand-earth-dark transition-all">
                                    <Icon name="ryggont" class="h-13 w-13 text-brand-accent-dark" />
                                </div>
                                <span
                                    class="text-brand-accent-dark font-medium text-xl group-hover:text-brand-accent group-focus:text-brand-earth-dark transition-all">Långvarig
                                    Ryggvärk / Ischias</span>
                            </a>
                        </li>
                        <li>
                            <a href="/symtom/ledvark-idrottsskador-artros/"
                                class="group flex items-center p-4 -mx-4 rounded-2xl hover:bg-white/50 focus:bg-white/80 focus:ring-2 focus:ring-brand-accent/50 active:scale-[0.98] transition-all outline-none">
                                <div
                                    class="h-16 w-16 shrink-0 rounded-full border border-brand-accent/30 flex items-center justify-center mr-5 group-hover:bg-brand-accent/20 group-hover:border-transparent group-focus:border-brand-earth-dark transition-all">
                                    <Icon name="ledvark" class="h-15 w-15 text-brand-accent-dark" />
                                </div>
                                <span
                                    class="text-brand-accent-dark font-medium text-xl group-hover:text-brand-accent group-focus:text-brand-earth-dark transition-all">Ledvärk
                                    & Artros</span>
                            </a>
                        </li>
                        <li>
                            <a href="/symtom/yrsel-balansproblem/"
                                class="group flex items-center p-4 -mx-4 rounded-2xl hover:bg-white/50 focus:bg-white/80 focus:ring-2 focus:ring-brand-accent/50 active:scale-[0.98] transition-all outline-none">
                                <div
                                    class="h-16 w-16 shrink-0 rounded-full border border-brand-accent/30 flex items-center justify-center mr-5 group-hover:bg-brand-accent/20 group-hover:border-transparent group-focus:border-brand-earth-dark transition-all">
                                    <Icon name="dizzy" class="h-11 w-11 text-brand-accent-dark" />
                                </div>
                                <span
                                    class="text-brand-accent-dark font-medium text-xl group-hover:text-brand-accent group-focus:text-brand-earth-dark transition-all">Yrsel
                                    & Balansproblem</span>
                            </a>
                        </li>
                        <li>
                            <a href="/symtom/utbrandhet-trotthetssyndrom/"
                                class="group flex items-center p-4 -mx-4 rounded-2xl hover:bg-white/50 focus:bg-white/80 focus:ring-2 focus:ring-brand-accent/50 active:scale-[0.98] transition-all outline-none">
                                <div
                                    class="h-16 w-16 shrink-0 rounded-full border border-brand-accent/30 flex items-center justify-center mr-5 group-hover:bg-brand-accent/20 group-hover:border-transparent group-focus:border-brand-earth-dark transition-all">
                                    <Icon name="tired_plant" class="h-12 w-12 text-brand-accent-dark" />
                                </div>
                                <span
                                    class="text-brand-accent-dark font-medium text-xl group-hover:text-brand-accent group-focus:text-brand-earth-dark transition-all">Trötthet</span>
                            </a>
                        </li>
                        <li>
                            <a href="/symtom/somnproblem-insomnia/"
                                class="group flex items-center p-4 -mx-4 rounded-2xl hover:bg-white/50 focus:bg-white/80 focus:ring-2 focus:ring-brand-accent/50 active:scale-[0.98] transition-all outline-none">
                                <div
                                    class="h-16 w-16 shrink-0 rounded-full border border-brand-accent/30 flex items-center justify-center mr-5 group-hover:bg-brand-accent/20 group-hover:border-transparent group-focus:border-brand-earth-dark transition-all">
                                    <Icon name="broken_moon_with_stars" class="h-11 w-11 text-brand-accent-dark" />
                                </div>
                                <span
                                    class="text-brand-accent-dark font-medium text-xl group-hover:text-brand-accent group-focus:text-brand-earth-dark transition-all">Sömnproblem</span>
                            </a>
                        </li>
                    </ul>

                    <div class="mt-8">
                        <a href="/symtom/"
                            class="btn-tertiary inline-flex items-center group text-sm font-bold uppercase tracking-wider text-brand-accent-dark hover:text-brand-accent hover:translate-x-1 focus:text-brand-earth-dark active:scale-95 transition-all outline-none">
                            <span class="pb-1">Visa alla besvär vi kan hjälpa dig med</span>
                            <span class="ml-2 transform transition-transform group-hover:translate-x-1">&rarr;</span>
                        </a>
                    </div>
                </div>

                <!-- Right: Energi- & Stressrelaterade tillstånd (Sky path) -->
                <div class="bg-brand-sky/5 rounded-3xl p-8 border border-brand-sky/10 shadow-sm">
                    <div class="flex items-center mb-10 pb-6 border-b border-brand-sky/20">
                        <div
                            class="h-16 w-16 shrink-0 rounded-full bg-brand-sky/10 flex items-center justify-center mr-6">
                            <Icon name="taichi_qigong_flow_min" class="h-17 w-17 text-brand-sky" />
                        </div>
                        <h3 class="text-brand-sky font-bold text-3xl m-0 leading-tight">Hälsofördelar & Vitalitet</h3>
                    </div>

                    <ul class="space-y-6">
                        <li>
                            <a href="/na-dina-halsomal/forbattra-balans-rorlighet-kroppskontroll/"
                                class="group flex items-center p-4 -mx-4 rounded-2xl hover:bg-white/50 focus:bg-white/80 focus:ring-2 focus:ring-brand-sky/30 active:scale-[0.98] transition-all outline-none">
                                <div
                                    class="h-16 w-16 shrink-0 rounded-full border border-brand-sky/30 flex items-center justify-center mr-5 group-hover:bg-brand-sky/20 group-hover:border-transparent group-focus:border-brand-sky-dark transition-all">
                                    <Icon name="taichi_qigong_flow_min" class="h-17 w-17 text-brand-sky" />
                                </div>
                                <span
                                    class="text-neutral-700 font-medium text-xl group-hover:text-brand-sky group-focus:text-brand-sky-dark transition-all">Förbättra
                                    Balans & Rörlighet</span>
                            </a>
                        </li>
                        <li>
                            <a href="/na-dina-halsomal/starka-fokus-mental-styrka/"
                                class="group flex items-center p-4 -mx-4 rounded-2xl hover:bg-white/50 focus:bg-white/80 focus:ring-2 focus:ring-brand-sky/30 active:scale-[0.98] transition-all outline-none">
                                <div
                                    class="h-16 w-16 shrink-0 rounded-full border border-brand-sky/30 flex items-center justify-center mr-5 group-hover:bg-brand-sky/20 group-hover:border-transparent group-focus:border-brand-sky-dark transition-all">
                                    <Icon name="Yin_yang" class="h-12 w-12 text-brand-sky" />
                                </div>
                                <span
                                    class="text-neutral-700 font-medium text-xl group-hover:text-brand-sky group-focus:text-brand-sky-dark transition-all">Stärka
                                    Fokus & Mental Styrka</span>
                            </a>
                        </li>
                        <li>
                            <a href="/na-dina-halsomal/minska-stress-hitta-inre-lugn/"
                                class="group flex items-center p-4 -mx-4 rounded-2xl hover:bg-white/50 focus:bg-white/80 focus:ring-2 focus:ring-brand-sky/30 active:scale-[0.98] transition-all outline-none">
                                <div
                                    class="h-16 w-16 shrink-0 rounded-full border border-brand-sky/30 flex items-center justify-center mr-5 group-hover:bg-brand-sky/20 group-hover:border-transparent group-focus:border-brand-sky-dark transition-all">
                                    <Icon name="flower" class="h-12 w-12 text-brand-sky" />
                                </div>
                                <span
                                    class="text-neutral-700 font-medium text-xl group-hover:text-brand-sky group-focus:text-brand-sky-dark transition-all">Minska
                                    Stress & Hitta Inre Lugn</span>
                            </a>
                        </li>
                        <li>
                            <a href="/na-dina-halsomal/oka-energi-livskraft/"
                                class="group flex items-center p-4 -mx-4 rounded-2xl hover:bg-white/50 focus:bg-white/80 focus:ring-2 focus:ring-brand-sky/30 active:scale-[0.98] transition-all outline-none">
                                <div
                                    class="h-16 w-16 shrink-0 rounded-full border border-brand-sky/30 flex items-center justify-center mr-5 group-hover:bg-brand-sky/20 group-hover:border-transparent group-focus:border-brand-sky-dark transition-all">
                                    <Icon name="lightening" class="h-13 w-13 text-brand-sky" />
                                </div>
                                <span
                                    class="text-neutral-700 font-medium text-xl group-hover:text-brand-sky group-focus:text-brand-sky-dark transition-all">Öka
                                    Energi & Livskraft</span>
                            </a>
                        </li>
                        <li>
                            <a href="/na-dina-halsomal/starka-immunforsvaret-bygga-motstandskraft/"
                                class="group flex items-center p-4 -mx-4 rounded-2xl hover:bg-white/50 focus:bg-white/80 focus:ring-2 focus:ring-brand-sky/30 active:scale-[0.98] transition-all outline-none">
                                <div
                                    class="h-16 w-16 shrink-0 rounded-full border border-brand-sky/30 flex items-center justify-center mr-5 group-hover:bg-brand-sky/20 group-hover:border-transparent group-focus:border-brand-sky-dark transition-all">
                                    <Icon name="wind_shield" class="h-12 w-12 text-brand-sky" />
                                </div>
                                <span
                                    class="text-neutral-700 font-medium text-xl group-hover:text-brand-sky group-focus:text-brand-sky-dark transition-all">Stärka
                                    Immunförsvaret</span>
                            </a>
                        </li>
                    </ul>

                    <div class="mt-8">
                        <a href="/na-dina-halsomal/"
                            class="btn-tertiary inline-flex items-center group text-sm font-bold uppercase tracking-wider text-brand-sky hover:text-brand-sky-light hover:translate-x-1 focus:text-brand-sky-dark active:scale-95 transition-all outline-none">
                            <span class="pb-1">Visa alla hälsofördelar vi kan hjälpa dig med</span>
                            <span class="ml-2 transform transition-transform group-hover:translate-x-1">&rarr;</span>
                        </a>
                    </div>
                </div>
            </div>
        </div>
        <!-- Korslänk Tai Chi -->
        <!-- 1. YTTRE WRAPPER: Samma bredd som boxen ovan (3xl) och centrerad (mx-auto). 
        Rör inte dessa klasser – de håller "spåret" på plats. -->
        <div class="max-w-3xl mx-auto mt-6 w-full px-4 md:px-0">

            <!-- 2. INRE BOX: Här bestämmer vi storleken på själva rutan.
            max-w-md  = Gör den smal (ca 450px).
            Ingen mx-auto = Den lägger sig till vänster i spåret. 
            text-left = Texten justerad till vänster. -->
            <div class="max-w-xl p-4 bg-brand-earth/5 rounded-lg border border-brand-earth/10 text-left">
                <p class="text-sm italic text-neutral-600">
                    <strong>Tips:</strong> När du är redo att utmana din koordination, är <a href="/kurser/tai-chi/"
                        class="text-brand-sky hover:underline hover:text-brand-accent-dark">Tai Chi</a> ett perfekt
                    nästa
                    steg.
                </p>
            </div>

        </div>
    </section>

    <!-- ======================================= -->
    <!-- Sektion 3: Kursformer                   -->
    <!-- ======================================= -->
    <section class="section-standard bg-brand-earth-lightest">
        <div class="container-base">
            <div class="text-center mb-12 max-w-3xl mx-auto">
                <h2 class="text-brand-earth">Välj en kursform som passar dig</h2>
                <p class="mt-4 text-brand-earth">
                    Vår undervisning fokuserar på effektiva och lättillgängliga metoder som <em>Sex Hemliga Ljud</em>
                    (Liu Zi Jue) och <em>Inombordsövningar</em> (Nei Gong). Oavsett vilken form du väljer får du lära
                    dig kraftfulla verktyg för din hälsa.
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">


                <!-- Helgkurser -->
                <div
                    class="content-box flex flex-col items-center hover:-translate-y-1 transition-transform duration-300">
                    <!-- Cirkulär bakgrund -->
                    <div
                        class="flex items-center justify-center h-16 w-16 rounded-full bg-brand-accent/20 mb-4 mx-auto">
                        <!-- Ikon: Kalender/Vecka (Justerad storlek och färg) -->
                        <svg class="h-12 w-12 text-brand-accent-dark" fill="none" stroke="currentColor"
                            viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z">
                            </path>
                        </svg>
                    </div>

                    <h3 class="text-xl font-bold text-neutral-900 mb-3">Helgkurser</h3>
                    <p class="text-neutral-700 mb-6 flex-grow text-center">
                        Djupdyk och upplev en ny nivå av inre lugn och lär dig en komplett hälsometod under en helg.
                        Perfekt
                        för dig som vill komma igång snabbt.
                    </p>
                    <div class="mt-6 pt-4 border-t border-neutral-200 w-full text-center">
                        <a href="/kurser/medicinsk-qigong/helgkurser/" class="btn-tertiary">Läs mer om helgkurser
                            &rarr;</a>
                    </div>
                </div>

                <!-- Privatundervisning -->
                <div
                    class="content-box flex flex-col items-center hover:-translate-y-1 transition-transform duration-300">
                    <!-- Cirkulär bakgrund -->
                    <div
                        class="flex items-center justify-center h-16 w-16 rounded-full bg-brand-accent/20 mb-4 mx-auto">
                        <!-- Ikon: Person/Fokus (Justerad storlek och färg) -->
                        <svg class="h-12 w-12 text-brand-accent-dark" fill="none" stroke="currentColor"
                            viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                        </svg>
                    </div>

                    <h3 class="text-xl font-bold text-neutral-900 mb-3">Privatundervisning</h3>
                    <p class="text-neutral-700 mb-6 flex-grow text-center">
                        Få ett program som är anpassat efter dig med fullt fokus på dina personliga hälsomål och
                        förutsättningar.
                    </p>

                    <div class="mt-6 pt-4 border-t border-neutral-200 w-full text-center">
                        <a href="/kurser/medicinsk-qigong/privatundervisning/" class="btn-tertiary">Läs mer om
                            privatlektioner &rarr;</a>
                    </div>
                </div>

            </div>
        </div>
    </section>

    <!-- ======================================= -->
    <!-- Sektion 4: Kursstarter / Fallback       -->
    <!-- ======================================= -->
    <section class="section-standard bg-white" id="kursanmalan">
        <div class="container-base">
            <h2 class="text-brand-earth text-center mb-10">Kursstarter för Medicinsk Qigong</h2>


            {/* {%if courses_qigong is defined and courses_qigong is not empty%} */}

            <!-- Active Courses Table -->
            <div class="overflow-x-auto shadow-md rounded-lg max-w-5xl mx-auto border border-neutral-200">
                <table class="min-w-full leading-normal">
                    <thead>
                        <tr>
                            <th
                                class="px-5 py-3 border-b-2 border-brand-earth bg-brand-earth-lightest text-left text-xs font-semibold text-brand-earth uppercase tracking-wider">
                                Kursform</th>
                            <th
                                class="px-5 py-3 border-b-2 border-brand-earth bg-brand-earth-lightest text-left text-xs font-semibold text-brand-earth uppercase tracking-wider">
                                Ort</th>
                            <th
                                class="px-5 py-3 border-b-2 border-brand-earth bg-brand-earth-lightest text-left text-xs font-semibold text-brand-earth uppercase tracking-wider">
                                Dag / Tid</th>
                            <th
                                class="px-5 py-3 border-b-2 border-brand-earth bg-brand-earth-lightest text-left text-xs font-semibold text-brand-earth uppercase tracking-wider">
                                Start</th>
                            <th class="px-5 py-3 border-b-2 border-brand-earth bg-brand-earth-lightest"></th>
                        </tr>
                    </thead>
                    <tbody>
                        {/* {%for course in courses_qigong%} */}
                        <tr>
                            <td class="px-5 py-5 border-b border-gray-200 bg-white text-sm">
                                <p class="text-gray-900 whitespace-no-wrap font-semibold">[course.title]</p>
                            </td>
                            <td class="px-5 py-5 border-b border-gray-200 bg-white text-sm">
                                <p class="text-gray-900 whitespace-no-wrap">[course.location]</p>
                            </td>
                            <td class="px-5 py-5 border-b border-gray-200 bg-white text-sm">
                                <p class="text-gray-900 whitespace-no-wrap">[course.day_time]</p>
                            </td>
                            <td class="px-5 py-5 border-b border-gray-200 bg-white text-sm">
                                <span
                                    class="relative inline-block px-3 py-1 font-semibold text-brand-earth-dark leading-tight">
                                    <span aria-hidden
                                        class="absolute inset-0 bg-brand-accent/30 opacity-50 rounded-full"></span>
                                    <span class="relative">[course.start_date]</span>
                                </span>
                            </td>
                            <td class="px-5 py-5 border-b border-gray-200 bg-white text-sm text-right">
                                <a href="[course.link]" class="text-brand-sky hover:text-brand-earth font-medium">Boka
                                    &rarr;</a>
                            </td>
                        </tr>
                        {/* {%endfor%} */}
                    </tbody>
                </table>
            </div>

            {/* {%else%} */}

            <!-- Fallback Block (Visas om inga kurser finns) -->
            <div
                class="max-w-4xl mx-auto border-2 border-dashed border-neutral-300 rounded-xl p-8 md:p-12 bg-neutral-50">
                <h3 class="font-heading text-2xl text-brand-earth mb-4 text-center">Så här kommer du igång!</h3>
                <p class="text-neutral-700 mb-10 text-center max-w-2xl mx-auto">
                    Just nu har vi inga schemalagda gruppstarter för Medicinsk Qigong, men din intresseanmälan är
                    avgörande
                    för vår planering. Det finns flera alternativ för att börja din hälsoresa redan nu.
                </p>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-4 min-[890px]:gap-8">

                    <!-- Väg 1: Intresseanmälan -->
                    <div
                        class="bg-gradient-to-br from-brand-sky/5 to-brand-accent/5 p-8 md:p-4 min-[890px]:p-8 rounded-lg shadow-sm border-2 border-brand-sky/20 hover:-translate-y-1 transition-transform duration-300">
                        <div
                            class="flex items-center justify-center h-12 w-12 rounded-full bg-brand-sky text-white mb-4 shadow-md">
                            <!-- Calendar with Star Icon -->
                            <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M8 7V3m8 4V3M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z">
                                </path>
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                    d="M12 10.5l.9 1.8 2 .3-1.45 1.4.35 2-1.8-.95-1.8.95.35-2-1.45-1.4 2-.3.9-1.8z"
                                    fill="currentColor"></path>
                            </svg>
                        </div>
                        <h4
                            class="font-bold text-brand-earth-dark text-xl md:text-base min-[890px]:text-xl mb-3 hyphens-auto">
                            Intresseanmälan</h4>
                        <p class="text-neutral-700 mb-6">
                            Var först med att få info om nästa termin. Genom att anmäla intresse hjälper du oss planera.
                        </p>
                        <a href="/kontakt/?subject=Kursintresse%20Qigong" class="btn-tertiary font-semibold">Anmäl
                            intresse
                            &rarr;</a>
                    </div>

