---
// 1. Import your Tailwind styles
import '../styles/global.css';

// 2. Define what variables this layout can receive
interface Props {
title?: string;
description?: string;
}

// 3. Get those variables (or use defaults)
const {
title = "Medidraken | Akupunktur & TCM i Sörmland",
description = "Traditionell Kinesisk Medicin i Nyköping, Gnesta och Oxelösund."
} = Astro.props;

---

<!doctype html>
<html lang="sv">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO Basics -->
    <title>{title}</title>
    <meta name="description" content={description} />
</head>

<body class="bg-stone-50 text-stone-900 antialiased">
    <slot />
</body>

</html>

<style>
    /* You can remove the old CSS here since we are using Tailwind now */
    html,
    body {
        margin: 0;
        width: 100%;
        min-height: 100%;
    }
</style>