---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';

// Images
import acupuncture_zoomImage from '../../assets/images/hero_aku2.png';
import linnea_mao_profileImage from '../../assets/images/linnea_mao_profile.jpg';
---

<style>
    .hero-background-white {
        background-color: white !important;
    }
    .hero-background-white::after {
        display: none !important;
    }
    .hero-subtitle {
        text-shadow: none !important;
    }
    .hero-text {
        text-shadow: none !important;
        filter: none !important;
    }
</style>

<BaseLayout title="Akupunktur i Nyköping & Gnesta mot Smärta & Stress">
<!-- ======================================= -->
<!-- Sektion 1: Toppsektion (Hero)           -->
<!-- ======================================= -->
<section class="hero-section min-h-[60vh]">
    <div class="hero-background hero-background-white">
        <Image src={acupuncture_zoomImage} alt="Akupunktur behandling av Linnéa Mao"
            class="hero-bg-image bg-brand-earth-light opacity-100" />
    </div>
    <div class="hero-content text-center">
        <div class="bg-brand-earth-light/100 p-8 md:p-12 rounded-3xl max-w-3xl mx-auto backdrop-blur-sm border border-brand-earth-light/20 shadow-2xl">
            <h1 class="hero-title text-brand-accent mb-4">Akupunktur</h1>
            <h2 class="hero-subtitle text-brand-earth-dark font-bold mb-3">Minska Smärta, Stress & Återfå Balans</h2>

            <p class="hero-text text-brand-earth-dark mt-0">
                Vill du hitta tillbaka till kroppens naturliga balans och potential? Oavsett om det handlar om att minska
                smärta och stress, eller att proaktivt stärka din energi och motståndskraft, så är akupunktur en tusenårig
                läkekonst där väldigt tunna, sterila nålar placeras på specifika punkter för att återställa kroppens
                naturliga energiflöde (Qi) och läkningsförmåga.
            </p>
        </div>
    </div>
</section>

<!-- ======================================= -->
<!-- Sektion 4: Symtom & Tillstånd           -->
<!-- ======================================= -->
<section class="bg-white border-t border-neutral-100">
    <div class="section-standard">
        <div class="container-base">
            <!-- Unified Header -->
            <div class="text-center max-w-3xl mx-auto mb-16 px-4">
                <h2 class="text-brand-earth mb-4 uppercase tracking-wide">Fysiska & Stressrelaterade Tillstånd</h2>
                <p class="text-lg text-neutral-700">
                    Akupunktur är ett mångsidigt verktyg som behandlar både specifika fysiska symtom och stärker din
                    hälsa på ett djupare plan vid stress och energibrist.
                </p>
            </div>

            <!-- Content Grid: Side-by-Side on Desktop -->
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-16 items-start max-w-5xl mx-auto">

                <!-- Left: Fysiska tillstånd (Accent path) -->
                <div class="bg-brand-accent/10 rounded-3xl p-8 border border-brand-accent/25 shadow-sm">
                    <div class="flex items-center mb-10 pb-6 border-b border-brand-accent/30">
                        <div class="h-16 w-16 rounded-full bg-brand-accent/10 flex items-center justify-center mr-6">
                            <Icon name="flower" class="h-10 w-10 text-brand-accent-dark" />
                        </div>
                        <h3 class="text-brand-earth-dark font-bold text-3xl m-0">Fysiska tillstånd</h3>
                    </div>

                    <ul class="space-y-6">
                        <li>
                            <a href="/symtom/rygg-landrygg/"
                                class="group flex items-center p-4 -mx-4 rounded-2xl hover:bg-white/50 focus:bg-white/80 focus:ring-2 focus:ring-brand-accent/50 active:scale-[0.98] transition-all outline-none">
                                <div
                                    class="h-20 w-20 shrink-0 rounded-full border border-brand-accent/30 flex items-center justify-center mr-5 group-hover:bg-brand-accent/20 group-hover:border-transparent group-focus:border-brand-earth-dark transition-all">
                                    <Icon name="ryggont" class="h-14 w-14 text-brand-accent-dark" />
                                </div>
                                <span
                                    class="text-brand-accent-dark font-medium text-xl group-hover:text-brand-accent group-focus:text-brand-earth-dark transition-all">Ryggsmärta,
                                    ländryggsvärk & ischias</span>
                            </a>
                        </li>
                        <li>
                            <a href="/symtom/nacke-axlar-skuldror/"
                                class="group flex items-center p-4 -mx-4 rounded-2xl hover:bg-white/50 focus:bg-white/80 focus:ring-2 focus:ring-brand-accent/50 active:scale-[0.98] transition-all outline-none">
                                <div
                                    class="h-16 w-16 shrink-0 rounded-full border border-brand-accent/30 flex items-center justify-center mr-5 group-hover:bg-brand-accent/20 group-hover:border-transparent group-focus:border-brand-earth-dark transition-all">
                                    <Icon name="nackont" class="h-11 w-11 text-brand-accent-dark" />
                                </div>
                                <span
                                    class="text-brand-accent-dark font-medium text-xl group-hover:text-brand-accent group-focus:text-brand-earth-dark transition-all">Värk
                                    & spänningar i nacke och axlar</span>
                            </a>
                        </li>
                        <li>
                            <a href="/symtom/huvudvark-yrsel/"
                                class="group flex items-center p-4 -mx-4 rounded-2xl hover:bg-white/50 focus:bg-white/80 focus:ring-2 focus:ring-brand-accent/50 active:scale-[0.98] transition-all outline-none">
                                <div
                                    class="h-16 w-16 shrink-0 rounded-full border border-brand-accent/30 flex items-center justify-center mr-5 group-hover:bg-brand-accent/20 group-hover:border-transparent group-focus:border-brand-earth-dark transition-all">
                                    <Icon name="huvudvark" class="h-11 w-11 text-brand-accent-dark" />
                                </div>
                                <span
                                    class="text-brand-accent-dark font-medium text-xl group-hover:text-brand-accent group-focus:text-brand-earth-dark transition-all">Huvudvärk,
                                    migrän & yrsel</span>
                            </a>
                        </li>
                        <li>
                            <a href="/symtom/ledvark-idrottsskador-artros/"
                                class="group flex items-center p-4 -mx-4 rounded-2xl hover:bg-white/50 focus:bg-white/80 focus:ring-2 focus:ring-brand-accent/50 active:scale-[0.98] transition-all outline-none">
                                <div
                                    class="h-16 w-16 shrink-0 rounded-full border border-brand-accent/30 flex items-center justify-center mr-5 group-hover:bg-brand-accent/20 group-hover:border-transparent group-focus:border-brand-earth-dark transition-all">
                                    <Icon name="tennisarmbage" class="h-14 w-14 text-brand-accent-dark" />
                                </div>
                                <span
                                    class="text-brand-accent-dark font-medium text-xl group-hover:text-brand-accent group-focus:text-brand-earth-dark transition-all">Tennisarmbåge
                                    & musarm</span>
                            </a>
                        </li>
                        <li>
                            <a href="/symtom/ledvark-idrottsskador-artros/"
                                class="group flex items-center p-4 -mx-4 rounded-2xl hover:bg-white/50 focus:bg-white/80 focus:ring-2 focus:ring-brand-accent/50 active:scale-[0.98] transition-all outline-none">
                                <div
                                    class="h-16 w-16 shrink-0 rounded-full border border-brand-accent/30 flex items-center justify-center mr-5 group-hover:bg-brand-accent/20 group-hover:border-transparent group-focus:border-brand-earth-dark transition-all">
                                    <Icon name="ledvark" class="h-15 w-15 text-brand-accent-dark" />
                                </div>
                                <span
                                    class="text-brand-accent-dark font-medium text-xl group-hover:text-brand-accent group-focus:text-brand-earth-dark transition-all">Ledvärk,
                                    artros & idrottskador</span>
                            </a>
                        </li>
                    </ul>

                    <div class="mt-8">
                        <a href="/symtom/"
                            class="btn-tertiary inline-flex items-center group text-sm font-bold uppercase tracking-wider text-brand-accent-dark hover:text-brand-accent hover:translate-x-1 focus:text-brand-earth-dark active:scale-95 transition-all outline-none">
                            <span class="pb-1">Visa alla fysiska bevsär</span>
                            <span class="ml-2 transform transition-transform group-hover:translate-x-1">&rarr;</span>
                        </a>
                    </div>
                </div>

                <!-- Right: Energi- & Stressrelaterade tillstånd (Sky path) -->
                <div class="bg-brand-sky/5 rounded-3xl p-8 border border-brand-sky/10 shadow-sm">
                    <div class="flex items-center mb-10 pb-6 border-b border-brand-sky/20">
                        <div
                            class="h-16 w-16 shrink-0 rounded-full bg-brand-sky/10 flex items-center justify-center mr-6">
                            <Icon name="stress3" class="h-14 w-14 text-brand-sky" />
                        </div>
                        <h3 class="text-brand-sky font-bold text-3xl m-0 leading-tight">Stressrelaterade
                            tillstånd</h3>
                    </div>

                    <ul class="space-y-6">
                        <li>
                            <a href="/na-dina-halsomal/"
                                class="group flex items-center p-4 -mx-4 rounded-2xl hover:bg-white/50 focus:bg-white/80 focus:ring-2 focus:ring-brand-sky/30 active:scale-[0.98] transition-all outline-none">
                                <div
                                    class="h-16 w-16 shrink-0 rounded-full border border-brand-sky/30 flex items-center justify-center mr-5 group-hover:bg-brand-sky/20 group-hover:border-transparent group-focus:border-brand-sky-dark transition-all">
                                    <Icon name="stress3" class="h-14 w-14 text-brand-sky" />
                                </div>
                                <span
                                    class="text-neutral-700 font-medium text-xl group-hover:text-brand-sky group-focus:text-brand-sky-dark transition-all">Stress
                                    & oro</span>
                            </a>
                        </li>
                        <li>
                            <a href="/na-dina-halsomal/"
                                class="group flex items-center p-4 -mx-4 rounded-2xl hover:bg-white/50 focus:bg-white/80 focus:ring-2 focus:ring-brand-sky/30 active:scale-[0.98] transition-all outline-none">
                                <div
                                    class="h-16 w-16 shrink-0 rounded-full border border-brand-sky/30 flex items-center justify-center mr-5 group-hover:bg-brand-sky/20 group-hover:border-transparent group-focus:border-brand-sky-dark transition-all">
                                    <Icon name="outlined_wilted_leaf" class="h-12 w-12 text-brand-sky" />
                                </div>
                                <span
                                    class="text-neutral-700 font-medium text-xl group-hover:text-brand-sky group-focus:text-brand-sky-dark transition-all">Utbrändhet</span>
                            </a>
                        </li>
                        <li>
                            <a href="/na-dina-halsomal/"
                                class="group flex items-center p-4 -mx-4 rounded-2xl hover:bg-white/50 focus:bg-white/80 focus:ring-2 focus:ring-brand-sky/30 active:scale-[0.98] transition-all outline-none">
                                <div
                                    class="h-16 w-16 shrink-0 rounded-full border border-brand-sky/30 flex items-center justify-center mr-5 group-hover:bg-brand-sky/20 group-hover:border-transparent group-focus:border-brand-sky-dark transition-all">
                                    <Icon name="broken_moon_with_stars" class="h-10 w-10 text-brand-sky" />
                                </div>
                                <span
                                    class="text-neutral-700 font-medium text-xl group-hover:text-brand-sky group-focus:text-brand-sky-dark transition-all">Sömnproblem
                                </span>
                            </a>
                        </li>
                        <li>
                            <a href="/na-dina-halsomal/"
                                class="group flex items-center p-4 -mx-4 rounded-2xl hover:bg-white/50 focus:bg-white/80 focus:ring-2 focus:ring-brand-sky/30 active:scale-[0.98] transition-all outline-none">
                                <div
                                    class="h-16 w-16 shrink-0 rounded-full border border-brand-sky/30 flex items-center justify-center mr-5 group-hover:bg-brand-sky/20 group-hover:border-transparent group-focus:border-brand-sky-dark transition-all">
                                    <Icon name="tired_plant" class="h-12 w-12 text-brand-sky" />
                                </div>
                                <span
                                    class="text-neutral-700 font-medium text-xl group-hover:text-brand-sky group-focus:text-brand-sky-dark transition-all">Trötthet</span>
                            </a>
                        </li>
                        <li>
                            <a href="/na-dina-halsomal/"
                                class="group flex items-center p-4 -mx-4 rounded-2xl hover:bg-white/50 focus:bg-white/80 focus:ring-2 focus:ring-brand-sky/30 active:scale-[0.98] transition-all outline-none">
                                <div
                                    class="h-16 w-16 shrink-0 rounded-full border border-brand-sky/30 flex items-center justify-center mr-5 group-hover:bg-brand-sky/20 group-hover:border-transparent group-focus:border-brand-sky-dark transition-all">
                                    <Icon name="broken_shield" class="h-12 w-12 text-brand-sky" />
                                </div>
                                <span
                                    class="text-neutral-700 font-medium text-xl group-hover:text-brand-sky group-focus:text-brand-sky-dark transition-all">Ofta
                                    förkyld</span>
                            </a>
                        </li>
                    </ul>

                    <div class="mt-8">
                        <a href="/na-dina-halsomal/"
                            class="btn-tertiary inline-flex items-center group text-sm font-bold uppercase tracking-wider text-brand-sky hover:text-brand-sky-light hover:translate-x-1 focus:text-brand-sky-dark active:scale-95 transition-all outline-none">
                            <span class="pb-1">Visa alla stressrelaterade besvär</span>
                            <span class="ml-2 transform transition-transform group-hover:translate-x-1">&rarr;</span>
                        </a>
                    </div>
                </div>

            </div>
        </div>
    </div>
</section>

<!-- ======================================= -->
<!-- Sektion 2: Hur Fungerar Akupunktur?     -->
<!-- ======================================= -->
<section class="section-standard bg-brand-earth-lightest">
    <div class="container-base max-w-5xl">
        <div class="text-center mb-10 md:mb-14">
            <h2 class="text-brand-earth mb-4">Hur Fungerar Akupunktur?</h2>
            <p class="text-lg text-neutral-700 max-w-2xl mx-auto">
                Akupunktur är ett sätt att kommunicera med kroppens egna energisystem för
                självläkning.
            </p>
        </div>

        <!-- Unified Container for Context & Coherence -->
        <div class="relative">

            <!-- Visual 3-Step Journey -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8 mb-6 md:mb-10 relative z-10">

                <!-- Step 1: Blockage -->
                <div
                    class="relative z-10 flex flex-col items-center text-center p-6 md:p-8 bg-brand-accent/5 rounded-3xl border border-brand-accent/20 shadow-sm transition-transform hover:-translate-y-1">
                    <div
                        class="h-16 w-16 rounded-full bg-brand-earth/10 flex items-center justify-center mb-6 ring-4 ring-brand-earth/5">
                        <Icon name="Yin_yang" class="h-12 w-12 text-brand-earth" />
                    </div>
                    <h3 class="text-lg md:text-xl font-bold text-brand-earth-dark mb-3">1. Identifiera Obalans</h3>
                    <p class="text-neutral-600 text-sm">
                        När energiflödet blockeras av stress, skada eller osund livsstil uppstår smärta och ohälsa. Vi
                        börjar med att finna källan.
                    </p>
                </div>

                <!-- Step 2: Signal -->
                <div
                    class="relative z-10 flex flex-col items-center text-center p-6 md:p-8 bg-brand-accent/5 rounded-3xl border border-brand-accent/20 shadow-md transform md:-translate-y-6 transition-transform hover:-translate-y-7">
                    <div
                        class="h-16 w-16 rounded-full bg-brand-accent/10 flex items-center justify-center mb-6 ring-4 ring-brand-earth/5">
                        <svg class="h-14 w-14 text-brand-accent-dark" fill="none" stroke="currentColor"
                            viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M13 10V3L4 14h7v7l9-11h-7z" />
                        </svg>
                    </div>
                    <h3 class="text-lg md:text-xl font-bold text-brand-earth-dark mb-3">2. Aktivera Signalen</h3>
                    <p class="text-neutral-700 text-sm">
                        Genom specifika punkter instrueras ditt energisystem att börja lösa upp blockeringarna.
                    </p>
                </div>

                <!-- Step 3: Flow -->
                <div
                    class="relative z-10 flex flex-col items-center text-center p-6 md:p-8 bg-brand-accent/5 rounded-3xl border border-brand-accent/20 shadow-sm transition-transform hover:-translate-y-1">
                    <div
                        class="h-16 w-16 rounded-full bg-brand-sky/10 flex items-center justify-center mb-6 ring-4 ring-brand-earth/5">
                        <Icon name="wind_shield" class="h-14 w-14 text-brand-sky" />
                    </div>
                    <h3 class="text-lg md:text-xl font-bold text-brand-earth-dark mb-3">3. Återställ Balans</h3>
                    <p class="text-neutral-600 text-sm">
                        Kroppens naturliga läkningsförmåga tar vid. Blodcirkulationen ökar, stressen sjunker och
                        balansen
                        återställs.
                    </p>
                </div>
            </div>

            <!-- Tightly Integrated Foldable Section: Additional Methods -->
            <div x-data="{ expanded: false }"
                class="max-w-4xl mx-auto rounded-2xl transition-all duration-300 relative z-20"
                :class="expanded ? 'bg-white shadow-md border border-brand-earth/10' : 'bg-transparent border border-transparent hover:bg-brand-accent/5 hover:shadow-sm'">

                <button @click="expanded = !expanded"
                    class="w-full flex items-center justify-between p-4 md:p-6 text-left group focus:outline-none rounded-2xl hover:bg-brand-accent/5 focus:bg-brand-accent/5">
                    <div class="flex items-center space-x-4 md:space-x-5 w-full">
                        <div class="h-10 w-10 shrink-0 rounded-full flex items-center justify-center text-brand-earth-dark transition-colors"
                            :class="expanded ? 'bg-brand-earth/5' : 'bg-white shadow-sm border border-brand-earth/10 group-hover:border-brand-earth/30 group-hover:bg-brand-earth/5'">
                            <svg x-show="!expanded" class="h-5 w-5 transform transition-transform group-hover:scale-110"
                                fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                            </svg>
                            <svg x-show="expanded" x-cloak
                                class="h-5 w-5 transform transition-transform group-hover:scale-110" fill="none"
                                viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4" />
                            </svg>
                        </div>
                        <div class="flex-1">
                            <h3
                                class="text-base md:text-lg font-bold text-neutral-800 m-0 group-hover:text-brand-earth-dark transition-colors">
                                Kompletterande TCM-metoder vid behov
                            </h3>
                            <p class="text-xs md:text-sm text-neutral-500 m-0 mt-0.5 hidden sm:block">
                                Ibland kompletterar vi behandlingen med öronakupressur eller värmande moxa.
                            </p>
                        </div>
                    </div>
                </button>

                <div x-show="expanded" x-collapse x-cloak>
                    <div class="p-4 md:p-6 lg:p-8 pt-0 border-t border-neutral-100 mt-2">
                        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 md:gap-6">
                            <!-- Kort 1: Öronakupressur -->
                            <div class="bg-brand-accent/10 rounded-2xl p-5 border border-neutral-100 shadow-sm">
                                <div class="flex items-center mb-3">
                                    <div
                                        class="flex items-center justify-center h-20 w-20 rounded-full bg-brand-accent/10 mr-3 shrink-0">
                                        <Icon name="oron_akupressur2" class="h-12 w-12 text-brand-accent-dark" />
                                    </div>
                                    <h4 class="text-base font-bold text-neutral-900 m-0">Ta med behandlingen hem med
                                        öronakupressur</h4>
                                </div>
                                <p class="text-neutral-600 text-sm leading-relaxed m-0">
                                    Genom att fästa små medicinska kulor på punkter i örat skapas en konstant
                                    stimulering som varar i flera dagar. Värdefullt vid stress och sömnproblem.
                                </p>
                            </div>

                            <!-- Kort 2: Moxa -->
                            <div class="bg-brand-accent/10 rounded-2xl p-5 border border-neutral-100 shadow-sm">
                                <div class="flex items-center mb-3">
                                    <div
                                        class="flex items-center justify-center h-20 w-20 rounded-full bg-brand-accent/10 mr-3 shrink-0">
                                        <Icon name="moxa" class="h-12 w-12 text-brand-accent-dark" />
                                    </div>
                                    <h4 class="text-base font-bold text-neutral-900 m-0">Värmande behandling</h4>
                                </div>
                                <p class="text-neutral-600 text-sm leading-relaxed m-0">
                                    Värmebehandling med örten gråbo stimulerar specifika punkter. Tillför energi och är
                                    effektivt vid tillstånd präglade av kyla.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</section>




<!-- ======================================= -->
<!-- Sektion 4.5: Din Akupunktör             -->
<!-- ======================================= -->
<section class="section-standard bg-white pt-16 pb-8">
    <div class="container-base max-w-4xl text-center">
        <h2 class="text-brand-earth mb-4">Möt din Akupunktör</h2>
        <p class="text-lg text-neutral-700 max-w-2xl mx-auto mb-12">
            Hos oss utförs alla akupunkturbehandlingar av Linnéa Mao, läkare i
            Traditionell Kinesisk Medicin. Hennes erfarenhet av att hjälpa patienter i Sverige sedan 2007
            garanterar en trygg och mjuk behandling anpassad för dig.
        </p>

        <div class="max-w-2xl mx-auto px-4">
            <article
                class="team-card flex-row bg-brand-accent/5 border border-brand-accent/20 text-left overflow-hidden min-h-[12rem] md:min-h-[14rem]">
                <div class="relative w-32 md:w-48 shrink-0 self-stretch overflow-hidden">
                    <Image src={linnea_mao_profileImage} alt="Linnéa Mao"
                        class="absolute inset-0 h-full w-full object-cover object-top" />
                </div>
                <div class="team-content justify-center py-4 md:py-6 pl-5 md:pl-6">
                    <h3 class="team-name text-xl">Linnéa Mao</h3>
                    <p class="team-role text-xs">Läkare i TCM, Terapeut & Akupunktör</p>
                    <div class="team-bio">
                        <p class="text-sm leading-relaxed">Som TCM-läkare och akupunktör
                            kombinerar Linnéa djup medicinsk kompetens med ett mjukt och inkännande bemötande i sina
                            behandlingar.</p>
                    </div>
                    <div class="flex justify-left mt-10 pb-4">
                        <a href="/om-oss/" class="btn-tertiary text-lg flex items-center group/link">
                            Läs mer om Linnéa
                            <span
                                class="ml-2 transform transition-transform group-hover/link:translate-x-1">&rarr;</span>
                        </a>
                    </div>
                </div>
            </article>
        </div>
    </div>
</section>

<section class="bg-brand-earth-light section-standard text-center">
    <div class="container-base max-w-4xl">

        <!-- Huvud CTA -->
        <div class="max-w-3xl mx-auto mb-16">
            <h2 class="text-brand-earth-dark mb-6 text-3xl md:text-5xl">Redo att ta första steget?</h2>
            <p class="text-brand-earth-dark text-lg md:text-xl leading-relaxed mb-10">
                Vi hjälper dig att hitta rätt behandling för just dig. Många av våra klienter upplever tydlig skillnad i
                smärta och funktion efter cirka 3 behandlingar.
            </p>

            <a href="/kontakt/" class="btn btn-primary-on-dark shadow-lg shadow-black/10 px-10 py-5 text-xl mb-0">
                Boka behandling
            </a>
        </div>

        <!-- Trust & Info Row (Discrete boxes with icon containers) -->
