---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title, 
  description = "Medidraken - Din väg till mindre smärta, mindre stress och mer energi med Traditionell Kinesisk Medicin." 
} = Astro.props;

const displayTitle = title ? `${title} | Medidraken` : "Medidraken | Akupunktur & TCM i Nyköping, Gnesta & Oxelösund";
---
<html lang="sv">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href="/assets/images/medidraken-logo_white_background.png" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- SEO Basics -->
    <title>{displayTitle}</title>
    <meta name="description" content={description} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet">
    <!-- Cloudflare Web Analytics -->
    <script defer src='https://static.cloudflareinsights.com/beacon.min.js' data-cf-beacon='{"token": "YOUR_CLOUDFLARE_TOKEN"}'></script>
    <!-- End Cloudflare Web Analytics -->
  </head>
  <body class="bg-neutral-100 text-neutral-700 font-body antialiased selection:bg-brand-accent selection:text-white">
    <Header />
    
    <slot />

    <Footer />
  </body>
</html>
