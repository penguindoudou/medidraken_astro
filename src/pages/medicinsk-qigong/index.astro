---
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Icon from '../../components/Icon.astro';

// Images
import heroImage from '../../assets/images/qigong_bamboo15.png';
import instructingImage from '../../assets/images/qigong_johannes_instructing_group.jpg';
import johannesProfile from '../../assets/images/johannes_mao_profile.jpg';
import mariaProfile from '../../assets/images/maria_morris_profile.jpg';
import magnusProfile from '../../assets/images/magnus_rooth_profile.jpg';

const courses_qigong = []; // Assuming no active courses for now as per fallback logic in twig
---

<BaseLayout title="Medicinsk Qigong i Nyköping | Kurser för Stress & Energi">
    <!-- Sektion 1: Hero -->
    <section class="hero-section">
        <div class="hero-background">
            <Image src={heroImage} alt="Medicinsk Qigong för inre balans och energi" class="hero-bg-image" />
        </div>
        <div class="hero-content">
            <h1 class="hero-title text-brand-accent text-shadow-hero-glow">Medicinsk Qigong</h1>
            <h2 class="hero-subtitle font-bold text-shadow-hero-shadow">Återfå Energi & Inre Balans</h2>

            <p class="hero-text">
                Känner du dig stressad, trött eller ur balans? Medicinsk Qigong är en varsam men kraftfull metod för att
                stärka din hälsa inifrån. Genom mjuka rörelser, fokuserad andning och mental närvaro löser du upp
                spänningar, kultiverar din livsenergi (Qi) och aktiverar kroppens egen förmåga till återhämtning.
            </p>

            <div class="mt-10">
                <a href="#kursanmalan" class="btn btn-primary-on-dark shadow-lg shadow-black/20">
                    Se Kursstarter & Anmäl Intresse
                </a>
            </div>
        </div>
    </section>

    <!-- Sektion 2: För Vem? (Expanderbar) -->
    <section class="section-standard bg-white">
        <div class="container-base" x-data="{ showAllBenefits: false }">
            <div class="max-w-4xl mx-auto text-center mb-12">
                <h2 class="text-brand-earth">En Skonsam Väg till Återhämtning & Energi</h2>
                <p class="mt-6 text-lg text-neutral-700">
                    När vi känner oss stressade, trötta eller har värk, är det ofta ett tecken på att kroppens system är i
                    obalans. Ur ett TCM-perspektiv uppstår ohälsa när flödet av livsenergi (Qi) är blockeradt. Medicinsk
                    Qigong använder specifika, ofta repetitiva rörelser för att medvetet styra och balansera Qi i kroppens
                    energibanor. Varje övning är utformad för att stärka specifika inre organ och deras funktioner.
                </p>
            </div>

            <!-- Huvudlista (Synlig) -->
            <div class="max-w-3xl mx-auto bg-brand-accent/10 rounded-2xl p-8 border border-brand-earth-lighter shadow-sm">
                <h3 class="font-heading text-2xl text-brand-earth mb-8 text-center decoration-brand-accent/30 underline underline-offset-8">En metod för dig som vill – eller har
                    besvär med:</h3>

                <ul class="space-y-4 md:grid md:grid-cols-2 md:gap-x-8 md:space-y-0 md:gap-y-6">
                    <li class="flex items-start group">
                        <div class="flex-shrink-0 w-8 h-8 rounded-full bg-brand-accent/20 flex items-center justify-center mr-4 group-hover:scale-110 transition-transform">
                            <Icon name="taichi_qigong_flow_min" class="h-5 w-5 text-brand-accent-dark" />
                        </div>
                        <a href="/minska-stress-hitta-inre-lugn/"
                            class="text-brand-earth-dark hover:text-brand-sky font-medium transition-colors pt-1">Minska
                            Stress & Hitta Inre Lugn</a>
                    </li>
                    <li class="flex items-start group">
                         <div class="flex-shrink-0 w-8 h-8 rounded-full bg-brand-accent/20 flex items-center justify-center mr-4 group-hover:scale-110 transition-transform">
                            <Icon name="taichi_qigong_flow_min" class="h-5 w-5 text-brand-accent-dark" />
                        </div>
                        <a href="/oka-energi-livskraft/"
                            class="text-brand-earth-dark hover:text-brand-sky font-medium transition-colors pt-1">Öka
                            Energi & Livskraft</a>
                    </li>
                    <li class="flex items-start group">
                         <div class="flex-shrink-0 w-8 h-8 rounded-full bg-brand-accent/20 flex items-center justify-center mr-4 group-hover:scale-110 transition-transform">
                            <Icon name="somnproblem_mane" class="h-5 w-5 text-brand-accent-dark" />
                        </div>
                        <a href="/somnproblem-insomnia/"
                            class="text-brand-earth-dark hover:text-brand-sky font-medium transition-colors pt-1">Sömnproblem
                            & Insomnia</a>
                    </li>
                    <li class="flex items-start group">
                         <div class="flex-shrink-0 w-8 h-8 rounded-full bg-brand-accent/20 flex items-center justify-center mr-4 group-hover:scale-110 transition-transform">
                            <Icon name="shield_health" class="h-5 w-5 text-brand-accent-dark" />
                        </div>
                        <a href="/starka-immunforsvaret-bygga-motstandskraft/"
                            class="text-brand-earth-dark hover:text-brand-sky font-medium transition-colors pt-1">Stärka
                            Immunförsvaret</a>
                    </li>
                    <li class="flex items-start group">
                         <div class="flex-shrink-0 w-8 h-8 rounded-full bg-brand-accent/20 flex items-center justify-center mr-4 group-hover:scale-110 transition-transform">
                            <Icon name="stress" class="h-5 w-5 text-brand-accent-dark" />
                        </div>
                        <a href="/utbrandhet-trotthetssyndrom/"
                            class="text-brand-earth-dark hover:text-brand-sky font-medium transition-colors pt-1">Utbrändhet
                            & Trötthetssyndrom</a>
                    </li>
                    <li class="flex items-start group">
                         <div class="flex-shrink-0 w-8 h-8 rounded-full bg-brand-accent/20 flex items-center justify-center mr-4 group-hover:scale-110 transition-transform">
                            <Icon name="flower" class="h-5 w-5 text-brand-accent-dark" />
                        </div>
                        <a href="/nedstamdhet-depression/"
                            class="text-brand-earth-dark hover:text-brand-sky font-medium transition-colors pt-1">Nedstämdhet
                            & Depression</a>
                    </li>
                </ul>

                <!-- Expanderknapp -->
                <div class="text-center mt-12">
                    <button @click="showAllBenefits = !showAllBenefits" type="button"
                        class="inline-flex items-center text-brand-sky font-bold hover:text-brand-accent-dark transition-colors focus:outline-none bg-brand-accent/5 px-6 py-2 rounded-full border border-brand-accent/20">
                        <span x-text="showAllBenefits ? 'Visa mindre' : 'Visa alla hälsofördelar'"></span>
                        <svg class="w-5 h-5 ml-2 transform transition-transform duration-300"
                            :class="{'rotate-180': showAllBenefits}" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7"></path>
                        </svg>
                    </button>
                </div>

                <!-- Dold Del (Expanderbar) -->
                <div x-show="showAllBenefits" x-collapse class="mt-8 pt-8 border-t border-brand-earth-lighter/30">
                    <div class="grid md:grid-cols-2 gap-12">
                        <!-- För Smärta & Värk -->
                        <div>
                            <h4 class="font-bold text-brand-earth-dark mb-6 uppercase text-sm tracking-widest border-l-4 border-brand-accent pl-4">För Smärta &
                                Värk</h4>
                            <ul class="space-y-4">
                                <li><a href="/rygg-landrygg/langvarig-vark-stelhet-landrygg/"
                                        class="text-brand-earth hover:text-brand-sky font-medium transition-colors flex items-center">
                                        <span class="w-1.5 h-1.5 bg-brand-accent rounded-full mr-3"></span>
                                        Långvarig värk & stelhet i ryggen</a></li>
                                <li><a href="/nacke-axlar-skuldror/"
                                        class="text-brand-earth hover:text-brand-sky font-medium transition-colors flex items-center">
                                         <span class="w-1.5 h-1.5 bg-brand-accent rounded-full mr-3"></span>
                                        Värk i nacke, axlar & skuldror</a></li>
                                <li><a href="/ledvark-idrottsskador-artros/"
                                        class="text-brand-earth hover:text-brand-sky font-medium transition-colors flex items-center">
                                         <span class="w-1.5 h-1.5 bg-brand-accent rounded-full mr-3"></span>
                                        Ledvärk & Artros</a></li>
                                <li><a href="/rygg-landrygg/ischias/"
                                        class="text-brand-earth hover:text-brand-sky font-medium transition-colors flex items-center">
                                         <span class="w-1.5 h-1.5 bg-brand-accent rounded-full mr-3"></span>
                                        Ischias & Utstrålande Smärta</a></li>
                                <li><a href="/fibromyalgi-kronisk-smarta/"
                                        class="text-brand-earth hover:text-brand-sky font-medium transition-colors flex items-center">
                                         <span class="w-1.5 h-1.5 bg-brand-accent rounded-full mr-3"></span>
                                        Fibromyalgi & kronisk smärta</a></li>
                                <li><a href="/huvudvark-yrsel/spanningshuvudvark-stresshuvudvark/"
                                        class="text-brand-earth hover:text-brand-sky font-medium transition-colors flex items-center">
                                         <span class="w-1.5 h-1.5 bg-brand-accent rounded-full mr-3"></span>
                                        Spänningshuvudvärk</a>
                                </li>
                            </ul>
                        </div>

                        <!-- För Funktion -->
                        <div>
                            <h4 class="font-bold text-brand-earth-dark mb-6 uppercase text-sm tracking-widest border-l-4 border-brand-accent pl-4">För Fysisk &
                                Mental Funktion</h4>
                            <ul class="space-y-4">
                                <li><a href="/forbattra-balans-rorlighet-kroppskontroll/"
                                        class="text-brand-earth hover:text-brand-sky font-medium transition-colors flex items-center">
                                        <span class="w-1.5 h-1.5 bg-brand-accent rounded-full mr-3"></span>
                                        Förbättra Balans & Kroppskontroll</a></li>
                                <li><a href="/huvudvark-yrsel/yrsel-balansproblem/"
                                        class="text-brand-earth hover:text-brand-sky font-medium transition-colors flex items-center">
                                        <span class="w-1.5 h-1.5 bg-brand-accent rounded-full mr-3"></span>
                                        Yrsel & Balansproblem</a></li>
                                <li><a href="/starka-fokus-mental-styrka/"
                                        class="text-brand-earth hover:text-brand-sky font-medium transition-colors flex items-center">
                                        <span class="w-1.5 h-1.5 bg-brand-accent rounded-full mr-3"></span>
                                        Stärka Fokus & Mental Styrka</a></li>
                                <li><a href="/magbesvar-ibs/"
                                        class="text-brand-earth hover:text-brand-sky font-medium transition-colors flex items-center">
                                        <span class="w-1.5 h-1.5 bg-brand-accent rounded-full mr-3"></span>
                                        Mag- och Tarmbesvär (IBS)</a></li>
                                <li><a href="/oka-energi-livskraft/"
                                        class="text-brand-earth hover:text-brand-sky font-medium transition-colors flex items-center">
                                        <span class="w-1.5 h-1.5 bg-brand-accent rounded-full mr-3"></span>
                                        Snabbare återhämtning för idrottare</a></li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <!-- Korslänk Tai Chi -->
        <div class="max-w-3xl mx-auto mt-10 w-full px-4">
            <div class="p-6 bg-brand-earth-lightest rounded-2xl border border-brand-earth/10 shadow-inner">
                <p class="text-base italic text-neutral-600 leading-relaxed">
                    <strong>Tips:</strong> När du är redo att utmana din koordination, är <a href="/tai-chi/"
                        class="text-brand-sky hover:text-brand-accent-dark font-bold underline decoration-brand-sky/30">Tai Chi</a> ett perfekt nästa
                    steg.
                </p>
            </div>
        </div>
    </section>

    <!-- Sektion 3: Kursformer (Weekly removed) -->
    <section class="section-standard bg-brand-earth-lightest">
        <div class="container-base">
            <div class="text-center mb-16 max-w-3xl mx-auto">
                <h2 class="text-brand-earth">Välj en kursform som passar dig</h2>
                <p class="mt-6 text-lg text-neutral-700">
                    Vår undervisning fokuserar på effektiva och lättillgängliga metoder som <em>Sex Hemliga Ljud</em> (Liu Zi Jue) och <em>Inombordsövningar</em> (Nei Gong). Oavsett vilken form du väljer får du lära dig kraftfulla verktyg för din hälsa.
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-12 max-w-4xl mx-auto">
                <!-- Helgkurser -->
                <div class="content-box group hover:border-brand-accent/40 transition-all duration-300">
                    <div class="flex items-center justify-center h-20 w-20 rounded-full bg-brand-accent/20 mb-6 mx-auto group-hover:bg-brand-accent/30 transition-colors">
                        <Icon name="taichi_qigong_flow" class="h-12 w-12 text-brand-accent-dark" />
                    </div>
                    <h3 class="text-2xl font-bold text-neutral-900 mb-4">Helgkurser</h3>
                    <p class="text-neutral-700 mb-8 flex-grow text-lg">
                        Djupdyk och upplev en ny nivå av inre lugn och lär dig en komplett hälsometod under en helg. Perfekt
                        för dig som vill komma igång snabbt.
                    </p>
                    <div class="mt-auto pt-6 border-t border-neutral-200">
                        <a href="/helgkurser-qigong/" class="btn-tertiary text-lg font-bold">Läs mer om helgkurser &rarr;</a>
                    </div>
                </div>

                <!-- Privatundervisning -->
                <div class="content-box group hover:border-brand-accent/40 transition-all duration-300">
                    <div class="flex items-center justify-center h-20 w-20 rounded-full bg-brand-accent/20 mb-6 mx-auto group-hover:bg-brand-accent/30 transition-colors">
                        <Icon name="holistic_qi_human" class="h-12 w-12 text-brand-accent-dark" />
                    </div>
                    <h3 class="text-2xl font-bold text-neutral-900 mb-4">Privatundervisning</h3>
                    <p class="text-neutral-700 mb-8 flex-grow text-lg">
                        Få ett program som är anpassat efter dig med fullt fokus på dina personliga hälsomål och
                        förutsättningar.
                    </p>
                    <div class="mt-auto pt-6 border-t border-neutral-200">
                        <a href="/privatundervisning-qigong/" class="btn-tertiary text-lg font-bold">Läs mer om privatlektioner &rarr;</a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Sektion 4: Kursstarter / Fallback -->
    <section class="section-standard bg-white" id="kursanmalan">
        <div class="container-base">
            <h2 class="text-brand-earth text-center mb-16">Kursstarter för Medicinsk Qigong</h2>

            {courses_qigong.length > 0 ? (
                <div class="overflow-x-auto shadow-xl rounded-2xl max-w-5xl mx-auto border border-neutral-200">
                    <table class="min-w-full leading-normal">
                        <thead>
                            <tr>
                                <th class="px-6 py-4 border-b-2 border-brand-earth bg-brand-earth-lightest text-left text-xs font-bold text-brand-earth uppercase tracking-widest">Kursform</th>
                                <th class="px-6 py-4 border-b-2 border-brand-earth bg-brand-earth-lightest text-left text-xs font-bold text-brand-earth uppercase tracking-widest">Ort</th>
                                <th class="px-6 py-4 border-b-2 border-brand-earth bg-brand-earth-lightest text-left text-xs font-bold text-brand-earth uppercase tracking-widest">Dag / Tid</th>
                                <th class="px-6 py-4 border-b-2 border-brand-earth bg-brand-earth-lightest text-left text-xs font-bold text-brand-earth uppercase tracking-widest">Start</th>
                                <th class="px-6 py-4 border-b-2 border-brand-earth bg-brand-earth-lightest"></th>
                            </tr>
                        </thead>
                        <tbody>
                            {courses_qigong.map((course) => (
                                <tr>
                                    <td class="px-6 py-6 border-b border-gray-200 bg-white text-sm">
                                        <p class="text-gray-900 whitespace-no-wrap font-bold text-lg">{course.title}</p>
                                    </td>
                                    <td class="px-6 py-6 border-b border-gray-200 bg-white text-sm">
                                        <p class="text-gray-900 whitespace-no-wrap">{course.location}</p>
                                    </td>
                                    <td class="px-6 py-6 border-b border-gray-200 bg-white text-sm">
                                        <p class="text-gray-900 whitespace-no-wrap">{course.day_time}</p>
                                    </td>
                                    <td class="px-6 py-6 border-b border-gray-200 bg-white text-sm">
                                        <span class="relative inline-block px-4 py-1.5 font-bold text-brand-earth-dark leading-tight">
                                            <span aria-hidden class="absolute inset-0 bg-brand-accent/20 rounded-full"></span>
                                            <span class="relative">{course.start_date}</span>
                                        </span>
                                    </td>
                                    <td class="px-6 py-6 border-b border-gray-200 bg-white text-sm text-right">
                                        <a href={course.link} class="btn-tertiary font-bold hover:scale-105 transition-transform inline-block">Boka &rarr;</a>
                                    </td>
                                </tr>
                            ))}
                        </tbody>
                    </table>
                </div>
            ) : (
                <div class="max-w-4xl mx-auto border-4 border-dashed border-neutral-200 rounded-3xl p-10 md:p-16 bg-neutral-50/50">
                    <h3 class="font-heading text-3xl text-brand-earth mb-6 text-center">Så här kommer du igång!</h3>
                    <p class="text-lg text-neutral-700 mb-12 text-center max-w-2xl mx-auto">
                        Just nu har vi inga schemalagda gruppstarter för Medicinsk Qigong, men din intresseanmälan är avgörande
                        för vår planering. Det finns flera alternativ för att börja din hälsoresa redan nu.
                    </p>

                    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                        <!-- Väg 1: Intresseanmälan -->
                        <div class="bg-white p-8 rounded-2xl shadow-sm border border-neutral-200 hover:shadow-md hover:-translate-y-1 transition-all">
                            <div class="flex items-center justify-center h-14 w-14 rounded-full bg-brand-sky text-white mb-6 shadow-lg shadow-brand-sky/20">
                                <Icon name="taichi_qigong_flow_min" class="h-8 w-8" />
                            </div>
                            <h4 class="font-bold text-brand-earth-dark text-xl mb-4">Intresseanmälan</h4>
                            <p class="text-neutral-600 mb-6 text-sm leading-relaxed">
                                Var först med att få info om nästa termin. Genom att anmäla intresse hjälper du oss planera.
                            </p>
                            <a href="/kontakt/?subject=Kursintresse%20Qigong" class="btn-tertiary font-bold underline decoration-brand-sky/20">Anmäl intresse &rarr;</a>
                        </div>

                        <!-- Väg 2: Privatundervisning -->
                        <div class="bg-white p-8 rounded-2xl shadow-sm border border-neutral-200 hover:shadow-md hover:-translate-y-1 transition-all">
                            <div class="flex items-center justify-center h-14 w-14 rounded-full bg-brand-sky text-white mb-6 shadow-lg shadow-brand-sky/20">
                                <Icon name="holistic_qi_human" class="h-8 w-8" />
                            </div>
                            <h4 class="font-bold text-brand-earth-dark text-xl mb-4">Privatundervisning</h4>
                            <p class="text-neutral-600 mb-6 text-sm leading-relaxed">
                                Få 100% odelad uppmärksamhet och undervisning anpassad för dig. Vi kan ofta hitta en tid inom
                                kort.
                            </p>
                            <a href="/privatundervisning-qigong/" class="btn-tertiary font-bold underline decoration-brand-sky/20">Läs mer &rarr;</a>
                        </div>

                        <!-- Väg 3: Egen Grupp -->
                        <div class="bg-white p-8 rounded-2xl shadow-sm border border-neutral-200 hover:shadow-md hover:-translate-y-1 transition-all">
                            <div class="flex items-center justify-center h-14 w-14 rounded-full bg-brand-sky text-white mb-6 shadow-lg shadow-brand-sky/20">
                                <Icon name="holistic_qi_human_circle" class="h-8 w-8" />
                            </div>
                            <h4 class="font-bold text-brand-earth-dark text-xl mb-4">Egen Grupp</h4>
                            <p class="text-neutral-600 mb-6 text-sm leading-relaxed">
                                Perfekt för arbetsplatsen eller kompisgänget. Vi skapar ett upplägg som passar er.
                            </p>
                            <a href="/upplevelser/workshops-gruppaktiviteter/" class="btn-tertiary font-bold underline decoration-brand-sky/20">Läs mer &rarr;</a>
                        </div>
                    </div>
                </div>
            )}
        </div>
    </section>

    <!-- Sektion 5: Metod & Team -->
    <section class="section-standard bg-brand-earth-lightest overflow-hidden">
        <div class="container-base">
            <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

                <!-- Text -->
                <div class="order-2 lg:order-1">
                    <h2 class="text-brand-earth mb-8">Lätt att Börja – Kraftfulla Resultat</h2>
                    <p class="mb-8 text-lg">
                        Du behöver inga förkunskaper för att börja med Medicinsk Qigong. Rörelserna är enkla, skonsamma och
                        kan anpassas efter allas fysiska förutsättningar. Vår pedagogik bygger på några enkla principer:
                    </p>
                    <ul class="space-y-6 mb-10">
                        <li class="flex items-start">
                            <div class="flex-shrink-0 w-8 h-8 rounded-full bg-brand-accent/20 flex items-center justify-center mr-4">
                                <Icon name="taichi_qigong_flow_min" class="h-5 w-5 text-brand-accent-dark" />
                            </div>
                            <div>
                                <strong class="text-brand-earth-dark block text-lg">Enkla, kraftfulla övningar</strong>
                                <span class="text-neutral-700">Vi fokuserar på beprövade metoder som är lätta att lära sig
                                    men ger djup effekt.</span>
                            </div>
                        </li>
                        <li class="flex items-start">
                             <div class="flex-shrink-0 w-8 h-8 rounded-full bg-brand-accent/20 flex items-center justify-center mr-4">
                                <Icon name="flower" class="h-5 w-5 text-brand-accent-dark" />
                            </div>
                            <div>
                                <strong class="text-brand-earth-dark block text-lg">Känn effekten direkt</strong>
                                <span class="text-neutral-700">Många upplever ökat lugn redan första passet, medan varaktiga
                                    resultat kommer med tid.</span>
                            </div>
                        </li>
                        <li class="flex items-start">
                             <div class="flex-shrink-0 w-8 h-8 rounded-full bg-brand-accent/20 flex items-center justify-center mr-4">
                                <Icon name="shield_health" class="h-5 w-5 text-brand-accent-dark" />
                            </div>
                            <div>
                                <strong class="text-brand-earth-dark block text-lg">Hälsan i fokus, inte prestationen</strong>
                                <span class="text-neutral-700">Vi guidar dig till att lyssna på din kropp och använda Qigong
                                    för ditt välbefinnande.</span>
                            </div>
                        </li>
                    </ul>

                    <div class="bg-white p-8 rounded-2xl border-l-8 border-brand-accent shadow-sm mb-10 italic text-lg leading-relaxed text-neutral-800">
                        "Vi ser din hälsoresa som ett samspel. För oss är dina frågor och upplevelser en viktig del av
                        undervisningen. Vår roll är att skapa en trygg atmosfär där du hittar balans och energi."
                    </div>

                    <!-- Team Link with Thumbnails -->
                    <div class="flex flex-col sm:flex-row items-center gap-6">
                        <div class="flex -space-x-4">
                            <Image class="inline-block h-14 w-14 rounded-full ring-4 ring-white shadow-md bg-neutral-800 object-cover"
                                src={johannesProfile} alt="Johannes" />
                            <Image class="inline-block h-14 w-14 rounded-full ring-4 ring-white shadow-md bg-neutral-800 object-cover"
                                src={mariaProfile} alt="Maria" />
                            <Image class="inline-block h-14 w-14 rounded-full ring-4 ring-white shadow-md bg-neutral-800 object-cover"
                                src={magnusProfile} alt="Magnus" />
                        </div>
                        <a href="/om-oss/#team" class="btn-tertiary text-lg font-bold hover:translate-x-2 transition-transform">
                            Möt våra instruktörer &rarr;
                        </a>
                    </div>
                </div>

                <!-- Bild -->
                <div class="order-1 lg:order-2 relative">
                    <div class="absolute inset-0 bg-brand-accent transform translate-x-4 translate-y-4 rounded-3xl opacity-10"></div>
                    <Image src={instructingImage}
                        alt="Instruktör som visar Qigong-rörelse"
                        class="relative rounded-3xl shadow-2xl w-full object-cover h-[600px]" />
                </div>

            </div>
        </div>
    </section>

    <!-- Sektion 6: Anmälan & Info (CTA) -->
    <section id="kursanmalan" class="section-standard bg-brand-earth-light text-center">
        <div class="container-base max-w-4xl">
            <h2 class="text-brand-earth-dark mb-8 text-4xl md:text-5xl">Redo att börja din resa mot mer energi och lugn?</h2>
            <p class="text-xl text-brand-earth mb-12 leading-relaxed">
                Nya kursstarter planeras löpande. Det enklaste sättet att få all information du behöver är att anmäla ditt
                intresse. Då kontaktar vi dig personligen med information om kommande starter, upplägg och priser.
                <br><span class="text-brand-earth-dark font-extrabold text-2xl mt-4 block">Din anmälan är helt kostnadsfri och inte
                    bindande.</span>
            </p>

            <a href="/kontakt/?subject=Kursintresse%20Qigong"
                class="btn btn-primary-on-dark text-xl px-12 py-6 shadow-2xl shadow-black/30 mb-20 hover:scale-105">
                Anmäl intresse & få mer information
            </a>

            <!-- Praktisk Info List -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-left border-t border-brand-earth-dark/10 pt-16">
                <!-- Platser -->
                <div class="group bg-brand-earth-dark/5 rounded-3xl p-8 border-2 border-brand-earth-dark/10 hover:border-brand-accent/30 transition-all">
                    <div class="flex items-center mb-6">
                        <div class="flex items-center justify-center h-12 w-12 rounded-full bg-brand-earth-dark/10 mr-4">
                            <Icon name="pin" class="h-6 w-6 text-brand-earth-dark" />
                        </div>
                        <span class="font-bold text-brand-earth-dark text-2xl">Platser</span>
                    </div>
                    <p class="text-neutral-700 leading-relaxed">
                        Våra kurser hålls i
                        <a href="/kontakt/#mottagningar" class="text-brand-sky hover:text-brand-sky-dark font-bold underline decoration-brand-sky/20">Nyköping</a>,
                        <a href="/kontakt/#mottagningar" class="text-brand-sky hover:text-brand-sky-dark font-bold underline decoration-brand-sky/20">Gnesta</a> och
                        <a href="/kontakt/#mottagningar" class="text-brand-sky hover:text-brand-sky-dark font-bold underline decoration-brand-sky/20">Oxelösund</a>
                    </p>
                </div>

                <!-- Friskvård -->
                <div class="group bg-brand-earth-dark/5 rounded-3xl p-8 border-2 border-brand-earth-dark/10 hover:border-brand-accent/30 transition-all">
                    <div class="flex items-center mb-6">
                        <div class="flex items-center justify-center h-12 w-12 rounded-full bg-brand-earth-dark/10 mr-4">
                            <Icon name="shield_health" class="h-6 w-6 text-brand-earth-dark" />
                        </div>
                        <span class="font-bold text-brand-earth-dark text-2xl">Friskvård</span>
                    </div>
                    <p class="text-neutral-700 leading-relaxed mb-4">
                        Använd ditt Friskvårdsbidrag! Alla våra kurser är godkända friskvårdsaktiviteter.
                    </p>
                    <a href="/friskvardsbidrag/" class="text-brand-sky hover:text-brand-sky-dark font-bold flex items-center">
                        Läs mer <span class="ml-2 group-hover:translate-x-1 transition-transform">&rarr;</span>
                    </a>
                </div>

                <!-- Presentkort -->
                <div class="group bg-brand-earth-dark/5 rounded-3xl p-8 border-2 border-brand-earth-dark/10 hover:border-brand-accent/30 transition-all">
                    <div class="flex items-center mb-6">
                        <div class="flex items-center justify-center h-12 w-12 rounded-full bg-brand-earth-dark/10 mr-4">
                            <Icon name="flower" class="h-6 w-6 text-brand-earth-dark" />
                        </div>
                        <span class="font-bold text-brand-earth-dark text-2xl">Presentkort</span>
                    </div>
                    <p class="text-neutral-700 leading-relaxed mb-4">
                        Ge bort en upplevelse av hälsa och vitalitet med ett presentkort i Medicinsk Qigong.
                    </p>
                    <a href="/presentkort/" class="text-brand-sky hover:text-brand-sky-dark font-bold flex items-center">
                        Läs mer <span class="ml-2 group-hover:translate-x-1 transition-transform">&rarr;</span>
                    </a>
                </div>
            </div>
        </div>
    </section>

    <!-- Sektion 7: FAQ (Accordion) -->
    <section class="section-standard bg-white">
        <div class="container-base max-w-4xl">
            <h2 class="text-brand-earth text-center mb-16">Vanliga frågor om Medicinsk Qigong</h2>

            <div class="space-y-6" x-data="{ active: null }">
                {[
                    {
                        q: "Vad är skillnaden mellan Qigong och Tai Chi?",
                        a: "Enkelt förklarat består Qigong oftare av enklare, enskilda rörelser som repeteras med specifikt hälsofokus. Tai Chi är en längre, sammanhängande serie av rörelser (en form) som ursprungligen är en kampkonst, men som tränas för sina hälsofördelar."
                    },
                    {
                        q: "Vad innebär Medicinsk Qigong?",
                        a: "Medicinsk Qigong innebär att metoderna vi lär ut är en integrerad del av Traditionell Kinesisk Medicin (TCM). Varje övning är specifikt utformad för att påverka kroppens energisystem och inre organ för att förebygga ohälsa och främja läkning, snarare än att ha ett spirituellt eller gymnastiskt fokus."
                    },
                    {
                        q: "Hur snabbt får jag resultat?",
                        a: "Många upplever en omedelbar effekt, som ett ökat lugn och mer energi, redan under första passet. Mer varaktiga och djupgående hälsofördelar, som minskad värk eller bättre sömn, infinner sig vanligtvis efter några tillfällens regelbunden träning."
                    },
                    {
                      q: "Vilka Qigong-metoder lär ni ut?",
                      a: "<p class='mb-4'>Vi fokuserar främst på två klassiska och mycket effektiva metoder:</p><ul class='list-disc list-inside space-y-4'><li><strong>Sex Hemliga Ljud (Liu Zi Jue):</strong> En metod där sex specifika ljud kombineras med enkla och dynamiska armrörelser. Syftet är att balansera och rensa ut spänningar från de inre organen.</li><li><strong>Inombordsövningar (Nei Gong):</strong> Detta är det 'inre arbetet' inom Qigong. Det handlar om att genom mental närvaro och subtil andningskontroll bygga upp energi inifrån.</li></ul>"
                    },
                    {
                        q: "Hur är kursen upplagd – praktik eller teori?",
                        a: "Vår pedagogik är enkel: vi tror på att lära genom att göra. Kursens fokus är nästan uteslutande på det praktiska utövandet. Eventuella frågor och filosofiska resonemang hanterar vi kortfattat och effektivt för att maximera den gemensamma tiden för praktik."
                    },
                    {
                        q: "Vad för kläder passar för Qigong?",
                        a: "Mjuka, bekväma kläder som du kan röra dig fritt i. Inomhus fungerar strumpor eller rena inneskor med platt sula bra. Utomhus rekommenderas bekväma skor med platt sula."
                    }
                ].map((item, index) => (
                    <div class="border-2 border-neutral-100 rounded-2xl overflow-hidden hover:border-brand-accent/20 transition-colors shadow-sm">
                        <button 
                            @click={`active === ${index} ? active = null : active = ${index}`}
                            class="w-full flex justify-between items-center p-6 bg-neutral-50 hover:bg-white transition-colors focus:outline-none"
                            :class={`active === ${index} ? 'bg-white' : ''`}
                        >
                            <span class="font-bold text-brand-earth text-left text-lg md:text-xl">{item.q}</span>
                            <span class="ml-4 text-brand-sky transform transition-transform"
                                :class={`active === ${index} ? 'rotate-180' : ''`}>
                                <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                                </svg>
                            </span>
                        </button>
                        <div 
                            x-show={`active === ${index}`} 
                            x-collapse 
                            x-cloak
                            class="p-8 bg-white text-neutral-700 leading-relaxed border-t-2 border-neutral-100 text-lg"
                        >
                            <Fragment set:html={item.a} />
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </section>
</BaseLayout>
