---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';

// Placeholder bild, byt ut vid tillfälle
import heroImage from '../assets/images/taichi_hero6.png'; 
import { siteConfig } from '../data/site.ts';
---

<BaseLayout title="Använd Ditt Friskvårdsbidrag för Massage & Qigong i Nyköping | Medidraken">
    <!-- Sektion 1: Toppsektion (Hero) -->
    <section class="hero-section">
        <div class="hero-background">
            <Image 
                src={heroImage} 
                alt="Friskvårdsbidrag för hälsan" 
                class="hero-bg-image" 
            />
        </div>
        <div class="hero-content">
            <h1 class="hero-title text-brand-accent">Friskvårdsbidrag</h1>
            
            <div class="hero-text bg-brand-earth-dark/40 p-6 rounded-lg backdrop-blur-sm border border-white/10">
                <h2 class="hero-subtitle font-bold mb-3">Investera i din Hälsa & Sänk din Stressnivå</h2>
                <p class="hero-text mt-0">
                    På Medidraken är din hälsa i fokus! Alla våra kurser och de flesta av våra behandlingar är godkända för friskvårdsbidrag - en fin förmån som många arbetsgivare erbjuder. Investera i dig själv och upplev fördelarna med TCM, Tai Chi och Qigong för mer energi och mindre stress.
                </p>
            </div>

            <div class="mt-10">
                <a href="/kontakt/?subject=friskvardsbidrag#tidsbokning" class="btn btn-primary-on-dark">
                    Boka & Använd ditt Friskvårdsbidrag
                </a>
            </div>
        </div>
    </section>

    <!-- ======================================= -->
    <!-- Sektion 2: Vad vi hjälper dig med       -->
    <!-- ======================================= -->
    <section class="bg-white border-t border-neutral-100 section-standard">
        <div class="container-base">
            <div class="text-center max-w-3xl mx-auto mb-16 px-4">
                <h2 class="text-brand-earth mb-4 uppercase tracking-wide">Vi hjälper dig med:</h2>
                <p class="text-lg text-neutral-700">
                    Oavsett om du har specifika besvär eller vill investera i din hälsa, kan vi hjälpa dig att hitta rätt väg till ett bättre mående.
                </p>
            </div>

            <!-- Content Grid: Side-by-Side on Desktop -->
            <div class="grid grid-cols-1 lg:grid-cols-[1.5fr_1fr] gap-8 lg:gap-12 items-start max-w-6xl mx-auto mb-12">

                <!-- Left: Besvär (Fysiska & Stressrelaterade) (Accent path) -->
                <div class="bg-brand-accent/10 rounded-3xl p-8 border border-brand-accent/25 shadow-sm">
                    <div class="flex items-center mb-8 pb-6 border-b border-brand-accent/30">
                        <div class="h-16 w-16 rounded-full bg-brand-accent/10 flex items-center justify-center mr-6 shrink-0">
                            <Icon name="ryggont" class="h-13 w-13 text-brand-accent-dark" />
                        </div>
                        <h3 class="text-brand-earth-dark font-bold text-3xl m-0">Medicinska Besvär</h3>
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-10">
                        <!-- Column 1: Fysiska -->
                        <div>
                            <h4 class="text-brand-earth-dark italic font-bold text-xl mb-4 px-2">Fysiska besvär</h4>
                            <ul class="flex flex-col gap-y-4">
                                <li>
                                    <div class="group flex items-center p-4 -mx-4 sm:mx-0 rounded-2xl hover:bg-white/50 transition-all">
                                        <div class="h-16 w-16 shrink-0 rounded-full border border-brand-accent/30 flex items-center justify-center mr-4 group-hover:bg-brand-accent/20 group-hover:border-transparent transition-all">
                                            <Icon name="ryggont" class="h-14 w-14 text-brand-accent-dark" />
                                        </div>
                                        <span class="text-brand-accent-dark font-medium text-lg lg:text-xl group-hover:text-brand-accent transition-all">Rygg &amp; Ländrygg</span>
                                    </div>
                                </li>
                                <li>
                                    <div class="group flex items-center p-4 -mx-4 sm:mx-0 rounded-2xl hover:bg-white/50 transition-all">
                                        <div class="h-16 w-16 shrink-0 rounded-full border border-brand-accent/30 flex items-center justify-center mr-4 group-hover:bg-brand-accent/20 group-hover:border-transparent transition-all">
                                            <Icon name="nackont" class="h-12 w-12 text-brand-accent-dark" />
                                        </div>
                                        <span class="text-brand-accent-dark font-medium text-lg lg:text-xl group-hover:text-brand-accent transition-all">Nacke &amp; Axlar</span>
                                    </div>
                                </li>
                                <li>
                                    <div class="group flex items-center p-4 -mx-4 sm:mx-0 rounded-2xl hover:bg-white/50 transition-all">
                                        <div class="h-16 w-16 shrink-0 rounded-full border border-brand-accent/30 flex items-center justify-center mr-4 group-hover:bg-brand-accent/20 group-hover:border-transparent transition-all">
                                            <Icon name="huvudvark" class="h-12 w-12 text-brand-accent-dark" />
                                        </div>
                                        <span class="text-brand-accent-dark font-medium text-lg lg:text-xl group-hover:text-brand-accent transition-all">Huvudvärk &amp; Yrsel</span>
                                    </div>
                                </li>
                                <li>
                                    <div class="group flex items-center p-4 -mx-4 sm:mx-0 rounded-2xl hover:bg-white/50 transition-all">
                                        <div class="h-16 w-16 shrink-0 rounded-full border border-brand-accent/30 flex items-center justify-center mr-4 group-hover:bg-brand-accent/20 group-hover:border-transparent transition-all">
                                            <Icon name="ledvark" class="h-15 w-15 text-brand-accent-dark" />
                                        </div>
                                        <span class="text-brand-accent-dark font-medium text-lg lg:text-xl group-hover:text-brand-accent transition-all">Ledvärk, Artros &amp; Idrottsskador</span>
                                    </div>
                                </li>
                            </ul>
                        </div>

                        <!-- Column 2: Stressrelaterade -->
                        <div>
                            <h4 class="text-brand-earth-dark italic font-bold text-xl mb-4 px-2">Stressrelaterade besvär</h4>
                            <ul class="flex flex-col gap-y-4">
                                <li>
                                    <div class="group flex items-center p-4 -mx-4 sm:mx-0 rounded-2xl hover:bg-white/50 transition-all">
                                        <div class="h-16 w-16 shrink-0 rounded-full border border-brand-accent/30 flex items-center justify-center mr-4 group-hover:bg-brand-accent/20 group-hover:border-transparent transition-all">
                                            <Icon name="broken_moon_with_stars" class="h-10 w-10 text-brand-accent-dark" />
                                        </div>
                                        <span class="text-brand-accent-dark font-medium text-lg lg:text-xl group-hover:text-brand-accent transition-all">Sömnproblem</span>
                                    </div>
                                </li>
                                <li>
                                    <div class="group flex items-center p-4 -mx-4 sm:mx-0 rounded-2xl hover:bg-white/50 transition-all">
                                        <div class="h-16 w-16 shrink-0 rounded-full border border-brand-accent/30 flex items-center justify-center mr-4 group-hover:bg-brand-accent/20 group-hover:border-transparent transition-all">
                                            <Icon name="outlined_wilted_leaf" class="h-10 w-10 text-brand-accent-dark" />
                                        </div>
                                        <span class="text-brand-accent-dark font-medium text-lg lg:text-xl group-hover:text-brand-accent transition-all">Utbrändhet &amp; Trötthet</span>
                                    </div>
                                </li>
                                <li>
                                    <div class="group flex items-center p-4 -mx-4 sm:mx-0 rounded-2xl hover:bg-white/50 transition-all">
                                        <div class="h-16 w-16 shrink-0 rounded-full border border-brand-accent/30 flex items-center justify-center mr-4 group-hover:bg-brand-accent/20 group-hover:border-transparent transition-all">
                                            <Icon name="broken_shield" class="h-12 w-12 text-brand-accent-dark" />
                                        </div>
                                        <span class="text-brand-accent-dark font-medium text-lg lg:text-xl group-hover:text-brand-accent transition-all">Ofta förkyld</span>
                                    </div>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>

                <!-- Right: Hälsofördelar (Sky path) -->
                <div class="bg-brand-sky/5 rounded-3xl p-8 border border-brand-sky/10 shadow-sm h-full">
                    <div class="flex items-center mb-10 pb-6 border-b border-brand-sky/20">
                        <div class="h-16 w-16 shrink-0 rounded-full bg-brand-sky/10 flex items-center justify-center mr-6">
                            <Icon name="holistic_qi_human" class="h-14 w-14 text-brand-sky" />
                        </div>
                        <h3 class="text-brand-sky font-bold text-3xl m-0 leading-tight">Hälsofördelar</h3>
                    </div>

                    <ul class="space-y-6 mt-5">
                        <li>
                            <div class="group flex items-center p-4 -mx-4 rounded-2xl hover:bg-white/50 transition-all">
                                <div class="h-16 w-16 shrink-0 rounded-full border border-brand-sky/30 flex items-center justify-center mr-5 group-hover:bg-brand-sky/20 group-hover:border-transparent transition-all">
                                    <Icon name="Yin_yang" class="h-10 w-10 text-brand-sky" />
                                </div>
                                <span class="text-neutral-700 font-medium text-lg lg:text-xl group-hover:text-brand-sky transition-all">Hitta Inre Lugn &amp; Balans</span>
                            </div>
                        </li>
                        <li>
                            <div class="group flex items-center p-4 -mx-4 rounded-2xl hover:bg-white/50 transition-all">
                                <div class="h-16 w-16 shrink-0 rounded-full border border-brand-sky/30 flex items-center justify-center mr-5 group-hover:bg-brand-sky/20 group-hover:border-transparent transition-all">
                                    <Icon name="lightening" class="h-12 w-12 text-brand-sky" />
                                </div>
                                <span class="text-neutral-700 font-medium text-lg lg:text-xl group-hover:text-brand-sky transition-all">Öka Energi &amp; Livskraft i Vardagen</span>
                            </div>
                        </li>
                        <li>
                            <div class="group flex items-center p-4 -mx-4 rounded-2xl hover:bg-white/50 transition-all">
                                <div class="h-16 w-16 shrink-0 rounded-full border border-brand-sky/30 flex items-center justify-center mr-5 group-hover:bg-brand-sky/20 group-hover:border-transparent transition-all">
                                    <Icon name="taichi_qigong_flow_min" class="h-18 w-18 text-brand-sky" />
                                </div>
                                <span class="text-neutral-700 font-medium text-lg lg:text-xl group-hover:text-brand-sky transition-all">Förbättra Balans, Rörlighet &amp; Kroppskontroll</span>
                            </div>
                        </li>
                    </ul>
                </div>

            </div>
        </div>
    </section>

    <!-- ======================================= -->
    <!-- Sektion 3: Godkända Metoder             -->
    <!-- ======================================= -->
    <section class="bg-brand-earth-lightest section-standard">
        <div class="container-base max-w-4xl">
            <div class="text-center mb-12">
                <h2 class="text-brand-earth">Våra Metoder &amp; Friskvårdsbidrag</h2>
                <p class="mt-4 text-neutral-700 text-lg">
                    Dessa metoder är godkända för friskvårdsbidrag och är ett utmärkt sätt att investera i ditt välmående.
                </p>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-8">
                <!-- Tai Chi -->
                <div class="bg-white rounded-2xl p-8 shadow-sm border border-brand-earth-lighter/30 flex flex-col items-center text-center">
                    <div class="flex items-center justify-center h-16 w-16 rounded-full bg-brand-earth/10 text-brand-earth mb-4">
                        <Icon name="taichi_yinyang_gongbu" class="h-11 w-11" />
                    </div>
                    <h3 class="text-xl font-bold text-brand-earth-dark mb-3">Tai Chi Chuan</h3>
                    <p class="text-neutral-600 mb-6 flex-grow">Flödande rörelser som bygger inre styrka och fysisk balans.</p>
                    <a href="/kurser/tai-chi/" class="text-brand-sky hover:text-brand-accent-dark font-medium underline decoration-brand-sky/30 underline-offset-4">Läs mer</a>
                </div>

                <!-- Qigong -->
                <div class="bg-white rounded-2xl p-8 shadow-sm border border-brand-earth-lighter/30 flex flex-col items-center text-center">
                    <div class="flex items-center justify-center h-16 w-16 rounded-full bg-brand-sky/10 text-brand-sky mb-4">
                        <Icon name="holistic_qi_human" class="h-12 w-12" />
                    </div>
                    <h3 class="text-xl font-bold text-brand-earth-dark mb-3">Medicinsk Qigong</h3>
                    <p class="text-neutral-600 mb-6 flex-grow">Mjuka och energigivande rörelser för stresshantering och hälsa.</p>
                    <a href="/kurser/medicinsk-qigong/" class="text-brand-sky hover:text-brand-accent-dark font-medium underline decoration-brand-sky/30 underline-offset-4">Läs mer</a>
                </div>

                <!-- Behandlingar -->
                <div class="bg-white rounded-2xl p-8 shadow-sm border border-brand-earth-lighter/30 flex flex-col items-center text-center">
                    <div class="flex items-center justify-center h-16 w-16 rounded-full bg-brand-accent/10 text-brand-accent-dark mb-4">
                        <Icon name="flower" class="h-11 w-11" />
                    </div>
                    <h3 class="text-xl font-bold text-brand-earth-dark mb-3">Behandling</h3>
                    <p class="text-neutral-600 mb-6 flex-grow">Akupunktur, TuiNa &amp; Oljemassage för dig som har specifika besvär eller behöver avkoppling.</p>
                    <a href="/behandling/" class="text-brand-sky hover:text-brand-accent-dark font-medium underline decoration-brand-sky/30 underline-offset-4">Läs mer</a>
                </div>
            </div>
        </div>
    </section>

    <!-- Sektion 3: Steg för steg -->
    <section class="bg-white section-standard">
        <div class="container-base max-w-4xl">
            <h2 class="text-brand-earth text-center mb-12">Så Använder Du Ditt Bidrag &ndash; 4 Enkla Steg</h2>

            <div class="relative">
                <!-- Vertical timeline line on desktop -->
                <div class="hidden md:block absolute left-8 top-8 bottom-8 w-0.5 bg-brand-earth-lighter/50"></div>

                <div class="space-y-8">
                    <!-- Steg 1 -->
                    <div class="relative flex flex-col md:flex-row items-start gap-4 md:gap-8 group">
                        <div class="flex-shrink-0 h-16 w-16 rounded-full bg-brand-earth text-white flex items-center justify-center font-bold text-xl shadow-lg relative z-10 group-hover:scale-110 transition-transform">
                            1
                        </div>
                        <div class="bg-neutral-50 rounded-2xl p-6 md:p-8 flex-grow border border-neutral-100 shadow-sm group-hover:shadow-md transition-shadow">
                            <h3 class="text-xl font-bold text-brand-earth-dark mb-3">Kolla med Din Arbetsgivare</h3>
                            <p class="text-neutral-700">Ta reda på ditt bidrags storlek och vilka specifika rutiner din arbetsgivare har. Många använder portaler som Epassi eller Benify - logga in där för information.</p>
                        </div>
                    </div>

                    <!-- Steg 2 -->
                    <div class="relative flex flex-col md:flex-row items-start gap-4 md:gap-8 group">
                        <div class="flex-shrink-0 h-16 w-16 rounded-full bg-brand-earth text-white flex items-center justify-center font-bold text-xl shadow-lg relative z-10 group-hover:scale-110 transition-transform">
                            2
                        </div>
                        <div class="bg-neutral-50 rounded-2xl p-6 md:p-8 flex-grow border border-neutral-100 shadow-sm group-hover:shadow-md transition-shadow">
                            <h3 class="text-xl font-bold text-brand-earth-dark mb-3">Boka hos Oss</h3>
                            <p class="text-neutral-700">Välj den kurs eller behandling du är intresserad av och <a href="/kontakt/?subject=friskvardsbidrag#tidsbokning" class="text-brand-sky hover:text-brand-accent-dark underline decoration-brand-sky/30 underline-offset-4 font-medium transition-colors">kontakta oss</a> för att boka din tid eller plats.</p>
                        </div>
                    </div>

                    <!-- Steg 3 -->
                    <div class="relative flex flex-col md:flex-row items-start gap-4 md:gap-8 group">
                        <div class="flex-shrink-0 h-16 w-16 rounded-full bg-brand-earth text-white flex items-center justify-center font-bold text-xl shadow-lg relative z-10 group-hover:scale-110 transition-transform">
                            3
                        </div>
                        <div class="bg-neutral-50 rounded-2xl p-6 md:p-8 flex-grow border border-neutral-100 shadow-sm group-hover:shadow-md transition-shadow">
                            <h3 class="text-xl font-bold text-brand-earth-dark mb-3">Betala &amp; Få Kvitto</h3>
                            <p class="text-neutral-700">Du betalar direkt till oss (t.ex. med Swish eller via faktura). Vi ser till att du får ett tydligt, specificerat kvitto som innehåller all information som Skatteverket och de flesta arbetsgivare kräver.</p>
                        </div>
                    </div>

                    <!-- Steg 4 -->
                    <div class="relative flex flex-col md:flex-row items-start gap-4 md:gap-8 group">
                        <div class="flex-shrink-0 h-16 w-16 rounded-full bg-brand-earth text-white flex items-center justify-center font-bold text-xl shadow-lg relative z-10 group-hover:scale-110 transition-transform">
                            4
                        </div>
                        <div class="bg-neutral-50 rounded-2xl p-6 md:p-8 flex-grow border border-neutral-100 shadow-sm group-hover:shadow-md transition-shadow">
                            <h3 class="text-xl font-bold text-brand-earth-dark mb-3">Få Ersättning</h3>
                            <p class="text-neutral-700">Lämna in kvittot till din arbetsgivare eller ladda upp det i din friskvårdsportal för att få tillbaka pengarna.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Sektion 4: FAQ -->
    <section class="section-standard bg-brand-earth-lightest">
        <div class="container-base max-w-3xl">
            <h2 class="text-brand-earth text-center mb-12">Vanliga Frågor om Friskvårdsbidrag</h2>

            <div class="space-y-4" x-data="{ active: null }">
                
                <!-- Fråga 1 -->
                <div class="border border-neutral-200 rounded-lg overflow-hidden">
                    <button @click="active === 1 ? active = null : active = 1"
                        class="w-full flex justify-between items-center p-5 bg-white hover:bg-neutral-50 transition-colors focus:outline-none focus:bg-brand-accent/30">
                        <span class="font-bold text-brand-earth-dark text-left text-lg">Är ni anslutna till Epassi, Benify eller Wellnet?</span>
                        <span class="ml-4 text-brand-sky transform transition-transform"
                            :class="active === 1 ? 'rotate-180' : ''">
                            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                            </svg>
                        </span>
                    </button>
                    <div x-show="active === 1" x-collapse x-cloak
                        class="p-5 bg-neutral-50 text-neutral-700 leading-relaxed border-t border-neutral-100">
                        För närvarande är vi inte direktanslutna till någon portal. Processen är därför att du betalar direkt till oss och sedan använder det detaljerade kvittot du får för att själv registrera ditt utlägg i din portal och få ersättning.
                    </div>
                </div>

                <!-- Fråga 2 -->
                <div class="border border-neutral-200 rounded-lg overflow-hidden">
                    <button @click="active === 2 ? active = null : active = 2"
                        class="w-full flex justify-between items-center p-5 bg-white hover:bg-neutral-50 transition-colors focus:outline-none focus:bg-brand-accent/30">
                        <span class="font-bold text-brand-earth-dark text-left text-lg">Viktigt att tänka på gällande Skatteverket &amp; Kvitton</span>
                        <span class="ml-4 text-brand-sky transform transition-transform"
                            :class="active === 2 ? 'rotate-180' : ''">
                            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                            </svg>
                        </span>
                    </button>
                    <div x-show="active === 2" x-collapse x-cloak
                        class="p-5 bg-neutral-50 text-neutral-700 leading-relaxed border-t border-neutral-100">
                        <ul class="space-y-4">
                            <li><strong>Ditt Ansvar:</strong> Det är alltid ditt eget ansvar att säkerställa att din valda aktivitet godkänns av just din arbetsgivare.</li>
                            <li><strong>Spara Kvittot:</strong> Se till att du sparar det specifika kvitto vi ger dig! Vanliga kortkvitton eller handskrivna lappar räcker oftast inte som bevis hos Skatteverket eller portalerna. Vårt kvitto innehåller all rätt information.</li>
                            <li><strong>Skatteverkets Regler:</strong> För den allra senaste officiella informationen kring friskvård, besök gärna <a href="https://www.skatteverket.se/privat/skatter/arbeteochinkomst/formaner/personalvardmotionochfriskvard.4.7459477810df5bccdd4800014540.html" target="_blank" rel="noopener noreferrer" class="text-brand-sky hover:underline">Skatteverkets webbplats</a>.</li>
                        </ul>
                    </div>
                </div>

            </div>
        </div>
    </section>

    <!-- Sektion 5: Avslutande CTA -->
    <section class="section-standard bg-brand-earth-light text-center">
        <div class="container-base max-w-4xl">
            <div class="max-w-3xl mx-auto mb-8">
                <h2 class="text-brand-earth-dark mb-6 text-3xl md:text-5xl">Gör Något Bra för Dig Själv Idag!</h2>
                <p class="text-brand-earth-dark text-lg md:text-xl leading-relaxed mb-10">
                    Välkommen att investera i dig själv med ditt friskvårdsbidrag - en hälsosammare och stressfriare vardag väntar!
                </p>

                <a href="/kontakt/?subject=friskvardsbidrag#tidsbokning" class="btn btn-primary-on-dark shadow-lg shadow-black/10 px-10 py-5 text-xl mb-4 inline-block">
                    Har du fler frågor? Kontakta oss gärna!
                </a>
            </div>
            
            <!-- Praktisk Info Row -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8 pt-10 mt-6 border-t border-brand-earth-dark/10">
                <!-- Platser -->
                <div class="group bg-brand-earth-dark/5 rounded-2xl p-6 shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-300 border-2 border-brand-earth-dark/10 flex flex-col items-start text-left">
                    <div class="flex items-center mb-4">
                        <div class="flex items-center justify-center h-10 w-10 rounded-full bg-brand-earth-dark/25 mr-3">
                            <div class="relative flex h-3 w-3 items-center justify-center">
                                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-accent opacity-75"></span>
                                <span class="relative inline-flex rounded-full h-2 w-2 bg-brand-accent"></span>
                            </div>
                        </div>
                        <span class="font-bold text-brand-earth-dark text-xl">Våra Platser</span>
                    </div>
                    <div class="text-neutral-700 leading-relaxed text-sm md:text-base flex-grow">
                        Välkommen till våra mottagningar i 
                        <a href="/kontakt/#mottagningar" class="text-brand-sky hover:text-brand-sky-dark font-medium underline decoration-brand-sky/20 underline-offset-4 transition-all">Nyköping</a>, 
                        <a href="/kontakt/#mottagningar" class="text-brand-sky hover:text-brand-sky-dark font-medium underline decoration-brand-sky/20 underline-offset-4 transition-all">Gnesta</a> och 
                        <a href="/kontakt/#mottagningar" class="text-brand-sky hover:text-brand-sky-dark font-medium underline decoration-brand-sky/20 underline-offset-4 transition-all">Oxelösund</a>.
                    </div>
                    <a href="/kontakt/#mottagningar" class="text-brand-sky hover:text-brand-sky-dark font-medium flex items-center mt-4 group-hover:translate-x-1 transition-transform">Se alla mottagningar &rarr;</a>
                </div>

                <!-- Presentkort -->
