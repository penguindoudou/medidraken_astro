---
import { Image } from 'astro:assets';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Icon from '../../../components/Icon.astro';

// Images
import taichi_hero6Image from '../../../assets/images/taichi_hero6.png';
---

<BaseLayout title="Helgkurser i Tai Chi">
<!-- ======================================= -->
<!-- Sektion 1: Hero                         -->
<!-- ======================================= -->
<section class="hero-section">
    <div class="hero-background">
        <!-- Bild: Tai Chi natur/fokus -->
        <Image src={taichi_hero6Image}
            alt="Helgkurs i Tai Chi - Djupgående intensivkurs" class="hero-bg-image" />
    </div>

    <div class="hero-content">
        <h1 class="hero-title text-brand-accent text-balance">Helgkurs i Tai Chi</h1>
        <h2 class="hero-subtitle font-bold">Intensiv fördjupning för Balans & Välbefinnande</h2>

        <p class="hero-text">
            Våra helgkurser är det snabbaste sättet att få en solid grund i Tai Chi. Under två intensiva och givande
            dagar får du möjlighet att fördjupa dig i rörelserna, bygga starkt muskelminne och lämna helgen med en
            komplett form – en verktygslåda du kan använda för ta hand om din hälsa på egen hand livet ut.
        </p>

        <div class="mt-10">
            <a href="#kursstarter" class="btn btn-primary-on-dark">
                Se kommande helgkurser & anmäl intresse
            </a>
        </div>
    </div>
</section>

<!-- ======================================= -->
<!-- Sektion 2: Fördelarna med en Intensiv Helgkurs -->
<!-- ======================================= -->
<section class="section-standard bg-white">
    <div class="container-base">
        <div class="text-center mb-12 max-w-3xl mx-auto">
            <h2 class="text-brand-earth">Varför välja en Helgkurs?</h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

            <!-- Feature Box 1: Hel Hälsorutin -->
            <div class="content-box flex flex-col items-center text-center">
                <div class="flex items-center justify-center h-16 w-16 rounded-full bg-brand-accent/20 mb-4">
                    <Icon name="holistic_qi_human" class="h-12 w-12 text-brand-accent-dark" />
                </div>

                <h3 class="text-xl font-bold text-neutral-900 mb-3">Hel Hälsorutin på en helg</h3>
                <p class="text-neutral-700">
                    Istället för att lära dig en rörelse i taget under en hel termin får du en komplett kurs på bara två
                    dagar. För dig som är ny är detta det snabbaste sättet att lära sig en komplett Tai Chi form.
                </p>
            </div>

            <!-- Feature Box 2: Oavbruten Fördjupning -->
            <div class="content-box flex flex-col items-center text-center">
                <div class="flex items-center justify-center h-16 w-16 rounded-full bg-brand-accent/20 mb-4">
                    <!-- Ikon: Fokus/Djupdykning (Magnifying Glass with Plus) -->
                    <svg class="h-10 w-10 text-brand-accent-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                            d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7"></path>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 7v6m-3-3h6">
                        </path>
                    </svg>
                </div>
                <h3 class="text-xl font-bold text-neutral-900 mb-3">Oavbruten Fördjupning</h3>
                <p class="text-neutral-700">
                    När vi tränar flera timmar i sträck balanseras nervsystemet på djupet. Du lämnar vardagens
                    distraktioner bakom dig och landar i en djup närvaro och mental återhämtning som är svår att
                    uppnå under korta kvällspass.
                </p>
            </div>

            <!-- Feature Box 3: Enkelt att planera -->
            <div class="content-box flex flex-col items-center text-center">
                <div class="flex items-center justify-center h-16 w-16 rounded-full bg-brand-accent/20 mb-4">
                    <!-- Ikon: Flexibilitet/Vägskäl -->
                    <svg class="h-10 w-10 text-brand-accent-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                            d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z">
                        </path>
                    </svg>
                </div>

                <h3 class="text-xl font-bold text-neutral-900 mb-3">Enkelt att planera</h3>
                <p class="text-neutral-700">
                    Perfekt för dig med en välfylld kalender, oförutsägbar vardag eller för dig som bor en bit bort. En
                    helgkurs kräver bara en helg för att etablera ett verktyg som kan förbättra din hälsa livet ut.
                </p>
            </div>

        </div>
    </div>
</section>

<!-- ======================================= -->
<!-- Sektion 3: Kursupplägg & Innehåll       -->
<!-- ======================================= -->
<section class="section-standard bg-brand-earth-lightest">
    <div class="container-base">
        <div class="max-w-4xl mx-auto">
            <h2 class="text-brand-earth text-center mb-10">Hur en Helgkurs Går Till</h2>

            <div class="bg-white rounded-xl p-8 md:p-10 shadow-sm border border-neutral-200">

                <!-- Section 1: Upplägget: I praktiken -->
                <div class="mb-12">
                    <h3 class="font-bold text-brand-earth-dark text-2xl md:text-3xl mb-8 text-center tracking-wide">
                        Upplägget: I praktiken</h3>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

                        <!-- Stage 1: Rakt på sak -->
                        <div
                            class="bg-gradient-to-br from-brand-earth/5 to-brand-accent/5 rounded-xl p-6 border-2 border-brand-earth/20 shadow-sm">
                            <div class="flex flex-col items-center text-center h-full">
                                <div
                                    class="flex items-center justify-center h-16 w-16 rounded-full bg-brand-accent text-white mb-4 shadow-md">
                                    <Icon name="taichi_yinyang_mabu" class="h-10 w-10" />
                                </div>
                                <h4 class="font-bold text-brand-earth-dark text-lg mb-3">Rakt på sak</h4>
                                <p class="text-neutral-700 text-sm leading-relaxed">
                                    Efter förberedande övningar för att mjuka upp kroppen går vi direkt på formens
                                    rörelser inom första timmen.
                                </p>
                            </div>
                        </div>

                        <!-- Stage 2: Helheten & Flödet -->
                        <div
                            class="bg-gradient-to-br from-brand-earth/5 to-brand-accent/5 rounded-xl p-6 border-2 border-brand-earth/20 shadow-sm">
                            <div class="flex flex-col items-center text-center h-full">
                                <div
                                    class="flex items-center justify-center h-16 w-16 rounded-full bg-brand-accent text-white mb-4 shadow-md">
                                    <Icon name="taichi_yinyang_gongbu" class="h-10 w-10" />
                                </div>
                                <h4 class="font-bold text-brand-earth-dark text-lg mb-3">Helheten & Flödet</h4>
                                <p class="text-neutral-700 text-sm leading-relaxed">
                                    Vi knyter ihop rörelserna till en komplett form och fokuserar på att förfina
                                    detaljerna.
                                </p>
                            </div>
                        </div>

                        <!-- Stage 3: Integration & Pauser -->
                        <div
                            class="bg-gradient-to-br from-brand-earth/5 to-brand-accent/5 rounded-xl p-6 border-2 border-brand-earth/20 shadow-sm">
                            <div class="flex flex-col items-center text-center h-full">
                                <div
                                    class="flex items-center justify-center h-16 w-16 rounded-full bg-brand-accent text-white mb-4 shadow-md">
                                    <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <!-- Bell Icon -->
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                            d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9">
                                        </path>
                                    </svg>
                                </div>
                                <h4 class="font-bold text-brand-earth-dark text-lg mb-3">Integration & Pauser</h4>
                                <p class="text-neutral-700 text-sm leading-relaxed">
                                    Vi varvar träning med regelbundna pauser så att både kropp och sinne hinner
                                    absorbera rörelserna.
                                </p>
                            </div>
                        </div>

                    </div>
                </div>

                <!-- Section 2: Vår Pedagogik: Från rörelse till muskelminne -->
                <div class="mb-10">
                    <h3 class="font-bold text-brand-earth-dark text-2xl md:text-3xl mb-8 text-center tracking-wide">
                        Vår Pedagogik: Från rörelse till muskelminne</h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

                        <!-- Pedagogik 1: Kroppsminne -->
                        <div
                            class="bg-gradient-to-br from-brand-accent/5 to-brand-earth/5 rounded-xl p-8 border-2 border-brand-accent/20 shadow-sm">
                            <div class="flex flex-col items-center text-center h-full">
                                <div
                                    class="flex items-center justify-center h-20 w-20 rounded-full bg-brand-accent/20 mb-6">
                                    <Icon name="brain_muscle3" class="h-12 w-12 text-brand-accent-dark" />
                                </div>
                                <h4 class="font-bold text-brand-earth-dark text-xl mb-4">Kroppsminne</h4>
                                <p class="text-neutral-700 text-base leading-relaxed">
                                    Vi bryter ner komplexa rörelser till enkla, greppbara steg. Genom täta repetitioner
                                    "kodar" vi in tekniken i kroppen så att den sitter kvar efter helgen.
                                </p>
                            </div>
                        </div>

                        <!-- Pedagogik 2: Långsiktig Hälsa -->
                        <div
                            class="bg-gradient-to-br from-brand-accent/5 to-brand-earth/5 rounded-xl p-8 border-2 border-brand-accent/20 shadow-sm">
                            <div class="flex flex-col items-center text-center h-full">
                                <div
                                    class="flex items-center justify-center h-20 w-20 rounded-full bg-brand-accent/20 mb-6">
                                    <svg class="h-12 w-12 text-brand-accent-dark" fill="none" stroke="currentColor"
                                        viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                            d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                    </svg>
                                </div>
                                <h4 class="font-bold text-brand-earth-dark text-xl mb-4">Långsiktig Hälsa</h4>
                                <p class="text-neutral-700 text-base leading-relaxed">
                                    Vi lär inte bara ut rörelser; vi ger dig en metod för att förbättra din hälsa på
                                    sikt. Du lämnar helgen med en komplett sekvens, redo att användas när och var du
                                    vill.
                                </p>
                            </div>
                        </div>

                    </div>
                </div>

                <!-- Practical Info & Alternative -->
                <div class="space-y-6 pt-6 border-t border-neutral-200">
                    <div class="bg-brand-sky/5 rounded-xl p-6 border border-brand-sky/20 flex items-start gap-4">
                        <div class="text-brand-sky mt-1 shrink-0">
                            <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                            </svg>
                        </div>
                        <div>
                            <h4 class="font-bold text-neutral-900 mb-1">Praktisk info om lunch</h4>
                            <p class="text-neutral-700 text-sm md:text-base">Lunch ingår ej, men vi brukar uppmuntra
                                till ett gemensamt knytkalas för de som önskar!</p>
                        </div>
                    </div>

                    <div class="text-center">
                        <p class="text-neutral-700 italic">
                            Föredrar du ett lugnare tempo och regelbunden träning i vardagen?
                            <br class="hidden md:block">
                            Utforska våra populära <a href="/veckokurser-tai-chi/"
                                class="text-brand-sky font-semibold underline hover:text-brand-accent transition-colors">veckokurser</a>
                            som löper över terminen.
                        </p>
                    </div>
                </div>

            </div>
        </div>
    </div>
</section>



<!-- ======================================= -->
<!-- Sektion 5: Aktuella Kursstarter (Logic) -->
<!-- ======================================= -->
<section class="section-standard bg-white" id="kursstarter">
    <div class="container-base">
        <h2 class="text-brand-earth text-center mb-10">Kommande Helgkurser i Tai Chi</h2>

        
        {/* {%if courses_tai_chi_weekend is defined and courses_tai_chi_weekend is not empty%} */}

        <!-- Active Courses Table -->
        <div class="overflow-x-auto shadow-md rounded-lg max-w-5xl mx-auto border border-neutral-200">
            <table class="min-w-full leading-normal">
                <thead>
                    <tr>
                        <th
                            class="px-5 py-3 border-b-2 border-brand-earth bg-brand-earth-lightest text-left text-xs font-semibold text-brand-earth uppercase tracking-wider">
                            Kursnamn / Nivå</th>
                        <th
                            class="px-5 py-3 border-b-2 border-brand-earth bg-brand-earth-lightest text-left text-xs font-semibold text-brand-earth uppercase tracking-wider">
                            Ort</th>
                        <th
                            class="px-5 py-3 border-b-2 border-brand-earth bg-brand-earth-lightest text-left text-xs font-semibold text-brand-earth uppercase tracking-wider">
                            Datum</th>
                        <th
                            class="px-5 py-3 border-b-2 border-brand-earth bg-brand-earth-lightest text-left text-xs font-semibold text-brand-earth uppercase tracking-wider">
                            Tider</th>
                        <th class="px-5 py-3 border-b-2 border-brand-earth bg-brand-earth-lightest"></th>
                    </tr>
                </thead>
                <tbody>
                    {/* {%for course in courses_tai_chi_weekend%} */}
                    <tr>
                        <td class="px-5 py-5 border-b border-gray-200 bg-white text-sm">
                            <p class="text-gray-900 whitespace-no-wrap font-semibold">[course.title]</p>
                        </td>
                        <td class="px-5 py-5 border-b border-gray-200 bg-white text-sm">
                            <p class="text-gray-900 whitespace-no-wrap">[course.location]</p>
                        </td>
                        <td class="px-5 py-5 border-b border-gray-200 bg-white text-sm">
                            <p class="text-gray-900 whitespace-no-wrap">[course.date]</p>
                        </td>
                        <td class="px-5 py-5 border-b border-gray-200 bg-white text-sm">
                            <p class="text-gray-900 whitespace-no-wrap">[course.times]</p>
                        </td>
                        <td class="px-5 py-5 border-b border-gray-200 bg-white text-sm text-right">
                            <a href="[course.link]" class="text-brand-sky hover:text-brand-earth font-medium">Boka
                                &rarr;</a>
                        </td>
                    </tr>
                    {/* {%endfor%} */}
                </tbody>
            </table>
        </div>

        {/* {%else%} */}

        <!-- Fallback Block -->
        <div class="max-w-4xl mx-auto border-2 border-dashed border-neutral-300 rounded-xl p-8 md:p-12 bg-neutral-50">
            <h3 class="font-heading text-2xl text-brand-earth mb-4 text-center">Så här kommer du igång!</h3>
            <p class="text-neutral-700 mb-10 text-center max-w-2xl mx-auto">
                Just nu har vi inga schemalagda helgkurser, men det finns flera sätt att få en djupgående start i Tai
                Chi.
            </p>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-4 min-[890px]:gap-8">

                <!-- Väg 1: Intresseanmälan -->
                <div
                    class="bg-gradient-to-br from-brand-sky/5 to-brand-accent/5 p-8 md:p-4 min-[890px]:p-8 rounded-lg shadow-sm border-2 border-brand-sky/20 hover:-translate-y-1 transition-transform duration-300">
                    <div
                        class="flex items-center justify-center h-12 w-12 rounded-full bg-brand-sky text-white mb-4 shadow-md">
                        <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M8 7V3m8 4V3M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z">
                            </path>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                d="M12 10.5l.9 1.8 2 .3-1.45 1.4.35 2-1.8-.95-1.8.95.35-2-1.45-1.4 2-.3.9-1.8z"
                                fill="currentColor"></path>
                        </svg>
                    </div>
                    <h4
                        class="font-bold text-brand-earth-dark text-xl md:text-base min-[890px]:text-xl mb-3 hyphens-auto">
                        Intresseanmälan för nästa kurs</h4>
                    <p class="text-neutral-700 mb-6">
                        Var först med att få info om nästa planerade helgkurs. Genom att anmäla intresse hjälper du oss
                        planera.
                    </p>
                    <a href="#anmalan" class="btn-tertiary font-semibold">Anmäl intresse &rarr;</a>
                </div>

                <!-- Väg 2: Privatundervisning -->
                <div
                    class="bg-gradient-to-br from-brand-sky/5 to-brand-accent/5 p-8 md:p-4 min-[890px]:p-8 rounded-lg shadow-sm border-2 border-brand-sky/20 hover:-translate-y-1 transition-transform duration-300">
                    <div
                        class="flex items-center justify-center h-12 w-12 rounded-full bg-brand-sky text-white mb-4 shadow-md">
                        <!-- Magnifying Glass on Person Icon -->
                        <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                d="M21 21l-4.8-4.8m1.3-5.7a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                            <circle cx="10.5" cy="8" r="1.8" stroke="currentColor" stroke-width="1.5" fill="none">
                            </circle>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                d="M7 13c0-1.933 1.567-3.5 3.5-3.5s3.5 1.567 3.5 3.5"></path>
                        </svg>
                    </div>
                    <h4
                        class="font-bold text-brand-earth-dark text-xl md:text-base min-[890px]:text-xl mb-3 hyphens-auto">
                        Privatundervisning</h4>
                    <p class="text-neutral-700 mb-6">
                        Få 100% odelad uppmärksamhet och undervisning anpassad för dig.
                    </p>
                    <a href="/privatundervisning-tai-chi/" class="btn-tertiary font-semibold">Läs mer &rarr;</a>
                </div>

                <!-- Väg 3: Egen Grupp -->
                <div
                    class="bg-gradient-to-br from-brand-sky/5 to-brand-accent/5 p-8 md:p-4 min-[890px]:p-8 rounded-lg shadow-sm border-2 border-brand-sky/20 hover:-translate-y-1 transition-transform duration-300">
                    <div
                        class="flex items-center justify-center h-12 w-12 rounded-full bg-brand-sky text-white mb-4 shadow-md">
                        <!-- Group of People Icon -->
                        <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z">
                            </path>
                        </svg>
                    </div>
                    <h4
                        class="font-bold text-brand-earth-dark text-xl md:text-base min-[890px]:text-xl mb-3 hyphens-auto">
                        Egen Grupp</h4>
                    <p class="text-neutral-700 mb-6">
                        Perfekt för arbetsplatsen eller kompisgänget. Vi skapar ett upplägg som passar er kalender och
                        Era önskemål.
                    </p>
                    <a href="/upplevelser/workshops-gruppaktiviteter/" class="btn-tertiary font-semibold">Läs mer
                        &rarr;</a>
                </div>

            </div>
        </div>

        {/* {%endif%} */}
    </div>
</section>

<!-- ======================================= -->
<!-- Sektion 6: Anmälan, Pris & Info (CTA)   -->
<!-- ======================================= -->
<section class="section-standard bg-brand-earth-light text-neutral-100 text-center" id="anmalan">
    <div class="container-base max-w-3xl">
        <h2 class="text-brand-earth-dark mb-6">Redo för en djupdykning i Tai Chi?</h2>
        <p class="text-lg text-brand-earth mb-10 leading-relaxed">
            Nya helgkurser planeras löpande. Det enklaste sättet att få all information du behöver är att anmäla ditt
            intresse. Då kontaktar vi dig personligen med information om kommande starter, upplägg och priser.
            <br /><span class="text-brand-earth-dark font-semibold">Din anmälan är helt kostnadsfri och inte
                bindande.</span>
        </p>

        <a href="/kontakt/?subject=Kursintresse%3A%20Helgkurs%20Tai%20Chi"
            class="btn btn-primary-on-dark text-xl px-10 py-5 shadow-lg shadow-black/20 mb-8">
            Anmäl intresse & få mer information
        </a>

        <p class="text-brand-earth-dark mb-12 italic">
            {/* {%set tel = get_contact_detail('tel')%} */}
            Har du frågor om upplägget? Ring oss gärna på <a href="tel:[tel|clean_tel]"
                class="text-brand-sky underline hover:text-brand-sky-bright">[tel]</a>.
        </p>

        <!-- Praktisk Info List -->
        <div
            class="flex flex-col md:flex-row justify-center gap-6 md:gap-12 text-sm md:text-base border-t border-brand-earth-dark/10 pt-8 text-brand-earth-dark">
            <div class="flex flex-col items-start text-left">
                <div class="flex items-center">
                    <svg class="h-10 w-10 text-brand-earth-dark mr-2" fill="none" stroke="currentColor"
                        viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z">
                        </path>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                    </svg>
                    <span class="font-bold text-brand-earth-dark text-xl">Platser</span>
                </div>
                <div class="mt-1">
                    <span>Våra kurser hålls i <a href="/kontakt/#mottagningar"
                            class="text-brand-sky hover:text-brand-sky-bright font-medium">Nyköping</a>, <a
                            href="/kontakt/#mottagningar"
                            class="text-brand-sky hover:text-brand-sky-bright font-medium">Gnesta</a> och <a
                            href="/kontakt/#mottagningar"
                            class="text-brand-sky hover:text-brand-sky-bright font-medium">Oxelösund</a>.</span>
                </div>
            </div>
            <div class="flex flex-col items-start text-left">
                <div class="flex items-center">
