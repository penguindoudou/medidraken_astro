---
import { Image } from 'astro:assets';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Icon from '../../../components/Icon.astro';

// Images
import taichi_hero6Image from '../../../assets/images/taichi_hero6.png';
---

<BaseLayout title="Privatundervisning i Tai Chi">
<!-- ======================================= -->
<!-- Sektion 1: Hero                         -->
<!-- ======================================= -->
<section class="hero-section">
    <div class="hero-background">
        <!-- Bild: Tai Chi personlig guidning -->
        <Image src={taichi_hero6Image}
            alt="Privatundervisning i Tai Chi - Personlig guidning" class="hero-bg-image" />
    </div>

    <div class="hero-content">
        <h1 class="hero-title text-brand-accent text-balance">Privatundervisning i Tai Chi</h1>
        <h2 class="hero-subtitle font-bold">Skräddarsydd träning för dina personliga mål</h2>

        <p class="hero-text">
            Få 100% odelad uppmärksamhet från en erfaren instruktör och träning helt anpassat för
            dig. Privatundervisning ger dig ett levande träningsupplägg som anpassas efter din dagsform och långsiktiga
            mål.
            Det är det mest effektiva sättet att lära sig Tai Chi.
        </p>

        <div class="mt-10">
            <a href="#boka" class="btn btn-primary-on-dark shadow-lg">
                Diskutera ett personligt upplägg
            </a>
        </div>
    </div>
</section>

<!-- ======================================= -->
<!-- Sektion 2: Fördelarna med Privatundervisning -->
<!-- ======================================= -->
<section class="section-standard bg-white">
    <div class="container-base">
        <div class="text-center mb-12 max-w-3xl mx-auto">
            <h2 class="text-brand-earth">Varför välja Privatundervisning?</h2>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

            <!-- Feature Box 1: Maximal Progression -->
            <div class="content-box flex flex-col items-center text-center">
                <div class="flex items-center justify-center h-16 w-16 rounded-full bg-brand-accent/20 mb-4">
                    <!-- Ikon: Precision/Target -->
                    <svg class="h-10 w-10 text-brand-accent-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                            d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"></path>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                            d="M12 18a6 6 0 100-12 6 6 0 000 12z"></path>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                            d="M12 2v2m0 16v2m10-10h-2M4 12H2"></path>
                    </svg>
                </div>

                <h3 class="text-xl font-bold text-neutral-900 mb-3">Individuell precision</h3>
                <p class="text-neutral-700">
                    Med direkt och kontinuerlig feedback på det som spelar roll där du är blir din inlärning trygg och
                    effektiv.
                </p>
            </div>

            <!-- Feature Box 2: 100% Skräddarsytt -->
            <div class="content-box flex flex-col items-center text-center">
                <div class="flex items-center justify-center h-16 w-16 rounded-full bg-brand-accent/20 mb-4">
                    <!-- Ikon: Tempo/Gauge -->
                    <svg class="h-10 w-10 text-brand-accent-dark" fill="currentColor" viewBox="0 0 16 16">
                        <path
                            d="M8 4a.5.5 0 0 1 .5.5V6a.5.5 0 0 1-1 0V4.5A.5.5 0 0 1 8 4zM3.732 5.732a.5.5 0 0 1 .707 0l.915.914a.5.5 0 1 1-.708.708l-.914-.915a.5.5 0 0 1 0-.707zM2 10a.5.5 0 0 1 .5-.5h1.586a.5.5 0 0 1 0 1H2.5A.5.5 0 0 1 2 10zm9.5 0a.5.5 0 0 1 .5-.5h1.5a.5.5 0 0 1 0 1H12a.5.5 0 0 1-.5-.5zm.754-4.246a.389.389 0 0 0-.527-.02L7.547 9.31a.91.91 0 1 0 1.302 1.258l3.434-4.297a.389.389 0 0 0-.029-.518z" />
                        <path fill-rule="evenodd"
                            d="M0 10a8 8 0 1 1 15.547 2.661c-.442 1.253-1.845 1.602-2.932 1.25C11.309 13.488 9.475 13 8 13c-1.474 0-3.31.488-4.615.911-1.087.352-2.49.003-2.932-1.25A7.988 7.988 0 0 1 0 10zm8-7a7 7 0 0 0-6.603 9.329c.203.575.923.876 1.68.63C4.397 12.533 6.358 12 8 12s3.604.532 4.923.96c.757.245 1.477-.056 1.68-.631A7 7 0 0 0 8 3z" />
                    </svg>
                </div>

                <h3 class="text-xl font-bold text-neutral-900 mb-3">Anpassat tempo</h3>
                <p class="text-neutral-700">
                    Vi arbetar i din takt, svarar på dina specifika frågor och stannar vid det som känns svårt tills det
                    känns enkelt.
                </p>
            </div>

            <!-- Feature Box 3: Total Flexibilitet -->
            <div class="content-box flex flex-col items-center text-center">
                <div class="flex items-center justify-center h-16 w-16 rounded-full bg-brand-accent/20 mb-4">
                    <!-- Ikon: Kalender/Klocka -->
                    <svg class="h-10 w-10 text-brand-accent-dark" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                            d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z">
                        </path>
                    </svg>
                </div>

                <h3 class="text-xl font-bold text-neutral-900 mb-3">Flexibelt schema</h3>
                <p class="text-neutral-700">
                    Du är inte bunden till fasta terminstider. Vi hittar tillsammans tider som passar din kalender.
                </p>
            </div>

        </div>
    </div>
</section>

<!-- ======================================= -->
<!-- Sektion 3: En pedagogik som lyssnar      -->
<!-- ======================================= -->
<section class="section-standard bg-brand-earth-lightest">
    <div class="container-base">
        <div class="max-w-4xl mx-auto">
            <h2 class="text-brand-earth text-center mb-10">En pedagogik som lyssnar</h2>

            <div class="bg-white rounded-xl p-8 md:p-10 shadow-sm border border-neutral-200">

                <!-- 3-Block Narrative Grid -->
                <div class="space-y-8">

                    <!-- Block 1: Kalibrering efter dagsform (Accent) -->
                    <div
                        class="flex flex-col md:flex-row items-center md:items-start gap-6 p-6 rounded-xl bg-gradient-to-br from-brand-accent/5 to-brand-sky/5 border border-brand-accent/10">
                        <div
                            class="flex-shrink-0 flex items-center justify-center h-14 w-14 rounded-full bg-brand-accent text-white shadow-md">
                            <!-- Ikon: Tempo/Gauge (Anpassat) -->
                            <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                    d="M10.5 6h9.75M10.5 6a1.5 1.5 0 1 1-3 0m3 0a1.5 1.5 0 1 0-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m-9.75 0h9.75" />
                            </svg>
                        </div>
                        <div class="text-center md:text-left">
                            <h3 class="font-bold text-brand-earth-dark text-lg mb-2">Kalibrering efter dagsform</h3>
                            <p class="text-neutral-700 leading-relaxed">
                                Är du trött, stel eller full av energi? Vi justerar passet efter hur du mår och doserar
                                mängden ny information efter hur mycket du kan ta in.
                            </p>
                        </div>
                    </div>

                    <!-- Block 2: Hälsa på dina villkor (Accent) -->
                    <div
                        class="flex flex-col md:flex-row items-center md:items-start gap-6 p-6 rounded-xl bg-gradient-to-br from-brand-accent/5 to-brand-sky/5 border border-brand-accent/10">
                        <div
                            class="flex-shrink-0 flex items-center justify-center h-14 w-14 rounded-full bg-brand-accent text-white shadow-md">
                            <Icon name="shield_health" class="h-8 w-8" />
                        </div>
                        <div class="text-center md:text-left">
                            <h3 class="font-bold text-brand-earth-dark text-lg mb-2">Hälsa på dina villkor</h3>
                            <p class="text-neutral-700 leading-relaxed">
                                Har du specifika fysiska utmaningar, smärta eller skador? Vi anpassar övningarna så att
                                de stärker din kropp på rätt sätt.
                            </p>
                        </div>
                    </div>

                    <!-- Block 3: Långsiktig röd tråd (Accent) -->
                    <div
                        class="flex flex-col md:flex-row items-center md:items-start gap-6 p-6 rounded-xl bg-gradient-to-br from-brand-accent/5 to-brand-sky/5 border border-brand-accent/10">
                        <div
                            class="flex-shrink-0 flex items-center justify-center h-14 w-14 rounded-full bg-brand-accent text-white shadow-md">
                            <!-- Ikon: Rutt/Väg (Route) -->
                            <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                    d="M13.19 8.688a4.5 4.5 0 0 1 1.242 7.244l-4.5 4.5a4.5 4.5 0 0 1-6.364-6.364l1.757-1.757m13.35-.622 1.757-1.757a4.5 4.5 0 0 0-6.364-6.364l-4.5 4.5a4.5 4.5 0 0 0 1.242 7.244" />
                            </svg>
                        </div>
                        <div class="text-center md:text-left">
                            <h3 class="font-bold text-brand-earth-dark text-lg mb-2">Långsiktig röd tråd</h3>
                            <p class="text-neutral-700 leading-relaxed">
                                Även om vi anpassar oss i stunden, väver vi dem samman med dina långsiktiga mål. Varje
                                lektion är en naturlig pusselbit på din Tai Chi-resa.
                            </p>
                        </div>
                    </div>

                    <!-- Footer Link -->
                    <div class="text-center pt-8 mt-8 border-t border-neutral-200">
                        <p class="text-neutral-700 italic">
                            Vill du hellre träna i gemenskap med andra?
                            <br class="hidden md:block">
                            Utforska våra <a href="/veckokurser-tai-chi/"
                                class="text-brand-sky font-semibold underline hover:text-brand-accent transition-colors">veckokurser</a>
                            eller <a href="/helgkurser-tai-chi/"
                                class="text-brand-sky font-semibold underline hover:text-brand-accent transition-colors">helgkurser</a>.
                        </p>
                    </div>

                </div>
            </div>
        </div>
</section>

<!-- ======================================= -->
<!-- Sektion 4: Kom igång i 3 Steg           -->
<!-- ======================================= -->
<section class="section-standard bg-white">
    <div class="container-base">
        <h2 class="text-brand-earth text-center mb-12">Vägen till ditt först pass</h2>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

            <!-- Steg 1: Kontakta Oss -->
            <div
                class="bg-gradient-to-br from-brand-sky/5 to-brand-accent/5 p-8 rounded-xl shadow-sm border-2 border-brand-sky/20 flex flex-col items-center text-center">
                <div
                    class="flex items-center justify-center h-12 w-12 rounded-full bg-brand-sky text-white mb-6 shadow-md font-bold text-xl">
                    1
                </div>
                <h3 class="font-bold text-brand-earth-dark text-xl mb-4">Förutsättningslös kontakt</h3>
                <p class="text-neutral-700">
                    Ta första steget genom att använda formuläret nedan eller ring oss direkt. Berätta kort om dina
                    önskemål
                    och vad du vill uppnå med din träning.
                </p>
            </div>

            <!-- Steg 2: Personlig Konsultation -->
            <div
                class="bg-gradient-to-br from-brand-sky/5 to-brand-accent/5 p-8 rounded-xl shadow-sm border-2 border-brand-sky/20 flex flex-col items-center text-center">
                <div
                    class="flex items-center justify-center h-12 w-12 rounded-full bg-brand-sky text-white mb-6 shadow-md font-bold text-xl">
                    2
                </div>
                <h3 class="font-bold text-brand-earth-dark text-xl mb-4">Personlig konsultation</h3>
                <p class="text-neutral-700">
                    Vi återkommer till dig för en kort, kostnadsfri konsultation via telefon där vi diskuterar dina mål
                    mer i detalj och kommer överens om ett passande upplägg.
                </p>
            </div>

            <!-- Steg 3: Flexibel Tidsbokning -->
            <div
                class="bg-gradient-to-br from-brand-sky/5 to-brand-accent/5 p-8 rounded-xl shadow-sm border-2 border-brand-sky/20 flex flex-col items-center text-center">
                <div
                    class="flex items-center justify-center h-12 w-12 rounded-full bg-brand-sky text-white mb-6 shadow-md font-bold text-xl">
                    3
                </div>
                <h3 class="font-bold text-brand-earth-dark text-xl mb-4">Ditt första pass</h3>
                <p class="text-neutral-700">
                    Vi bokar in din första lektion på en tid som passar dig. Vi erbjuder vanligtvis tider alla dagar i
                    veckan mellan kl. 09:00 och 20:00, enligt överenskommelse.
                </p>
            </div>

        </div>
    </div>
</section>

<!-- ======================================= -->
<!-- Sektion 5: Anmälan, Pris & Praktisk Info -->
<!-- ======================================= -->
<section class="section-standard bg-brand-earth-light text-neutral-100 text-center" id="boka">
    <div class="container-base max-w-3xl">
        <h2 class="text-brand-earth-dark mb-6">Redo att ta nästa steg?</h2>
        <p class="text-lg text-brand-earth mb-10 leading-relaxed">
            Det första steget är en kort, kostnadsfri konsultation där vi diskuterar dina mål. Därefter skapar vi ett
            skräddarsytt upplägg och ger dig ett prisförslag. Många av våra elever märker tydliga framsteg redan efter
            ett par lektioner.
            <br /><span class="text-brand-earth-dark font-semibold">Din förfrågan är helt förutsättningslös.</span>
        </p>

        <a href="/kontakt/?subject=Kursintresse%3A%20Privatundervisning%20Tai%20Chi"
            class="btn btn-primary-on-dark text-xl px-10 py-5 shadow-lg shadow-black/20 mb-8">
            Diskutera ett personligt upplägg
        </a>

        <p class="text-brand-earth-dark mb-12 italic">
            {/* {%set tel = get_contact_detail('tel')%} */}
            Har du specifika frågor innan du kontaktar oss? Ring oss gärna på <a href="tel:[tel|clean_tel]"
                class="text-brand-sky underline hover:text-brand-sky-bright">[tel]</a>.
        </p>

        <!-- Praktisk Info List -->
        <div
            class="flex flex-col md:flex-row justify-center gap-6 md:gap-12 text-sm md:text-base border-t border-brand-earth-dark/10 pt-8 text-brand-earth-dark">
            <div class="flex flex-col items-start text-left">
                <div class="flex items-center">
                    <svg class="h-10 w-10 text-brand-earth-dark mr-2" fill="none" stroke="currentColor"
                        viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z">
                        </path>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
                    </svg>
                    <span class="font-bold text-brand-earth-dark text-xl">Platser</span>
                </div>
                <div>
                    <span>Våra kurser hålls i <a href="/kontakt/#mottagningar"
                            class="text-brand-sky hover:text-brand-sky-bright font-medium">Nyköping</a>, <a
                            href="/kontakt/#mottagningar"
                            class="text-brand-sky hover:text-brand-sky-bright font-medium">Gnesta</a> och <a
                            href="/kontakt/#mottagningar"
                            class="text-brand-sky hover:text-brand-sky-bright font-medium">Oxelösund</a>.</span>
                </div>
            </div>
            <div class="flex flex-col items-start text-left">
                <div class="flex items-center">
                    <svg class="h-10 w-10 text-brand-earth-dark mr-2" fill="none" stroke="currentColor"
                        viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                    <span class="font-bold text-brand-earth-dark text-xl">Friskvårdsbidrag</span>
                </div>
                <div>
                    <span>
                        Använd ditt Friskvårdsbidrag! Alla våra lektioner är godkända.
                        <br />
                        <a href="/friskvardsbidrag/" class="text-brand-sky hover:text-brand-sky-bright font-medium">Läs
                            mer här &rarr;</a></span>
                </div>
            </div>
            <div class="flex flex-col items-start text-left">
                <div class="flex items-center">
                    <svg class="h-10 w-10 text-brand-earth-dark mr-2" fill="none" stroke="currentColor"
                        viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M12 8v13m0-13V6a2 2 0 112 2h-2zm0 0V5.5A2.5 2.5 0 109.5 8H12zm-7 4h14M5 12a2 2 0 110-4h14a2 2 0 110 4M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7">
                        </path>
                    </svg>
                    <span class="font-bold text-brand-earth-dark text-xl">Presentkort</span>
                </div>
                <div>
                    <span>
                        Ge bort en upplevelse av hälsa och vitalitet med ett presentkort i Tai Chi.
                        <br />
                        <a href="/presentkort/" class="text-brand-sky hover:text-brand-sky-bright font-medium">Läs mer
                            om
                            våra presentkort &rarr;</a></span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ======================================= -->
<!-- Sektion 6: Vanliga frågor (FAQ)         -->
<!-- ======================================= -->
<section id="faq" class="section-standard bg-white">
    <div class="container-base max-w-3xl" x-data="{ active: null }">
        <div class="text-center mb-12">
            <h2 class="text-brand-earth">Frågor och Svar om Privatundervisning</h2>
        </div>

        <div class="space-y-4">

            <!-- Fråga 1 -->
            <div class="border border-neutral-200 rounded-lg overflow-hidden">
                <button @click="active === 1 ? active = null : active = 1"
                    class="w-full flex justify-between items-center p-5 bg-neutral-50 hover:bg-neutral-100 transition-colors focus:outline-none focus:bg-brand-accent/30">
                    <span class="font-bold text-brand-earth text-left">För vem passar privatundervisning bäst?</span>
                    <span class="ml-4 text-brand-sky transform transition-transform"
                        :class="active === 1 ? 'rotate-180' : ''">
                        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                        </svg>
                    </span>
                </button>
                <div x-show="active === 1" x-collapse x-cloak
                    class="p-5 bg-white text-neutral-700 leading-relaxed border-t border-neutral-100">
                    Det passar alla, men är särskilt värdefullt för dig som har specifika hälsomål, ett oregelbundet
                    schema, vill lära dig i avskildhet eller helt enkelt vill ha den effektivaste och mest
                    skräddarsydda inlärningen.
                </div>
            </div>

            <!-- Fråga 2 -->
            <div class="border border-neutral-200 rounded-lg overflow-hidden">
                <button @click="active === 2 ? active = null : active = 2"
                    class="w-full flex justify-between items-center p-5 bg-neutral-50 hover:bg-neutral-100 transition-colors focus:outline-none focus:bg-brand-accent/30">
                    <span class="font-bold text-brand-earth text-left">Kan vi vara två personer, t.ex. ett par eller
                        vänner?</span>
                    <span class="ml-4 text-brand-sky transform transition-transform"
                        :class="active === 2 ? 'rotate-180' : ''">
                        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                        </svg>
                    </span>
                </button>
                <div x-show="active === 2" x-collapse x-cloak
                    class="p-5 bg-white text-neutral-700 leading-relaxed border-t border-neutral-100">
                    Absolut! Vi erbjuder även privatundervisning för par eller små grupper om 2-3 personer. Kontakta
                    oss så skräddarsyr vi ett upplägg och ger er ett prisförslag.
                </div>
            </div>

            <!-- Fråga 3 -->
            <div class="border border-neutral-200 rounded-lg overflow-hidden">
                <button @click="active === 3 ? active = null : active = 3"
                    class="w-full flex justify-between items-center p-5 bg-neutral-50 hover:bg-neutral-100 transition-colors focus:outline-none focus:bg-brand-accent/30">
                    <span class="font-bold text-brand-earth text-left">Vad kostar en privatlektion?</span>
                    <span class="ml-4 text-brand-sky transform transition-transform"
                        :class="active === 3 ? 'rotate-180' : ''">
                        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                        </svg>
                    </span>
                </button>
                <div x-show="active === 3" x-collapse x-cloak
                    class="p-5 bg-white text-neutral-700 leading-relaxed border-t border-neutral-100">
                    Pris ges vid förfrågan och baseras på uppläggets längd och frekvens. Eftersom varje lektion är
                    skräddarsydd, diskuterar vi priset under vår inledande konsultation för att säkerställa att du
                    får ett upplägg som passar både dina mål och din budget.
                </div>
            </div>

            <!-- Fråga 4 -->
            <div class="border border-neutral-200 rounded-lg overflow-hidden">
                <button @click="active === 4 ? active = null : active = 4"
                    class="w-full flex justify-between items-center p-5 bg-neutral-50 hover:bg-neutral-100 transition-colors focus:outline-none focus:bg-brand-accent/30">
                    <span class="font-bold text-brand-earth text-left">Hur lång är en lektion?</span>
                    <span class="ml-4 text-brand-sky transform transition-transform"
                        :class="active === 4 ? 'rotate-180' : ''">
                        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                        </svg>
                    </span>
                </button>
                <div x-show="active === 4" x-collapse x-cloak
                    class="p-5 bg-white text-neutral-700 leading-relaxed border-t border-neutral-100">
                    En standardlektion är 60 minuter, men anpassas efter behov.
                </div>
            </div>

            <!-- Fråga 5 -->
            <div class="border border-neutral-200 rounded-lg overflow-hidden">
                <button @click="active === 5 ? active = null : active = 5"
                    class="w-full flex justify-between items-center p-5 bg-neutral-50 hover:bg-neutral-100 transition-colors focus:outline-none focus:bg-brand-accent/30">
                    <span class="font-bold text-brand-earth text-left">Hur ofta bör jag träna?</span>
                    <span class="ml-4 text-brand-sky transform transition-transform"
                        :class="active === 5 ? 'rotate-180' : ''">
                        <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                        </svg>
                    </span>
                </button>
                <div x-show="active === 5" x-collapse x-cloak
                    class="p-5 bg-white text-neutral-700 leading-relaxed border-t border-neutral-100">
                    Det fina med privatundervisning är att vi anpassar frekvensen efter din inlärningstakt och ditt
                    schema. Vissa vill ha veckovisa pass för kontinuitet, medan andra bokar mer sällan för att djupdyka
                    i specifika detaljer de sedan tränar på själva.
                </div>
            </div>

        </div>
    </div>
</section>
</BaseLayout>
