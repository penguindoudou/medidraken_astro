---
import { Image } from 'astro:assets';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Icon from '../../../components/Icon.astro';

// Images
import qigong_bamboo15Image from '../../../assets/images/qigong_bamboo15.png';
import { siteConfig } from '../../../data/site.ts';
import { coursesQigong } from '../../../data/courses.ts';

// Filtrera framtida kurser eller de som pågår
const activeCourses = coursesQigong.filter(course => new Date(course.lastDate) >= new Date(new
Date().setHours(0,0,0,0)));

---

<BaseLayout title="Helgkurser i Medicinsk Qigong">
    <!-- ======================================= -->
    <!-- Sektion 1: Hero                         -->
    <!-- ======================================= -->
    <section class="hero-section">
        <div class="hero-background">
            <Image src={qigong_bamboo15Image} alt="Helgkurs i Medicinsk Qigong - Djupgående intensivkurs"
                class="hero-bg-image" />
        </div>

        <div class="hero-content">
            <h1 class="hero-title text-brand-accent text-balance">Helgkurs i Medicinsk Qigong</h1>

            <div class="hero-text bg-brand-earth-dark/20 p-6 rounded-lg backdrop-blur-sm border border-white/10">
                <h2 class="hero-subtitle font-bold mb-3">Lär dig en komplett Qigong-metod på en Helg</h2>

                <p class="hero-text mt-0">
                    Våra helgkurser är det snabbaste sättet att få en solid grund i Medicinsk Qigong. Under två
                    intensiva
                    dagar får du möjlighet att helt fördjupa dig i övningarna, aktivera kroppens energiflöde och lämna
                    helgen
                    med ett komplett kraftfullt verktyg du kan använda för din hälsa livet ut.
                </p>
            </div>

            <div class="mt-10">
                <a href="#kursstarter" class="btn btn-primary-on-dark">
                    Se kommande helgkurser & anmäl intresse
                </a>
            </div>
        </div>
    </section>

    <!-- ======================================= -->
    <!-- Sektion 2: Fördelarna med en Intensiv Helgkurs -->
    <!-- ======================================= -->
    <section class="section-standard bg-white">
        <div class="container-base">
            <div class="text-center mb-12 max-w-3xl mx-auto">
                <h2 class="text-brand-earth">Varför välja en Helgkurs?</h2>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-8">

                <!-- Feature Box 1: En Snabb & Effektiv Start -->
                <div class="content-box flex flex-col items-center text-center">
                    <div class="flex items-center justify-center h-16 w-16 rounded-full bg-brand-accent/20 mb-4">
                        <Icon name="lightening" class="h-12 w-12 text-brand-accent-dark" stroke-width="1.2" />
                    </div>

                    <h3 class="text-xl font-bold text-neutral-900 mb-3">En Snabb & Effektiv Start</h3>
                    <p class="text-neutral-700">
                        Istället för att lära dig en rörelse i taget under en hel termin får du en komplett
                        hälsometod på bara en helg. För dig som är ny är detta det snabbaste sättet att lära sig en
                        komplett
                        Qigong-metod.
                    </p>
                </div>

                <!-- Feature Box 2: Total Fokus & Djupdykning -->
                <div class="content-box flex flex-col items-center text-center">
                    <div class="flex items-center justify-center h-16 w-16 rounded-full bg-brand-accent/20 mb-4">
                        <!-- Ikon: Fokus/Djupdykning (Magnifying Glass with Plus) -->
                        <svg class="h-10 w-10 text-brand-accent-dark" fill="none" stroke="currentColor"
                            viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7"></path>
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 7v6m-3-3h6">
                            </path>
                        </svg>
                    </div>
                    <h3 class="text-xl font-bold text-neutral-900 mb-3">Total Fokus & Djupdykning</h3>
                    <p class="text-neutral-700">
                        När vi tränar flera timmar i sträck balanseras nervsystemet på djupet. Du lämnar vardagens
                        distraktioner bakom dig och kan helt fokusera på energi, hälsa och återhämtning.
                    </p>
                </div>

                <!-- Feature Box 3: Enkelt att planera -->
                <div class="content-box flex flex-col items-center text-center">
                    <div class="flex items-center justify-center h-16 w-16 rounded-full bg-brand-accent/20 mb-4">
                        <Icon name="calendar" class="h-10 w-10 text-brand-accent-dark" />
                    </div>

                    <h3 class="text-xl font-bold text-neutral-900 mb-3">Enkelt att planera</h3>
                    <p class="text-neutral-700">
                        Perfekt för dig med en välfylld kalender, oförutsägbar vardag eller för dig som bor en bit bort.
                        En
                        helgkurs kräver bara en helg för att etablera ett verktyg som kan förbättra din hälsa livet ut.
                    </p>
                </div>

            </div>
        </div>
    </section>

    <!-- ======================================= -->
    <!-- Sektion 3: Kursupplägg & Innehåll       -->
    <!-- ======================================= -->
    <section class="section-standard bg-brand-earth-lightest">
        <div class="container-base">
            <div class="max-w-4xl mx-auto">
                <h2 class="text-brand-earth text-center mb-10">Hur en Helgkurs Går Till</h2>

                <div class="bg-white rounded-xl p-8 md:p-10 shadow-sm border border-neutral-200">

                    <!-- Section 1: Upplägget: I praktiken -->
                    <div class="mb-12">
                        <h3 class="font-bold text-brand-earth-dark text-2xl md:text-3xl mb-8 text-center tracking-wide">
                            Upplägget: I praktiken</h3>
                        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

                            <!-- Stage 1: Rakt på sak -->
                            <div
                                class="bg-gradient-to-br from-brand-earth/5 to-brand-accent/5 rounded-xl p-6 border-2 border-brand-earth/20 shadow-sm">
                                <div class="flex flex-col items-center text-center h-full">
                                    <div
                                        class="flex items-center justify-center h-16 w-16 rounded-full bg-brand-accent text-white mb-4 shadow-md">
                                        <Icon name="taichi_yinyang_mabu" class="h-10 w-10" />
                                    </div>
                                    <h4 class="font-bold text-brand-earth-dark text-lg mb-3">Rakt på sak</h4>
                                    <p class="text-neutral-700 text-sm leading-relaxed">
                                        Efter förberedande övningar för att mjuka upp kroppen går vi direkt på
                                        inlärningen
                                        av övningarna inom första timmen.
                                    </p>
                                </div>
                            </div>

                            <!-- Stage 2: Helheten & Energiflödet -->
                            <div
                                class="bg-gradient-to-br from-brand-earth/5 to-brand-accent/5 rounded-xl p-6 border-2 border-brand-earth/20 shadow-sm">
                                <div class="flex flex-col items-center text-center h-full">
                                    <div
                                        class="flex items-center justify-center h-16 w-16 rounded-full bg-brand-accent text-white mb-4 shadow-md">
                                        <Icon name="flower" class="h-8 w-8" />
                                    </div>
                                    <h4 class="font-bold text-brand-earth-dark text-lg mb-3">Helheten & Energiflödet
                                    </h4>
                                    <p class="text-neutral-700 text-sm leading-relaxed">
                                        Vi knyter ihop rörelserna till en komplett Qigong-metod.
                                    </p>
                                </div>
                            </div>

                            <!-- Stage 3: Integration & Pauser -->
                            <div
                                class="bg-gradient-to-br from-brand-earth/5 to-brand-accent/5 rounded-xl p-6 border-2 border-brand-earth/20 shadow-sm">
                                <div class="flex flex-col items-center text-center h-full">
                                    <div
                                        class="flex items-center justify-center h-16 w-16 rounded-full bg-brand-accent text-white mb-4 shadow-md">
                                        <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <!-- Bell Icon -->
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9">
                                            </path>
                                        </svg>
                                    </div>
                                    <h4 class="font-bold text-brand-earth-dark text-lg mb-3">Integration & Pauser</h4>
                                    <p class="text-neutral-700 text-sm leading-relaxed">
                                        Vi varvar träning med regelbundna pauser så att både kropp och sinne hinner
                                        återhämta sig och absorbera övningarna.
                                    </p>
                                </div>
                            </div>

                        </div>
                    </div>

                    <!-- Section 2: Vår Pedagogik: Upplevelsebaserad hälsa -->
                    <div class="mb-10">
                        <h3 class="font-bold text-brand-earth-dark text-2xl md:text-3xl mb-8 text-center tracking-wide">
                            Vår Pedagogik: Upplevelsebaserad Hälsa</h3>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">

                            <!-- Pedagogik 1: Direkt Effekt -->
                            <div
                                class="bg-gradient-to-br from-brand-accent/5 to-brand-earth/5 rounded-xl p-8 border-2 border-brand-accent/20 shadow-sm">
                                <div class="flex flex-col items-center text-center h-full">
                                    <div
                                        class="flex items-center justify-center h-20 w-20 rounded-full bg-brand-accent/20 mb-6">
                                        <Icon name="holistic_qi_human" class="h-14 w-14 text-brand-accent-dark" />
                                    </div>
                                    <h4 class="font-bold text-brand-earth-dark text-xl mb-4">Direkt Effekt</h4>
                                    <p class="text-neutral-700 text-base leading-relaxed">
                                        Vår undervisning är utformad för att vara direkt och upplevelsebaserad. Vi
                                        fokuserar
                                        på att du ska känna övningarnas direkta effekt på kropp och sinne redan under
                                        kursens gång.
                                    </p>
                                </div>
                            </div>

                            <!-- Pedagogik 2: Långsiktig Hälsa -->
                            <div
                                class="bg-gradient-to-br from-brand-accent/5 to-brand-earth/5 rounded-xl p-8 border-2 border-brand-accent/20 shadow-sm">
                                <div class="flex flex-col items-center text-center h-full">

                                    <div
                                        class="flex items-center justify-center h-20 w-20 rounded-full bg-brand-accent/20 mb-6">
                                        <Icon name="shield_health" class="h-12 w-12 text-brand-accent-dark" />
                                    </div>
                                    <h4 class="font-bold text-brand-earth-dark text-xl mb-4">Långsiktig Hälsa</h4>
                                    <p class="text-neutral-700 text-base leading-relaxed">
                                        Vi lär inte bara ut rörelser; vi ger dig kraftfulla verktyg för din hälsa. Du
                                        lämnar
                                        helgen med en metod du omedelbart kan använda när och var du vill.
                                    </p>
                                </div>
                            </div>

                        </div>
                    </div>

                    <!-- Practical Info & Alternative -->
                    <div class="space-y-6 pt-6 border-t border-neutral-200">
                        <div class="bg-brand-sky/5 rounded-xl p-6 border border-brand-sky/20 flex items-start gap-4">
                            <div class="text-brand-sky mt-1 shrink-0">
                                <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                </svg>
                            </div>
                            <div>
                                <h4 class="font-bold text-neutral-900 mb-1">Praktisk info om lunch</h4>
                                <p class="text-neutral-700 text-sm md:text-base">Lunch ingår ej, men vi brukar uppmuntra
                                    till ett gemensamt knytkalas för de som önskar!</p>
                            </div>
                        </div>

                        <div class="text-center">
                            <p class="text-neutral-700 italic">
                                Föredrar du ett flexiblare upplägg anpassat till dig?
                                <br class="hidden md:block">
                                Utforska våra <a href="/kurser/medicinsk-qigong/privatundervisning/"
                                    class="text-brand-sky font-semibold underline hover:text-brand-accent transition-colors">privatlektioner</a>
                            </p>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </section>



    <!-- ======================================= -->
    <!-- Sektion 5: Aktuella Kursstarter (Logic) -->
    <!-- ======================================= -->
    <section class="section-standard bg-white" id="kursstarter">
        <div class="container-base">
            <h2 class="text-brand-earth text-center mb-10">Kommande Helgkurser i Medicinsk Qigong</h2>


            {activeCourses.length > 0 ? (
            <!-- Active Courses Table -->
            <div class="overflow-x-auto shadow-md rounded-lg max-w-5xl mx-auto border border-neutral-200">
                <table class="min-w-full leading-normal">
                    <thead>
                        <tr>
                            <th
                                class="px-5 py-3 border-b-2 border-brand-earth bg-brand-earth-lightest text-left text-xs font-semibold text-brand-earth uppercase tracking-wider">
                                Kursnamn / Nivå</th>
                            <th
                                class="px-5 py-3 border-b-2 border-brand-earth bg-brand-earth-lightest text-left text-xs font-semibold text-brand-earth uppercase tracking-wider">
                                Ort</th>
                            <th
                                class="px-5 py-3 border-b-2 border-brand-earth bg-brand-earth-lightest text-left text-xs font-semibold text-brand-earth uppercase tracking-wider">
                                Datum</th>
                            <th
                                class="px-5 py-3 border-b-2 border-brand-earth bg-brand-earth-lightest text-left text-xs font-semibold text-brand-earth uppercase tracking-wider">
                                Tider</th>
                            <th class="px-5 py-3 border-b-2 border-brand-earth bg-brand-earth-lightest"></th>
                        </tr>
                    </thead>
                    <tbody>
                        {activeCourses.map(course => (
                        <tr>
                            <td class="px-5 py-5 border-b border-gray-200 bg-white text-sm">
                                <p class="text-gray-900 whitespace-no-wrap font-semibold">{course.title}</p>
                            </td>
                            <td class="px-5 py-5 border-b border-gray-200 bg-white text-sm">
                                <p class="text-gray-900 whitespace-no-wrap">{course.location}</p>
                            </td>
                            <td class="px-5 py-5 border-b border-gray-200 bg-white text-sm">
                                <p class="text-gray-900 whitespace-no-wrap">{course.date}</p>
                            </td>
                            <td class="px-5 py-5 border-b border-gray-200 bg-white text-sm">
                                <p class="text-gray-900 whitespace-no-wrap">{course.times}</p>
                            </td>
                            <td class="px-5 py-5 border-b border-gray-200 bg-white text-sm text-right">
                                <a href={course.link} class="text-brand-sky hover:text-brand-accent-dark font-bold">Boka
                                    &rarr;</a>
                            </td>
                        </tr>
                        ))}
                    </tbody>
                </table>
            </div>
            ) : (
            <!-- Fallback Block -->
            <div
                class="max-w-4xl mx-auto border-2 border-dashed border-neutral-300 rounded-xl p-8 md:p-12 bg-neutral-50">
                <h3 class="font-heading text-2xl text-brand-earth mb-4 text-center">Så här kommer du igång!</h3>
                <p class="text-neutral-700 mb-10 text-center max-w-2xl mx-auto">
                    Just nu har vi inga schemalagda helgkurser, men det finns flera sätt att få en djupgående start i
                    Medicinsk Qigong.
                </p>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-4 min-[890px]:gap-8">

                    <!-- Väg 1: Intresseanmälan -->
                    <div
                        class="bg-gradient-to-br from-brand-sky/5 to-brand-accent/5 p-8 md:p-4 min-[890px]:p-8 rounded-lg shadow-sm border-2 border-brand-sky/20 hover:-translate-y-1 transition-transform duration-300">
                        <div
                            class="flex items-center justify-center h-12 w-12 rounded-full bg-brand-sky text-white mb-4 shadow-md">
                            <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M8 7V3m8 4V3M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z">
                                </path>
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                    d="M12 10.5l.9 1.8 2 .3-1.45 1.4.35 2-1.8-.95-1.8.95.35-2-1.45-1.4 2-.3.9-1.8z"
                                    fill="currentColor"></path>
                            </svg>
                        </div>
                        <h4
                            class="font-bold text-brand-earth-dark text-xl md:text-base min-[890px]:text-xl mb-3 hyphens-auto">
                            Intresseanmälan för nästa kurs</h4>
                        <p class="text-neutral-700 mb-6">
                            Var först med att få info om nästa planerade helgkurs. Genom att anmäla intresse hjälper du
                            oss
                            planera.
                        </p>
                        <a href="#anmalan" class="btn-tertiary font-semibold">Anmäl intresse &rarr;</a>
                    </div>

                    <!-- Väg 2: Privatundervisning -->
                    <div
                        class="bg-gradient-to-br from-brand-sky/5 to-brand-accent/5 p-8 md:p-4 min-[890px]:p-8 rounded-lg shadow-sm border-2 border-brand-sky/20 hover:-translate-y-1 transition-transform duration-300">
                        <div
                            class="flex items-center justify-center h-12 w-12 rounded-full bg-brand-sky text-white mb-4 shadow-md">
                            <!-- Magnifying Glass on Person Icon -->
                            <svg class="h-8 w-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                    d="M21 21l-4.8-4.8m1.3-5.7a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                                <circle cx="10.5" cy="8" r="1.8" stroke="currentColor" stroke-width="1.5" fill="none">
                                </circle>
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                    d="M7 13c0-1.933 1.567-3.5 3.5-3.5s3.5 1.567 3.5 3.5"></path>
                            </svg>
                        </div>
                        <h4
                            class="font-bold text-brand-earth-dark text-xl md:text-base min-[890px]:text-xl mb-3 hyphens-auto">
                            Privatundervisning</h4>
                        <p class="text-neutral-700 mb-6">
                            Få 100% odelad uppmärksamhet och undervisning anpassad för dig.
                        </p>
                        <a href="/kurser/medicinsk-qigong/privatundervisning/" class="btn-tertiary font-semibold">Läs
                            mer &rarr;</a>
                    </div>

                    <!-- Väg 3: Egen Grupp -->
                    <div
                        class="bg-gradient-to-br from-brand-sky/5 to-brand-accent/5 p-8 md:p-4 min-[890px]:p-8 rounded-lg shadow-sm border-2 border-brand-sky/20 hover:-translate-y-1 transition-transform duration-300">
                        <div
                            class="flex items-center justify-center h-12 w-12 rounded-full bg-brand-sky text-white mb-4 shadow-md">
                            <!-- Group of People Icon -->
                            <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z">
                                </path>
                            </svg>
                        </div>
                        <h4
                            class="font-bold text-brand-earth-dark text-xl md:text-base min-[890px]:text-xl mb-3 hyphens-auto">
                            Egen Grupp</h4>
                        <p class="text-neutral-700 mb-6">
                            Perfekt för arbetsplatsen eller kompisgänget. Vi skapar ett upplägg som passar er kalender
                            och
                            Era önskemål.
                        </p>
                        <a href="/upplevelser/workshops-gruppaktiviteter/" class="btn-tertiary font-semibold">Läs mer
                            &rarr;</a>
                    </div>

                </div>
            </div>
            )}
        </div>
    </section>

    <!-- ======================================= -->
    <!-- Sektion 6: Anmälan & Info (CTA)   -->
    <!-- ======================================= -->
    <section class="bg-brand-earth-light section-standard text-center" id="anmalan">
        <div class="container-base max-w-4xl">
            <!-- Huvud CTA -->
            <div class="max-w-3xl mx-auto mb-16">
                <h2 class="text-brand-earth-dark mb-6 text-3xl md:text-5xl">Redo att ge din hälsa en kraftfull nystart?
                </h2>
                <p class="text-brand-earth-dark text-lg md:text-xl leading-relaxed mb-10">
                    Nya helgkurser planeras löpande. Det enklaste sättet att få all information du behöver är att anmäla
                    ditt intresse. Då kontaktar vi dig personligen med information om kommande start och upplägg.
                    <br /><span class="text-brand-earth-dark font-semibold">Din anmälan är helt kostnadsfri och inte
                        bindande.</span>
                </p>

                <a href="/kontakt/?subject=qigong&sub=helgkurs#tidsbokning"
                    class="btn btn-primary-on-dark shadow-lg shadow-black/10 px-10 py-5 text-xl mb-6">
                    Anmäl intresse & få mer information
                </a>

                <p class="text-brand-earth-dark mb-0 italic">
                    {/* {%set tel = get_contact_detail('tel')%} */}
                    Har du frågor om upplägget? Ring oss gärna på <a href={`tel:${siteConfig.phone.clean}`}
                        class="text-brand-sky underline hover:text-brand-sky-dark">{siteConfig.phone.display}</a>.
                </p>
            </div>

            <!-- Trust & Info Row (Discrete boxes with icon containers) -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 md:gap-8 pt-6 mt-0 border-t border-brand-earth-dark/10">

                <!-- Column 1: Platser -->
                <div
                    class="group bg-brand-earth-dark/5 rounded-2xl p-6 shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-300 border-2 border-brand-earth-dark/10 flex flex-col items-start text-left">
                    <div class="flex items-center mb-4">
                        <div
                            class="flex items-center justify-center h-10 w-10 rounded-full bg-brand-earth-dark/25 mr-3">
                            <div class="relative flex h-3 w-3 items-center justify-center">
                                <span
                                    class="animate-ping absolute inline-flex h-full w-full rounded-full bg-brand-accent opacity-75"></span>
                                <span class="relative inline-flex rounded-full h-2 w-2 bg-brand-accent"></span>
                            </div>
                        </div>
                        <span class="font-bold text-brand-earth-dark text-xl">Platser</span>
                    </div>
                    <div class="text-neutral-700 leading-relaxed text-sm md:text-base flex-grow">
                        Våra kurser hålls i <a href="/kontakt/#mottagningar"
                            class="text-brand-sky hover:text-brand-sky-dark font-medium underline decoration-brand-sky/20 underline-offset-4">Nyköping</a>,
                        <a href="/kontakt/#mottagningar"
